{
  "name": "velnora-website",
  "version": "1.0.0",
  "description": "Velnora - Elegant AI Intelligence Engine",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "validate:tools": "node scripts/validate-tools.mjs",
    "validate:utility-support": "node scripts/validate-utility-support.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "generate:image-sitemap": "node scripts/generate-image-sitemap.mjs",
    "optimize:images": "node scripts/seo/optimize-images.mjs",
    "seo:keywords": "node scripts/seo/research-keywords-apify.mjs",
    "seo:plan": "node scripts/seo/build-seo-plan.mjs",
    "cloudflare:images": "node scripts/upload-cloudflare-images.mjs",
    "cloudflare:images:dry": "node scripts/upload-cloudflare-images.mjs --dry-run",
    "cloudflare:purge": "node scripts/cloudflare/purge-velnora-cache.mjs",
    "scrape:convertio": "node scripts/scrape-convertio-formats.mjs",
    "generate:wiki": "node scripts/generate-velnora-wiki.mjs",
    "refresh:intel": "npm run scrape:convertio && npm run generate:wiki",
    "build": "npm run validate:tools && npm run validate:utility-support && npm run optimize:images && npm run generate:sitemap && npm run generate:image-sitemap && astro build",
    "check:routes": "node scripts/check-routes.mjs",
    "check:routes:deep": "node scripts/check-routes.mjs --deep",
    "check:security": "node scripts/check-security-headers.mjs",
    "test:seo:render": "node scripts/seo/test-renderer.mjs",
    "test:seo:perf": "node scripts/seo/test-performance.mjs",
    "test:seo:links": "node scripts/seo/test-local-crawl.mjs",
    "test:seo": "npm run test:seo:render && npm run test:seo:perf && npm run test:seo:links",
    "gsc:enable-api": "node scripts/seo/gsc-enable-api.mjs",
    "gsc:check": "node scripts/seo/gsc-check.mjs",
    "gsc:indexing": "node scripts/seo/gsc-request-indexing.mjs",
    "audit:prod": "npm audit --omit=dev",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.79",
    "astro": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "pdf-lib": "^1.17.1",
    "preact": "^10.19.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@astrojs/preact": "^3.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "@astrojs/tailwind": "^6.0.2",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "google-auth-library": "^10.6.2",
    "lighthouse": "^13.1.0",
    "postcss": "^8.5.9",
    "puppeteer": "^24.41.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
