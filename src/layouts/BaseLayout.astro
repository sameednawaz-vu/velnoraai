---
import '../styles/tailwind.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedDate?: string;
  author?: string;
}

const { title, description = "Velnora - Execution-first AI Utility Workspace", image, article = false, publishedDate, author } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const gaId = import.meta.env.PUBLIC_GA_ID;
const shouldLoadAnalytics = Boolean(gaId) && canonicalURL.hostname === 'velnoraai.app';
const imageCdnBase = (import.meta.env.PUBLIC_IMAGE_CDN_BASE ?? '').trim().replace(/\/+$/, '');
const withImageCdn = (assetPath: string) => {
  const normalizedPath = assetPath.startsWith('/') ? assetPath : `/${assetPath}`;
  return imageCdnBase ? `${imageCdnBase}${normalizedPath}` : normalizedPath;
};
const imageCdnOrigin = (() => {
  if (!imageCdnBase) {
    return '';
  }

  try {
    return new URL(imageCdnBase).origin;
  } catch {
    return '';
  }
})();
const defaultOgImage = withImageCdn('/images/favicon-velnora.webp');
const faviconSvgImage = withImageCdn('/images/favicon-velnora.svg');
const faviconFallbackImage = withImageCdn('/images/favicon-velnora.webp');
const socialImage = image ?? defaultOgImage;
const shouldLoadDynamicSchema = Astro.url.pathname.startsWith('/utility/');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#FFF9ED" />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta name="generator" content="Astro" />

  {imageCdnOrigin && <link rel="preconnect" href={imageCdnOrigin} crossorigin />}

  <title>{title} | Velnora</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- OG Tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={article ? "article" : "website"} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={socialImage} />
  <meta property="og:image:alt" content={`${title} | Velnora`} />
  <meta property="og:site_name" content="Velnora" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImage} />
  <meta name="twitter:image:alt" content={`${title} | Velnora`} />
  
  {article && publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )}
  {article && author && (
    <meta property="article:author" content={author} />
  )}
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={faviconSvgImage} />
  <link rel="alternate icon" type="image/webp" href={faviconFallbackImage} />
  <link rel="apple-touch-icon" href={faviconFallbackImage} />
  
  {shouldLoadAnalytics && (
    <>
      <!-- Google Analytics 4 (optional, controlled via PUBLIC_GA_ID) -->
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )}

  {shouldLoadDynamicSchema && <script type="module" src="/schema-generator.js"></script>}

  <script>
    if (typeof window !== 'undefined') {
      window.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[data-reveal]').forEach((node) => node.classList.add('is-visible'));
      });

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {
            // Ignore registration errors in unsupported/private modes.
          });
        });
      }
    }
  </script>
  
  <style is:global>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      --color-primary: #132239;
      --color-secondary: #ff5d3d;
      --color-accent: #0a8a82;
      --color-background: #fff9ed;
      --color-background-soft: #f8f3e4;
      --color-text: #20314a;
      --color-border: #e5d8bf;
      --color-card-bg: #fffdf7;
      --color-cyan: #0a8a82;
      --color-purple: #ff5d3d;
      --color-highlight: #ffc53d;
      --font-display: 'Palatino Linotype', 'Book Antiqua', Palatino, serif;
      --font-sans: 'Trebuchet MS', 'Segoe UI', Tahoma, sans-serif;
      --shadow-soft: 0 10px 30px rgba(20, 42, 68, 0.08);
      --shadow-medium: 0 20px 42px rgba(16, 40, 66, 0.14);
    }
    
    html {
      font-family: var(--font-sans);
      background: radial-gradient(circle at 12% 10%, rgba(255, 197, 61, 0.35), transparent 45%),
                  radial-gradient(circle at 85% 4%, rgba(10, 138, 130, 0.2), transparent 35%),
                  linear-gradient(180deg, #fff9ed 0%, #fff3de 100%);
      background-attachment: fixed;
      color: var(--color-text);
    }
    
    body {
      line-height: 1.6;
      min-height: 100vh;
      position: relative;
      color: var(--color-text);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: linear-gradient(rgba(19, 34, 57, 0.05) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(19, 34, 57, 0.05) 1px, transparent 1px);
      background-size: 52px 52px;
      mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), transparent 76%);
      z-index: 0;
    }

    body > * {
      position: relative;
      z-index: 1;
    }
    
    h1, h2, h3, h4, h5, h6 {
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--color-primary);
    }
    
    h1, .display-heading {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 1.08;
    }

    h2 {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 3.2vw, 2.35rem);
      line-height: 1.15;
    }

    h3 {
      font-size: clamp(1.15rem, 2vw, 1.45rem);
      line-height: 1.25;
    }
    
    a {
      color: var(--color-accent);
      text-decoration: none;
      transition: color 0.2s ease, opacity 0.2s ease;
    }
    
    a:hover {
      color: #066861;
    }
    
    button {
      padding: 0.74rem 1.15rem;
      border: 1px solid transparent;
      border-radius: 0.55rem;
      font-weight: 600;
      cursor: pointer;
      font-family: var(--font-sans);
      transition: all 0.18s ease;
    }
    
    button.primary {
      background: linear-gradient(135deg, var(--color-secondary) 0%, #ff7f2f 100%);
      color: white;
      box-shadow: var(--shadow-soft);
    }
    
    button.primary:hover {
      background: linear-gradient(135deg, #ff6a3f 0%, #ff963f 100%);
      box-shadow: var(--shadow-medium);
      transform: translateY(-1px);
    }

    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: opacity 0.35s ease, transform 0.35s ease;
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: none;
    }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] {
        opacity: 1;
        transform: none;
        transition: none;
      }

      * {
        scroll-behavior: auto !important;
      }
    }

  </style>
</head>
<body>
  <slot />
</body>
</html>
