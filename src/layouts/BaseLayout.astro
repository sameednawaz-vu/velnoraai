---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: boolean;
  publishedDate?: string;
  author?: string;
}

const { title, description = "Velnora - Elegant AI Intelligence Engine", image, article = false, publishedDate, author } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const gaId = import.meta.env.PUBLIC_GA_ID;
const defaultOgImage = 'https://velnoraai.app/images/og-velnora.png';
const socialImage = image ?? defaultOgImage;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#FFF9ED" />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <meta name="generator" content="Astro" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800&family=Sora:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <ViewTransitions />

  <title>{title} | Velnora</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- OG Tags -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={article ? "article" : "website"} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={socialImage} />
  <meta property="og:site_name" content="Velnora" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImage} />
  
  {article && publishedDate && (
    <meta property="article:published_time" content={publishedDate} />
  )}
  {article && author && (
    <meta property="article:author" content={author} />
  )}
  
  <!-- Favicon -->
  <link rel="icon" type="image/jpeg" href="/images/favicon-velnora.jpg" />
  <link rel="shortcut icon" type="image/jpeg" href="/images/favicon-velnora.jpg" />
  <link rel="apple-touch-icon" href="/images/favicon-velnora.jpg" />
  
  {gaId && (
    <>
      <!-- Google Analytics 4 (optional, controlled via PUBLIC_GA_ID) -->
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
      <script define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    </>
  )}

  <script>
    if (typeof window !== 'undefined') {
      window.addEventListener('DOMContentLoaded', () => {
        const targets = document.querySelectorAll('[data-reveal]');
        if (!('IntersectionObserver' in window) || targets.length === 0) {
          targets.forEach((node) => node.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );

        targets.forEach((node) => observer.observe(node));
      });
    }
  </script>

  <script>
    if (typeof window !== 'undefined') {
      const showLoader = () => {
        document.documentElement.classList.add('is-page-loading');
      };

      const hideLoader = () => {
        document.documentElement.classList.remove('is-page-loading');
      };

      const isModifiedClick = (event) =>
        event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0;

      const shouldTrackLink = (anchor) =>
        anchor.origin === window.location.origin &&
        anchor.target !== '_blank' &&
        !anchor.hasAttribute('download') &&
        !anchor.href.includes('#');

      document.addEventListener('click', (event) => {
        if (!(event.target instanceof Element) || isModifiedClick(event) || event.defaultPrevented) {
          return;
        }

        const anchor = event.target.closest('a[href]');
        if (!(anchor instanceof HTMLAnchorElement) || !shouldTrackLink(anchor)) {
          return;
        }

        showLoader();
      });

      document.addEventListener('astro:before-preparation', showLoader);
      document.addEventListener('astro:after-swap', hideLoader);
      window.addEventListener('pageshow', hideLoader);
      window.addEventListener('load', hideLoader, { once: true });
    }
  </script>
  
  <style is:global>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    :root {
      --color-primary: #132239;
      --color-secondary: #ff5d3d;
      --color-accent: #0a8a82;
      --color-background: #fff9ed;
      --color-background-soft: #f8f3e4;
      --color-text: #20314a;
      --color-border: #e5d8bf;
      --color-card-bg: #fffdf7;
      --color-cyan: #0a8a82;
      --color-purple: #ff5d3d;
      --color-highlight: #ffc53d;
      --font-display: 'Fraunces', Georgia, 'Times New Roman', serif;
      --font-sans: 'Sora', 'Segoe UI', Tahoma, sans-serif;
      --shadow-soft: 0 10px 30px rgba(20, 42, 68, 0.08);
      --shadow-medium: 0 20px 42px rgba(16, 40, 66, 0.14);
    }
    
    html {
      font-family: var(--font-sans);
      background: radial-gradient(circle at 12% 10%, rgba(255, 197, 61, 0.35), transparent 45%),
                  radial-gradient(circle at 85% 4%, rgba(10, 138, 130, 0.2), transparent 35%),
                  linear-gradient(180deg, #fff9ed 0%, #fff3de 100%);
      background-attachment: fixed;
      color: var(--color-text);
    }
    
    body {
      line-height: 1.6;
      min-height: 100vh;
      position: relative;
      color: var(--color-text);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image: linear-gradient(rgba(19, 34, 57, 0.05) 1px, transparent 1px),
                        linear-gradient(90deg, rgba(19, 34, 57, 0.05) 1px, transparent 1px);
      background-size: 52px 52px;
      mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), transparent 76%);
      z-index: 0;
    }

    body > * {
      position: relative;
      z-index: 1;
    }
    
    h1, h2, h3, h4, h5, h6 {
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--color-primary);
    }
    
    h1, .display-heading {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 1.08;
    }

    h2 {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 3.2vw, 2.35rem);
      line-height: 1.15;
    }

    h3 {
      font-size: clamp(1.15rem, 2vw, 1.45rem);
      line-height: 1.25;
    }
    
    a {
      color: var(--color-accent);
      text-decoration: none;
      transition: color 0.2s ease, opacity 0.2s ease;
    }
    
    a:hover {
      color: #066861;
    }
    
    button {
      padding: 0.74rem 1.15rem;
      border: 1px solid transparent;
      border-radius: 0.55rem;
      font-weight: 600;
      cursor: pointer;
      font-family: var(--font-sans);
      transition: all 0.18s ease;
    }
    
    button.primary {
      background: linear-gradient(135deg, var(--color-secondary) 0%, #ff7f2f 100%);
      color: white;
      box-shadow: var(--shadow-soft);
    }
    
    button.primary:hover {
      background: linear-gradient(135deg, #ff6a3f 0%, #ff963f 100%);
      box-shadow: var(--shadow-medium);
      transform: translateY(-1px);
    }

    [data-reveal] {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      [data-reveal] {
        opacity: 1;
        transform: none;
        transition: none;
      }

      * {
        scroll-behavior: auto !important;
      }
    }

    #global-page-loader {
      position: fixed;
      inset: 0;
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      display: grid;
      place-items: center;
      transition: opacity 0.2s ease;
      background: linear-gradient(180deg, rgba(255, 250, 239, 0.92), rgba(253, 243, 223, 0.94));
      backdrop-filter: blur(5px);
    }

    :global(html.is-page-loading) #global-page-loader {
      opacity: 1;
      pointer-events: auto;
    }

    .loader-shell {
      width: min(560px, calc(100vw - 2rem));
      border: 1px solid rgba(40, 60, 90, 0.15);
      border-radius: 0.95rem;
      background: rgba(255, 255, 255, 0.75);
      box-shadow: 0 20px 40px rgba(20, 42, 68, 0.16);
      padding: 1rem;
      display: grid;
      gap: 0.7rem;
    }

    .loader-top,
    .loader-line,
    .loader-chip {
      border-radius: 999px;
      background: linear-gradient(
        90deg,
        rgba(237, 224, 201, 0.9) 0%,
        rgba(255, 255, 255, 0.88) 45%,
        rgba(237, 224, 201, 0.9) 100%
      );
      background-size: 220% 100%;
      animation: loader-shimmer 1.2s linear infinite;
    }

    .loader-top {
      height: 16px;
      width: 48%;
    }

    .loader-line {
      height: 12px;
      width: 100%;
    }

    .loader-line.short {
      width: 72%;
    }

    .loader-chip-row {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.2rem;
    }

    .loader-chip {
      height: 30px;
      width: 108px;
      border-radius: 0.55rem;
    }

    @keyframes loader-shimmer {
      from {
        background-position: 0% 0%;
      }

      to {
        background-position: -220% 0%;
      }
    }
  </style>
</head>
<body>
  <div id="global-page-loader" aria-hidden="true">
    <div class="loader-shell">
      <div class="loader-top"></div>
      <div class="loader-line"></div>
      <div class="loader-line short"></div>
      <div class="loader-chip-row">
        <div class="loader-chip"></div>
        <div class="loader-chip"></div>
        <div class="loader-chip"></div>
      </div>
    </div>
  </div>

  <slot />
</body>
</html>
