---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  publishedDate: string;
  author: string;
  readingTime: number;
  image?: string;
  imageAlt?: string;
  imageCaption?: string;
}

const { title, description, publishedDate, author, readingTime, image, imageAlt, imageCaption } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: image || undefined,
  datePublished: publishedDate,
  dateModified: publishedDate,
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Velnora',
    url: 'https://velnoraai.app',
  },
  mainEntityOfPage: `https://velnoraai.app${Astro.url.pathname}`,
};
---

<BaseLayout title={title} description={description} image={image} article={true} publishedDate={publishedDate} author={author}>
  <Header />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <main class="page-shell blogpost-page">
    <article class="section-panel post-shell" data-reveal>
      <header class="post-header">
        <p class="eyebrow">Blog article</p>
        <h1>{title}</h1>
        <p class="lede">{description}</p>

        <div class="post-meta">
          <span>By {author}</span>
          <span>Updated {new Date(publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <span>{readingTime} min read</span>
        </div>
      </header>

      {image && (
        <figure class="post-hero-image">
          <img src={image} alt={imageAlt ?? `${title} illustration`} width="1200" height="630" loading="eager" decoding="async" />
          {imageCaption && <figcaption>{imageCaption}</figcaption>}
        </figure>
      )}

      <div class="article-content">
        <slot />
      </div>

      <footer class="post-footer">
        <a href="/blog" class="btn-link">Back to blog</a>
      </footer>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blogpost-page {
    max-width: 920px;
  }

  .post-shell {
    display: grid;
    gap: 0.95rem;
  }

  .post-header {
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 16%, transparent);
    padding-bottom: 0.72rem;
  }

  .post-meta {
    margin-top: 0.58rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
  }

  .post-meta span {
    border: 1px solid color-mix(in srgb, var(--color-secondary) 38%, transparent);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-secondary) 12%, transparent);
    color: color-mix(in srgb, var(--color-text) 84%, transparent);
    font-size: 0.7rem;
    padding: 0.17rem 0.48rem;
    font-family: var(--font-mono);
  }

  .article-content {
    display: grid;
    gap: 0.62rem;
    color: color-mix(in srgb, var(--color-text) 83%, transparent);
  }

  .post-hero-image {
    margin: 0;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 26%, var(--color-border));
    border-radius: 0.8rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
  }

  .post-hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-hero-image figcaption {
    padding: 0.52rem 0.66rem;
    font-size: 0.74rem;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    line-height: 1.55;
  }

  :global(.article-content h2) {
    margin: 0.45rem 0 0.14rem;
    font-size: 1.16rem;
    color: var(--color-primary);
  }

  :global(.article-content h3) {
    margin: 0.34rem 0 0.1rem;
    font-size: 0.98rem;
    color: color-mix(in srgb, var(--color-text) 92%, transparent);
  }

  :global(.article-content p) {
    margin: 0;
    line-height: 1.66;
    font-size: 0.88rem;
  }

  :global(.article-content ul),
  :global(.article-content ol) {
    margin: 0;
    padding-left: 1rem;
    display: grid;
    gap: 0.28rem;
    line-height: 1.55;
    font-size: 0.85rem;
  }

  :global(.article-content a) {
    color: var(--color-secondary);
    text-decoration: underline;
    text-decoration-thickness: 1px;
  }

  :global(.article-content code) {
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-text) 14%, transparent);
    border-radius: 0.3rem;
    padding: 0.05rem 0.26rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
  }

  :global(.article-content pre) {
    margin: 0.2rem 0;
    border-radius: 0.62rem;
    border: 1px solid color-mix(in srgb, var(--color-text) 14%, transparent);
    background: color-mix(in srgb, var(--color-card-bg) 90%, transparent);
    padding: 0.62rem;
    overflow: auto;
  }

  :global(.article-content blockquote) {
    margin: 0.25rem 0;
    padding: 0.42rem 0.62rem;
    border-left: 3px solid var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 9%, transparent);
    border-radius: 0.46rem;
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
  }

  .post-footer {
    border-top: 1px dashed color-mix(in srgb, var(--color-text) 18%, transparent);
    padding-top: 0.55rem;
  }
</style>
