---
interface ToolEntry {
  name: string;
  slug: string;
  status: string;
}

interface ToolGroup {
  slug: string;
  name: string;
  tools: ToolEntry[];
}

interface SurfaceEntry {
  slug: string;
  name: string;
  description: string;
  groups: ToolGroup[];
}

interface Props {
  surface: SurfaceEntry;
  eyebrow?: string;
}

const { surface, eyebrow = 'Utility Surface' } = Astro.props;
const totalTools = surface.groups.reduce((count, group) => count + group.tools.length, 0);
---

<section class="surface-hero" data-reveal>
  <p class="eyebrow">{eyebrow}</p>
  <h1>{surface.name}</h1>
  <p class="description">{surface.description}</p>
  <p class="meta">{totalTools} tools mapped across {surface.groups.length} groups.</p>
</section>

<section class="surface-groups" data-reveal>
  {surface.groups.map((group) => (
    <article class="group-card">
      <h2>{group.name}</h2>
      <ul>
        {group.tools.map((tool) => (
          <li>
            <a href={`/utility/${surface.slug}/${tool.slug}`}>{tool.name}</a>
            {tool.status === 'starter' && <span class="starter-badge">Live starter</span>}
          </li>
        ))}
      </ul>
    </article>
  ))}
</section>

<style>
  .surface-hero {
    border: 1px solid color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
    border-radius: var(--radius-lg);
    padding: 1.1rem;
    background:
      radial-gradient(circle at 100% -18%, color-mix(in srgb, var(--color-secondary) 28%, transparent), transparent 60%),
      color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    box-shadow: var(--shadow-soft);
  }

  .eyebrow {
    margin-bottom: 0.45rem;
  }

  .surface-hero h1 {
    margin-bottom: 0.65rem;
  }

  .description {
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    max-width: 72ch;
    line-height: 1.68;
  }

  .meta {
    margin-top: 0.62rem;
    font-weight: 600;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .surface-groups {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.78rem;
  }

  .group-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.85rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    box-shadow: var(--shadow-soft);
  }

  .group-card h2 {
    margin-bottom: 0.65rem;
    font-size: 1.1rem;
  }

  .group-card ul {
    list-style: none;
    display: grid;
    gap: 0.5rem;
  }

  .group-card li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-bottom: 0.28rem;
    border-bottom: 1px dashed color-mix(in srgb, var(--color-text) 16%, transparent);
  }

  .group-card li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .group-card a {
    color: var(--color-primary);
    font-weight: 600;
  }

  .group-card a:hover {
    color: var(--color-secondary);
  }

  .starter-badge {
    display: inline-flex;
    border: 1px solid color-mix(in srgb, var(--color-accent) 32%, transparent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-accent);
    font-size: 0.66rem;
    border-radius: 999px;
    padding: 0.18rem 0.5rem;
    font-weight: 700;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .surface-hero,
    .group-card {
      padding: 0.9rem;
    }

    .surface-groups {
      grid-template-columns: 1fr;
    }
  }
</style>