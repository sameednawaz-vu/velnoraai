---
interface ToolItem {
  id: number;
  name: string;
  slug: string;
  category: string;
  mode: string;
  status: string;
  description: string;
  valueProposition: string;
  tags: string[];
  lastUpdated: string;
}

interface Props {
  tool: ToolItem;
}

const { tool } = Astro.props;
const categoryLabel = tool.category
  .split('-')
  .filter(Boolean)
  .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
  .join(' ');
const infoMessage = tool.valueProposition || tool.description;
---

<article
  class="tool-card"
  data-tool-card
  data-name={tool.name.toLowerCase()}
  data-category={tool.category}
  data-tags={tool.tags.join(' ').toLowerCase()}
  data-mode={tool.mode}
>
  <div class="tool-card-top">
    <p class="tool-mode">Mode {tool.mode}</p>
    <p class="tool-updated">Updated {tool.lastUpdated}</p>
  </div>

  <div class="tool-name-row">
    <h3>
      <a href={`/tools/${tool.category}/${tool.slug}`}>{tool.name}</a>
    </h3>
    <button class="info-dot" type="button" aria-label={`Tool details for ${tool.name}`}>i</button>
    <span class="info-tooltip" role="tooltip">{infoMessage}</span>
  </div>

  <p class="tool-category">{categoryLabel}</p>

  <ul class="tool-tags" aria-label="Tool tags">
    {tool.tags.slice(0, 3).map((tag) => <li>{tag}</li>)}
  </ul>

  <a class="tool-link" href={`/tools/${tool.category}/${tool.slug}`}>
    Open tool
  </a>
</article>

<style>
  .tool-card {
    border: 1px solid var(--color-border);
    border-radius: 0.82rem;
    background: linear-gradient(165deg, #fffef9 0%, #fff8eb 100%);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.62rem;
    height: 100%;
    box-shadow: var(--shadow-soft);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .tool-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-medium);
    border-color: #d9c4a0;
  }

  .tool-card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.78rem;
    color: #5a6a86;
  }

  .tool-mode {
    font-weight: 700;
    color: #0b6f68;
    text-transform: uppercase;
    letter-spacing: 0.07rem;
  }

  .tool-updated {
    text-align: right;
  }

  .tool-card h3 {
    font-size: 1.02rem;
    line-height: 1.32;
    margin: 0;
  }

  .tool-name-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.5rem;
  }

  .tool-card h3 a {
    color: var(--color-primary);
  }

  .tool-card h3 a:hover {
    color: var(--color-accent);
  }

  .tool-category {
    color: #3e5474;
    font-size: 0.85rem;
    margin: 0;
    font-weight: 600;
  }

  .info-dot {
    width: 1.28rem;
    height: 1.28rem;
    border-radius: 999px;
    border: 1px solid #bfd0e7;
    background: #edf3fb;
    color: #27486d;
    font-size: 0.74rem;
    font-weight: 700;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: help;
    padding: 0;
  }

  .info-dot:hover,
  .info-dot:focus-visible {
    border-color: #9eb6d3;
    background: #e1ebf8;
    outline: none;
  }

  .info-tooltip {
    position: absolute;
    left: 0;
    top: calc(100% + 0.32rem);
    min-width: 220px;
    max-width: min(320px, 92vw);
    border: 1px solid #cfdcef;
    border-radius: 0.55rem;
    background: #ffffff;
    padding: 0.56rem 0.62rem;
    color: #364f6d;
    font-size: 0.8rem;
    line-height: 1.4;
    box-shadow: 0 12px 28px rgba(17, 34, 57, 0.14);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.16s ease, transform 0.16s ease;
    transform: translateY(4px);
    z-index: 20;
  }

  .info-dot:hover + .info-tooltip,
  .info-dot:focus-visible + .info-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .tool-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }

  .tool-tags li {
    font-size: 0.76rem;
    border: 1px solid rgba(10, 138, 130, 0.35);
    color: #26566c;
    background: rgba(10, 138, 130, 0.09);
    border-radius: 999px;
    padding: 0.28rem 0.65rem;
  }

  .tool-link {
    margin-top: auto;
    width: fit-content;
    padding: 0.45rem 0.82rem;
    border-radius: 0.5rem;
    border: 1px solid #d5c2a2;
    color: var(--color-primary);
    background: #fffaf0;
    font-weight: 700;
    font-size: 0.86rem;
    transition: all 0.2s ease;
  }

  .tool-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .info-tooltip {
      left: 0;
      right: auto;
      max-width: min(88vw, 320px);
    }
  }
</style>
