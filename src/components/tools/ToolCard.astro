---
interface ToolItem {
  id: number;
  name: string;
  slug: string;
  category: string;
  mode: string;
  status: string;
  description: string;
  valueProposition: string;
  tags: string[];
  lastUpdated: string;
}

interface Props {
  tool: ToolItem;
}

const { tool } = Astro.props;
---

<article
  class="tool-card"
  data-tool-card
  data-name={tool.name.toLowerCase()}
  data-category={tool.category}
  data-tags={tool.tags.join(' ').toLowerCase()}
  data-mode={tool.mode}
>
  <div class="tool-card-top">
    <p class="tool-mode">Mode {tool.mode}</p>
    <p class="tool-updated">Updated {tool.lastUpdated}</p>
  </div>

  <h3>
    <a href={`/tools/${tool.category}/${tool.slug}`}>{tool.name}</a>
  </h3>

  <p class="tool-description">{tool.description}</p>
  <p class="tool-value">{tool.valueProposition}</p>

  <ul class="tool-tags">
    {tool.tags.map((tag) => <li>{tag}</li>)}
  </ul>

  <a class="tool-link" href={`/tools/${tool.category}/${tool.slug}`}>
    Open tool
  </a>
</article>

<style>
  .tool-card {
    border: 1px solid var(--color-border);
    border-radius: 0.82rem;
    background: linear-gradient(165deg, #fffef9 0%, #fff6e8 100%);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    height: 100%;
    box-shadow: var(--shadow-soft);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .tool-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-medium);
    border-color: #d9c4a0;
  }

  .tool-card-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    font-size: 0.78rem;
    color: #5a6a86;
  }

  .tool-mode {
    font-weight: 700;
    color: #0b6f68;
    text-transform: uppercase;
    letter-spacing: 0.07rem;
  }

  .tool-updated {
    text-align: right;
  }

  .tool-card h3 {
    font-size: 1.18rem;
    line-height: 1.35;
  }

  .tool-card h3 a {
    color: var(--color-primary);
  }

  .tool-card h3 a:hover {
    color: var(--color-accent);
  }

  .tool-description {
    color: #425472;
    line-height: 1.55;
  }

  .tool-value {
    color: #29466b;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .tool-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
  }

  .tool-tags li {
    font-size: 0.76rem;
    border: 1px solid rgba(10, 138, 130, 0.35);
    color: #26566c;
    background: rgba(10, 138, 130, 0.09);
    border-radius: 999px;
    padding: 0.28rem 0.65rem;
  }

  .tool-link {
    margin-top: auto;
    width: fit-content;
    padding: 0.55rem 0.95rem;
    border-radius: 0.5rem;
    border: 1px solid #d5c2a2;
    color: var(--color-primary);
    background: #fffaf0;
    font-weight: 700;
    transition: all 0.2s ease;
  }

  .tool-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
</style>
