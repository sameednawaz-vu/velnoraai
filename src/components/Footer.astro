---
import toolsData from '../content/data/tools.json';
import catalog from '../content/data/freeconvert-catalog.json';
import { blogPosts } from '../content/data/blog-posts';

const publishedTools = toolsData.tools.filter((tool) => tool.status === 'published').length;
const utilityToolCount = catalog.surfaces.reduce(
  (count, surface) => count + surface.groups.reduce((groupCount, group) => groupCount + group.tools.length, 0),
  0
);
const liveToolCount = publishedTools + utilityToolCount;
---

<footer class="site-footer">
  <section class="footer-main">
    <div class="footer-brand">
      <p class="footer-kicker">Velnora Free Tools</p>
      <h2>Velnora</h2>
      <p>
        A curated index of practical browser workflows with {liveToolCount} free tools and {blogPosts.length} blog
        guides for conversion, compression, and utility execution.
      </p>
      <div class="footer-actions">
        <a href="/tools#tool-search">Search all tools</a>
        <a href="/blog">Read practical guides</a>
      </div>
      <div class="footer-dots" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>

    <div class="footer-column">
      <h3>Directory</h3>
      <a href="/tools">Tools</a>
      <a href="/convert">Convert</a>
      <a href="/compress">Compress</a>
      <a href="/utility-tools">Utility Tools</a>
    </div>

    <div class="footer-column">
      <h3>Insight</h3>
      <a href="/blog">Blog</a>
      <a href="/learning-hub">Learning Hub</a>
      <a href="/library">Library</a>
      <a href="/tools">Tool updates</a>
    </div>

    <div class="footer-column">
      <h3>Company</h3>
      <a href="/about">About</a>
      <a href="/privacy-policy">Privacy Policy</a>
      <a href="/contact">Contact</a>
    </div>
  </section>

  <section class="footer-bottom">
    <span>© 2026 velnoraai.app</span>
    <span>Edition 2026 · Obsidian and Gold</span>
    <span>Built for execution-first workflows</span>
  </section>
</footer>

<style>
  .site-footer {
    margin-top: 2.6rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-background);
    padding: 1.35rem 1rem 0.9rem;
    display: grid;
    gap: 0.8rem;
  }

  .footer-main {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-card-bg) 95%, transparent);
    padding: 1.25rem;
    display: grid;
    grid-template-columns: minmax(320px, 1.55fr) repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .footer-kicker {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.21em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-secondary) 92%, var(--color-text));
    margin-bottom: 0.52rem;
  }

  .footer-brand h2 {
    font-size: clamp(2.1rem, 3.8vw, 2.75rem);
    line-height: 1;
    margin-bottom: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .footer-brand p {
    color: color-mix(in srgb, var(--color-text) 88%, transparent);
    line-height: 1.68;
    font-size: 0.88rem;
    max-width: 39ch;
  }

  .footer-actions {
    margin-top: 0.9rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.56rem;
  }

  .footer-actions a {
    border: 1px solid color-mix(in srgb, var(--color-border) 94%, transparent);
    border-radius: 0.35rem;
    padding: 0.45rem 0.72rem;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-card-bg) 96%, transparent);
  }

  .footer-actions a:hover {
    border-color: color-mix(in srgb, var(--color-secondary) 64%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 8%, transparent);
  }

  .footer-dots {
    margin-top: 1rem;
    display: inline-flex;
    gap: 0.42rem;
  }

  .footer-dots span {
    width: 0.76rem;
    height: 0.76rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-secondary) 24%, transparent);
  }

  .footer-column {
    display: grid;
    align-content: start;
    gap: 0.38rem;
  }

  .footer-column h3 {
    margin: 0 0 0.34rem;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--color-secondary) 94%, var(--color-text));
  }

  .footer-column a {
    font-size: 1rem;
    font-family: var(--font-display);
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--color-text) 94%, transparent);
  }

  .footer-column a:hover {
    color: color-mix(in srgb, var(--color-secondary) 90%, var(--color-text));
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-top: 0.72rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.72rem;
    font-size: 0.64rem;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.13em;
  }

  @media (max-width: 960px) {
    .footer-main {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding: 1rem 0.8rem;
    }

    .footer-main {
      grid-template-columns: 1fr;
      padding: 1rem;
    }
  }
</style>
