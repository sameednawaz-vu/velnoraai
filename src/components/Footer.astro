---
import { Boxes } from './ui/background-boxes';
---

<footer class="site-footer">
  <div class="footer-motion" aria-hidden="true">
    <div class="footer-motion-mask"></div>
    <Boxes client:only="preact" className="footer-boxes-layer" />
  </div>

  <div class="footer-container">
    <div class="footer-section brand">
      <h3>Velnora</h3>
      <p>
        Product-first AI utility platform focused on practical workflows, high-clarity UX, and browser-first
        experiences.
      </p>
    </div>

    <div class="footer-section">
      <h4>Navigate</h4>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/convert">Convert</a></li>
        <li><a href="/compress">Compress</a></li>
        <li><a href="/utility-tools">Tools</a></li>
        <li><a href="/tools">All Categories</a></li>
        <li><a href="/learning-hub">Learning Hub</a></li>
        <li><a href="/library">Library</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Tool Surfaces</h4>
      <ul>
        <li><a href="/convert">Video and Audio Convert</a></li>
        <li><a href="/convert">Image Convert</a></li>
        <li><a href="/compress">Image and PDF Compress</a></li>
        <li><a href="/utility-tools">Image and PDF Utility Tools</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Connect</h4>
      <ul>
        <li><a href="mailto:sameednawaz1@gmail.com">sameednawaz1@gmail.com</a></li>
        <li>
          <a href="https://linkedin.com/in/sameed-nawaz-pak" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </li>
        <li><a href="https://sameednawaz.tech/" target="_blank" rel="noopener noreferrer">Portfolio</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; 2026 Velnora. Built by Sameed Nawaz.</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: 4rem;
    border-top: 1px solid rgba(209, 187, 152, 0.5);
    background: linear-gradient(145deg, #fdf4de 0%, #f4e5c4 100%);
    color: var(--color-primary);
    overflow: hidden;
    isolation: isolate;
  }

  .footer-motion {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .footer-motion-mask {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: radial-gradient(circle at 22% 25%, rgba(255, 244, 222, 0.1), rgba(255, 244, 222, 0.95) 72%);
  }

  .footer-boxes-layer {
    opacity: 0.55;
    z-index: 1;
    position: absolute;
  }

  .footer-container {
    max-width: 1220px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.4rem;
    position: relative;
    z-index: 3;
  }

  .footer-section h3 {
    font-family: var(--font-display);
    font-size: 1.6rem;
    margin-bottom: 0.6rem;
    background: linear-gradient(135deg, #1a2f4b, #0a8a82);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-section h4 {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08rem;
    margin-bottom: 0.45rem;
    color: #8a531f;
  }

  .footer-section p {
    line-height: 1.62;
    color: #40506c;
  }

  .footer-section ul {
    list-style: none;
    display: grid;
    gap: 0.34rem;
  }

  .footer-section a {
    color: #2b3f5c;
    font-size: 0.92rem;
  }

  .footer-section a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    position: relative;
    z-index: 3;
    text-align: center;
    padding: 1.1rem 2rem 1.5rem;
    border-top: 1px solid rgba(35, 53, 82, 0.14);
    color: #435776;
  }

  @media (max-width: 800px) {
    .footer-container {
      padding: 2.2rem 1rem;
    }
  }
</style>
