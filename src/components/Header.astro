---
import toolsData from '../content/data/tools.json';
import catalog from '../content/data/freeconvert-catalog.json';
import { blogPosts } from '../content/data/blog-posts';

interface NavChildLink {
  label: string;
  href: string;
  hint?: string;
}

interface NavGroupLink {
  label: string;
  href: string;
  summary?: string;
  children: NavChildLink[];
}

interface NavMenuItem {
  label: string;
  href: string;
  groups?: NavGroupLink[];
}

const publishedTools = toolsData.tools.filter((tool) => tool.status === 'published');
const categoryNameBySlug = Object.fromEntries(toolsData.categories.map((entry) => [entry.slug, entry.name]));

const utilityTools = catalog.surfaces.flatMap((surface) =>
  surface.groups.flatMap((group) =>
    group.tools.map((tool) => ({
      name: tool.name,
      slug: tool.slug,
      groupName: group.name,
      surfaceName: surface.name,
      href: `/utility/${surface.slug}/${tool.slug}`,
    }))
  )
);

const liveToolCount = publishedTools.length + utilityTools.length;

const toHubSlug = (groupSlug: string) => {
  if (groupSlug.includes('image')) return 'images';
  if (groupSlug.includes('video') || groupSlug.includes('audio')) return 'video-audio';
  if (groupSlug.includes('gif')) return 'gif';
  if (groupSlug.includes('pdf') || groupSlug.includes('document')) return 'pdf';
  return groupSlug;
};

const buildUtilityMenu = (surfaceSlug: string, fallbackHref: string): NavMenuItem | null => {
  const surface = catalog.surfaces.find((entry) => entry.slug === surfaceSlug);
  if (!surface) {
    return null;
  }

  const menuLabel = surfaceSlug === 'tools' ? 'Utility' : surface.name;

  const groups = surface.groups.map((group) => ({
    label: group.name,
    href: `/utility/${toHubSlug(group.slug)}`,
    summary: `${group.tools.length} routes`,
    children: group.tools.slice(0, 12).map((tool) => ({
      label: tool.name,
      href: `/utility/${surface.slug}/${tool.slug}`,
      hint: `${surface.name} / ${group.name}`,
    })),
  }));

  return {
    label: menuLabel,
    href: fallbackHref,
    groups,
  };
};

const convertMenu = buildUtilityMenu('convert', '/convert');
const compressMenu = buildUtilityMenu('compress', '/compress');

const professionalToolsMenu: NavMenuItem = {
  label: 'Tools',
  href: '/tools',
  groups: toolsData.categories
    .map((category) => {
      const categoryTools = publishedTools.filter((tool) => tool.category === category.slug);
      if (categoryTools.length === 0) {
        return null;
      }

      return {
        label: category.name,
        href: `/tools/${category.slug}`,
        summary: `${categoryTools.length} pages`,
        children: categoryTools.slice(0, 10).map((tool) => ({
          label: tool.name,
          href: `/tools/${tool.category}/${tool.slug}`,
          hint: 'Professional tool',
        })),
      };
    })
    .filter((entry): entry is NavGroupLink => Boolean(entry)),
};

const navMenuItems: NavMenuItem[] = [
  professionalToolsMenu,
  ...(convertMenu ? [convertMenu] : []),
  ...(compressMenu ? [compressMenu] : []),
  { label: 'Blog', href: '/blog' },
];

const searchIndex = [
  ...publishedTools.map((tool) => ({
    n: tool.name,
    s: tool.slug,
    h: `/tools/${tool.category}/${tool.slug}`,
    y: 'P',
    c: categoryNameBySlug[tool.category] ?? tool.category,
  })),
  ...utilityTools.map((tool) => ({
    n: tool.name,
    s: tool.slug,
    h: tool.href,
    y: 'U',
    c: `${tool.surfaceName} / ${tool.groupName}`,
  })),
  ...blogPosts.map((post) => ({
    n: post.title,
    s: post.slug,
    h: `/blog/${post.slug}`,
    y: 'A',
    c: `Blog / ${post.category}`,
  })),
];

const quickSearches = [
  ...publishedTools.slice(0, 5).map((tool) => tool.name),
  ...utilityTools.slice(0, 2).map((tool) => tool.name),
  ...blogPosts.slice(0, 3).map((post) => post.title),
].slice(0, 8);
---

<header class="site-header">
  <div class="nav-wrap">
    <a class="logo" href="/" aria-label="Velnora home">
      <span class="logo-mark" aria-hidden="true">
        <img src="/images/favicon-velnora.svg" alt="" width="24" height="24" loading="eager" decoding="async" />
      </span>
      <span class="logo-word">Velnora</span>
    </a>

    <div class="nav-right">
      <nav class="nav-links" aria-label="Primary">
        <ul class="nav-root">
          {navMenuItems.map((item) => (
            <li class:list={['nav-item', item.groups && 'has-flyout']}>
              <a class="nl" href={item.href}>{item.label}</a>
              {item.groups && (
                <div class="flyout" role="menu" aria-label={`${item.label} menu`}>
                  <ul class="flyout-groups">
                    {item.groups.map((group) => (
                      <li class="group-item has-sub">
                        <a class="group-link" href={group.href}>
                          <span>{group.label}</span>
                          {group.summary && <small>{group.summary}</small>}
                        </a>

                        <div class="sub-flyout">
                          <a class="sub-open" href={group.href}>Open {group.label}</a>
                          <ul>
                            {group.children.map((child) => (
                              <li>
                                <a href={child.href}>
                                  <strong>{child.label}</strong>
                                  {child.hint && <span>{child.hint}</span>}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <div class="header-actions">
        <button class="search-launch" type="button" data-search-open aria-haspopup="dialog" aria-expanded="false">
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="M13.8 12.4a5.9 5.9 0 1 0-1.4 1.4l3.5 3.5a1 1 0 0 0 1.4-1.4l-3.5-3.5Zm-7.9-2.5a4 4 0 1 1 8 0 4 4 0 0 1-8 0Z"></path>
          </svg>
          <span>Search</span>
          <kbd>/</kbd>
        </button>

        <button class="theme-launch" type="button" data-theme-toggle aria-label="Toggle theme">
          <svg class="theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3a6.36 6.36 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
          <svg class="theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
          </svg>
        </button>

        <a class="contact-btn" href="/tools">Open Workspace</a>
      </div>
    </div>
  </div>

  <div class="search-overlay" data-search-overlay hidden>
    <div class="search-overlay-shell" role="dialog" aria-modal="true" aria-label="Tool search">
      <div class="search-overlay-head">
        <p>Intelligence Search</p>
        <button type="button" class="search-overlay-close" data-search-close aria-label="Close search">
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="M5.2 5.2a1 1 0 0 1 1.4 0L10 8.6l3.4-3.4a1 1 0 0 1 1.4 1.4L11.4 10l3.4 3.4a1 1 0 1 1-1.4 1.4L10 11.4l-3.4 3.4a1 1 0 1 1-1.4-1.4L8.6 10 5.2 6.6a1 1 0 0 1 0-1.4Z"></path>
          </svg>
        </button>
      </div>

      <label class="sr-only" for="header-search-input">Search tools</label>
      <div class="search-query-shell">
        <svg viewBox="0 0 20 20" aria-hidden="true">
          <path d="M13.8 12.4a5.9 5.9 0 1 0-1.4 1.4l3.5 3.5a1 1 0 0 0 1.4-1.4l-3.5-3.5Zm-7.9-2.5a4 4 0 1 1 8 0 4 4 0 0 1-8 0Z"></path>
        </svg>
        <input
          id="header-search-input"
          type="search"
          placeholder="Search a tool route (for example: compress PDF, MP4 to MP3, JSON formatter)"
          autocomplete="off"
          data-search-input
        />
      </div>

      <div class="search-overlay-grid">
        <section class="search-quick" aria-label="Trending searches">
          <h2>Trending Searches</h2>
          <div>
            {quickSearches.map((item) => (
              <button type="button" data-search-quick={item}>{item}</button>
            ))}
          </div>
          <p>Tap a trend or type your own query.</p>
        </section>

        <section class="search-logic" aria-label="Search logic">
          <h2>Search Logic</h2>
          <p>
            Our real-time engine parses {liveToolCount}+ tool routes. Type the action (like “compress”) or a file
            format (like “webp”) to jump directly to the best match.
          </p>
          <article class="search-lab-note">
            <span>Lab Note</span>
            <p>Search results are processed entirely client-side. Zero latency. Zero tracking.</p>
          </article>
        </section>
      </div>

      <section class="search-results-panel" aria-label="Search results">
        <h2 data-search-title>Type at least 2 characters</h2>
        <div class="search-filter" role="tablist" aria-label="Search filters">
          <button type="button" class="is-active" data-search-filter="tools">Tools</button>
          <button type="button" data-search-filter="articles">Articles</button>
          <button type="button" data-search-filter="both">Both</button>
        </div>
        <ul data-search-list></ul>
        <p class="search-empty" data-search-empty hidden>No matching tools found.</p>
        <a class="search-view-all" href="/tools#tool-search">Open full tool search</a>
      </section>
    </div>
  </div>

  <script id="header-search-data" type="application/json" set:html={JSON.stringify(searchIndex)}></script>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const storageKey = 'velnora-theme';
    const toggle = document.querySelector('[data-theme-toggle]');

    const setTheme = (theme) => {
      root.setAttribute('data-theme', theme);
      window.localStorage.setItem(storageKey, theme);
    };

    if (toggle) {
      toggle.addEventListener('click', () => {
        const current = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
        setTheme(current === 'dark' ? 'light' : 'dark');
      });
    }

    const searchOverlay = document.querySelector('[data-search-overlay]');
    const searchOpenButton = document.querySelector('[data-search-open]');
    const searchCloseButton = document.querySelector('[data-search-close]');
    const searchDataNode = document.getElementById('header-search-data');
    if (
      !(searchOverlay instanceof HTMLElement) ||
      !(searchOpenButton instanceof HTMLButtonElement) ||
      !(searchCloseButton instanceof HTMLButtonElement) ||
      !(searchDataNode instanceof HTMLScriptElement)
    ) {
      return;
    }

    // The sticky header uses backdrop-filter, so keep the overlay under <body>
    // to ensure fixed positioning covers the full viewport on every page.
    if (searchOverlay.parentElement !== document.body) {
      document.body.appendChild(searchOverlay);
    }

    const input = searchOverlay.querySelector('[data-search-input]');
    const list = searchOverlay.querySelector('[data-search-list]');
    const empty = searchOverlay.querySelector('[data-search-empty]');
    const title = searchOverlay.querySelector('[data-search-title]');
    const quickButtons = Array.from(searchOverlay.querySelectorAll('[data-search-quick]'));
    const filterButtons = Array.from(searchOverlay.querySelectorAll('[data-search-filter]'));
    const viewAllLink = searchOverlay.querySelector('.search-view-all');

    if (
      !(input instanceof HTMLInputElement) ||
      !(list instanceof HTMLElement) ||
      !(empty instanceof HTMLElement)
    ) {
      return;
    }

    let searchOpen = false;
    let index = null;
    let activeFilter = 'tools';

    const ensureIndex = () => {
      if (Array.isArray(index)) {
        return index;
      }

      try {
        const parsed = JSON.parse(searchDataNode.textContent || '[]');
        index = Array.isArray(parsed) ? parsed : [];
      } catch {
        index = [];
      }

      searchDataNode.remove();
      return index;
    };

    const normalize = (value) =>
      String(value)
        .toLowerCase()
        .replace(/[^a-z0-9\s-]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

    const inOrderMatch = (text, query) => {
      let cursor = 0;
      for (const char of query) {
        cursor = text.indexOf(char, cursor);
        if (cursor === -1) return false;
        cursor += 1;
      }
      return true;
    };

    const scoreEntry = (entry, query, tokens) => {
      const name = normalize(entry.n || '');
      const slug = normalize(entry.s || '');
      const context = normalize(entry.c || '');
      const typeLabel = entry.y === 'P' ? 'professional tool' : entry.y === 'U' ? 'utility route' : 'blog article';
      const keywords = `${name} ${slug} ${context} ${typeLabel}`;

      let score = 0;
      if (name.startsWith(query)) score += 130;
      if (slug.startsWith(query)) score += 120;
      if (name.includes(query)) score += 92;
      if (slug.includes(query)) score += 88;
      if (keywords.includes(query)) score += 64;
      if (inOrderMatch(`${name} ${slug}`, query)) score += 44;

      for (const token of tokens) {
        if (!token) continue;
        if (name.startsWith(token)) score += 42;
        if (slug.startsWith(token)) score += 38;
        if (keywords.includes(token)) score += 24;
      }

      const tokenBoost = keywords.split(' ').filter(Boolean).some((token) => token.startsWith(query));
      if (tokenBoost) score += 28;

      return score;
    };

    const matchesActiveFilter = (entry) => {
      if (activeFilter === 'tools') {
        return entry.y !== 'A';
      }

      if (activeFilter === 'articles') {
        return entry.y === 'A';
      }

      return true;
    };

    const applyFilterUi = () => {
      for (const button of filterButtons) {
        if (!(button instanceof HTMLButtonElement)) continue;
        button.classList.toggle('is-active', button.dataset.searchFilter === activeFilter);
      }

      if (!(viewAllLink instanceof HTMLAnchorElement)) {
        return;
      }

      if (activeFilter === 'articles') {
        viewAllLink.href = '/blog';
        viewAllLink.textContent = 'Open blog index';
      } else if (activeFilter === 'both') {
        viewAllLink.href = '/blog';
        viewAllLink.textContent = 'Browse blog and tools';
      } else {
        viewAllLink.href = '/tools#tool-search';
        viewAllLink.textContent = 'Open full tool search';
      }
    };

    const describeScore = (score) => {
      if (score >= 300) return 'High confidence';
      if (score >= 220) return 'Strong candidate';
      return 'Related result';
    };

    const renderResults = (query) => {
      const ranked = index ? index : ensureIndex();
      const normalizedQuery = normalize(query);
      const tokens = normalizedQuery.split(' ').filter(Boolean);

      list.innerHTML = '';

      if (normalizedQuery.length < 2) {
        searchOverlay.classList.remove('search-has-query');
        empty.hidden = false;
        empty.textContent = 'Type at least 2 characters or select a trending search.';
        if (title instanceof HTMLElement) {
          title.textContent = 'Ready to search';
        }
        return;
      }

      searchOverlay.classList.add('search-has-query');

      const matches = ranked
        .filter((entry) => matchesActiveFilter(entry))
        .map((entry) => ({ entry, score: scoreEntry(entry, normalizedQuery, tokens) }))
        .filter((entry) => entry.score > 0)
        .sort((first, second) => second.score - first.score)
        .slice(0, 60);

      if (matches.length === 0) {
        empty.hidden = false;
        const targetLabel = activeFilter === 'articles' ? 'articles' : activeFilter === 'tools' ? 'tools' : 'results';
        empty.textContent = `No direct ${targetLabel} match for "${query}". Try a shorter phrase.`;
        if (title instanceof HTMLElement) {
          title.textContent = 'No matches yet';
        }
      } else {
        empty.hidden = true;
        if (title instanceof HTMLElement) {
          const heading = activeFilter === 'articles' ? 'Top article matches' : activeFilter === 'tools' ? 'Top tool matches' : 'Top matches';
          title.textContent = `${heading} (${matches.length})`;
        }
        for (const [index, match] of matches.entries()) {
          const row = document.createElement('li');
          const link = document.createElement('a');
          const top = document.createElement('div');
          const rank = document.createElement('span');
          const badge = document.createElement('b');
          const title = document.createElement('strong');
          const meta = document.createElement('span');
          const route = document.createElement('small');
          const confidence = document.createElement('em');

          link.href = match.entry.h;
          rank.textContent = `#${index + 1}`;
          rank.className = 'search-rank';
          badge.textContent = match.entry.y === 'P' ? 'PRO' : match.entry.y === 'U' ? 'UTILITY' : 'ARTICLE';
          title.textContent = match.entry.n;
          meta.textContent = `${match.entry.y === 'P' ? 'Professional tool' : match.entry.y === 'U' ? 'Utility route' : 'Blog article'} in ${match.entry.c}`;
          route.textContent = match.entry.h;
          confidence.textContent = describeScore(match.score);

          top.className = 'search-result-top';
          top.append(rank, badge, title);

          link.append(top, meta, route, confidence);
          row.append(link);
          list.append(row);
        }
      }
    };

    const setSearchOpen = (open) => {
      searchOpen = open;
      searchOverlay.hidden = !open;
      searchOpenButton.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
      document.documentElement.classList.toggle('search-open', open);

      if (!open) {
        searchOverlay.classList.remove('search-has-query');
      }

      if (open) {
        renderResults(input.value);
        queueMicrotask(() => input.focus());
      }
    };

    const runQuickSearch = (value) => {
      input.value = value;
      renderResults(value);
      input.focus();
    };

    applyFilterUi();

    searchOpenButton.addEventListener('click', () => {
      setSearchOpen(true);
    });

    searchCloseButton.addEventListener('click', () => {
      setSearchOpen(false);
    });

    searchOverlay.addEventListener('click', (event) => {
      if (event.target === searchOverlay) {
        setSearchOpen(false);
      }
    });

    for (const quickButton of quickButtons) {
      if (!(quickButton instanceof HTMLButtonElement)) continue;
      quickButton.addEventListener('click', () => {
        runQuickSearch(quickButton.dataset.searchQuick || quickButton.textContent || '');
      });
    }

    for (const filterButton of filterButtons) {
      if (!(filterButton instanceof HTMLButtonElement)) continue;
      filterButton.addEventListener('click', () => {
        const nextFilter = filterButton.dataset.searchFilter;
        if (nextFilter !== 'tools' && nextFilter !== 'articles' && nextFilter !== 'both') {
          return;
        }

        activeFilter = nextFilter;
        applyFilterUi();
        renderResults(input.value);
      });
    }

    input.addEventListener('input', () => {
      renderResults(input.value);
    });

    input.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setSearchOpen(false);
      }

      if (event.key === 'Enter') {
        const firstLink = list.querySelector('a');
        if (firstLink instanceof HTMLAnchorElement) {
          window.location.href = firstLink.href;
        }
      }
    });

    document.addEventListener('keydown', (event) => {
      const target = event.target;
      const isInputTarget =
        target instanceof HTMLInputElement ||
        target instanceof HTMLTextAreaElement ||
        target instanceof HTMLSelectElement;
      if (isInputTarget && !searchOpen) return;

      if (event.key === 'Escape' && searchOpen) {
        event.preventDefault();
        setSearchOpen(false);
        return;
      }

      if (event.key === '/' || (event.key.toLowerCase() === 'k' && (event.metaKey || event.ctrlKey))) {
        event.preventDefault();
        setSearchOpen(true);
      }
    });

    const viewportPadding = 14;

    const positionFlyout = (flyout) => {
      if (!(flyout instanceof HTMLElement)) {
        return;
      }

      flyout.classList.remove('open-left');

      const rect = flyout.getBoundingClientRect();
      if (rect.right > window.innerWidth - viewportPadding) {
        flyout.classList.add('open-left');
      }
    };

    const positionSubFlyout = (group, sub) => {
      if (!(group instanceof HTMLElement) || !(sub instanceof HTMLElement)) {
        return;
      }

      sub.classList.remove('open-left');
      group.classList.remove('sub-open-left');

      const rect = sub.getBoundingClientRect();
      if (rect.right > window.innerWidth - viewportPadding) {
        sub.classList.add('open-left');
        group.classList.add('sub-open-left');
      }
    };

    // Improve hovering stability for mega flyouts and sub-flyouts by using a small hide delay
    const navFlyoutItems = Array.from(document.querySelectorAll('.nav-item.has-flyout'));
    for (const item of navFlyoutItems) {
      let hideTimer = null;
      const flyout = item.querySelector('.flyout');

      const keepOpen = () => {
        if (hideTimer) {
          clearTimeout(hideTimer);
          hideTimer = null;
        }
        item.classList.add('nav-open');
        positionFlyout(flyout);
      };

      const scheduleClose = () => {
        if (hideTimer) clearTimeout(hideTimer);
        hideTimer = setTimeout(() => {
          item.classList.remove('nav-open');
          if (flyout instanceof HTMLElement) {
            flyout.classList.remove('open-left');
          }
        }, 260);
      };

      item.addEventListener('mouseenter', keepOpen);
      item.addEventListener('mouseleave', scheduleClose);

      if (flyout instanceof HTMLElement) {
        flyout.addEventListener('mouseenter', keepOpen);
        flyout.addEventListener('mouseleave', scheduleClose);
      }
    }

    const subFlyoutGroups = Array.from(document.querySelectorAll('.group-item.has-sub'));
    for (const group of subFlyoutGroups) {
      let hideTimer = null;
      const sub = group.querySelector('.sub-flyout');

      const keepOpen = () => {
        if (hideTimer) {
          clearTimeout(hideTimer);
          hideTimer = null;
        }
        group.classList.add('sub-open');
        positionSubFlyout(group, sub);
      };

      const scheduleClose = () => {
        if (hideTimer) clearTimeout(hideTimer);
        hideTimer = setTimeout(() => {
          group.classList.remove('sub-open');
          group.classList.remove('sub-open-left');
          if (sub instanceof HTMLElement) {
            sub.classList.remove('open-left');
          }
        }, 260);
      };

      group.addEventListener('mouseenter', keepOpen);
      group.addEventListener('mouseleave', scheduleClose);

      if (sub instanceof HTMLElement) {
        sub.addEventListener('mouseenter', keepOpen);
        sub.addEventListener('mouseleave', scheduleClose);
      }
    }

    window.addEventListener('resize', () => {
      for (const item of navFlyoutItems) {
        if (!(item instanceof HTMLElement) || !item.classList.contains('nav-open')) {
          continue;
        }

        const flyout = item.querySelector('.flyout');
        positionFlyout(flyout);
      }

      for (const group of subFlyoutGroups) {
        if (!(group instanceof HTMLElement) || !group.classList.contains('sub-open')) {
          continue;
        }

        const sub = group.querySelector('.sub-flyout');
        positionSubFlyout(group, sub);
      }
    });
  })();
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-background) 92%, transparent);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.78rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .nav-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.8rem;
    flex: 1;
    min-width: 0;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.56rem;
    color: var(--color-primary);
    font-weight: 700;
    font-family: var(--font-display);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .logo-mark {
    width: 1.7rem;
    height: 1.7rem;
    border-radius: 0;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 58%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 16%, transparent);
    color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.86rem;
    box-shadow: none;
  }

  .logo-mark img {
    width: 1rem;
    height: 1rem;
    display: block;
  }

  .logo-word {
    font-size: 1.12rem;
  }

  .nav-links {
    display: flex;
    justify-content: flex-end;
    min-width: 0;
  }

  .nav-root,
  .flyout-groups,
  .sub-flyout ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-root {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.28rem;
    justify-content: flex-end;
  }

  .nav-item {
    position: relative;
  }

  .nav-item.has-flyout::after {
    content: '';
    position: absolute;
    top: 100%;
    left: -0.36rem;
    right: -0.36rem;
    height: 1.35rem;
  }

  .nl {
    display: inline-flex;
    align-items: center;
    font-size: 0.66rem;
    color: color-mix(in srgb, var(--color-text) 86%, transparent);
    border: 1px solid transparent;
    border-radius: 0.42rem;
    padding: 0.4rem 0.58rem;
    transition: border-color 0.18s ease, background-color 0.18s ease, transform 0.18s ease;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
  }

  .nl:hover,
  .nav-item:focus-within > .nl {
    border-color: color-mix(in srgb, var(--color-secondary) 44%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
    transform: translateY(-1px);
  }

  .flyout {
    position: absolute;
    top: calc(100% + 0.06rem);
    left: 0;
    min-width: 330px;
    border: 1px solid var(--color-border);
    border-radius: 0.22rem;
    background: color-mix(in srgb, var(--color-background-soft) 88%, var(--color-card-bg));
    box-shadow: var(--shadow-medium);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(8px);
    transform-origin: top left;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 30;
    padding: 0;
  }

  .flyout.open-left {
    left: auto;
    right: 0;
    transform-origin: top right;
  }

  .flyout-groups {
    display: grid;
  }

  .has-flyout:hover > .flyout,
  .has-flyout:focus-within > .flyout {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* Keep flyout visible when JS toggles nav-open to avoid hover dropouts */
  .nav-item.nav-open > .flyout,
  .group-item.sub-open > .sub-flyout {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .group-item {
    position: relative;
  }

  .group-item.has-sub::after {
    content: '';
    position: absolute;
    top: 0;
    left: 100%;
    width: 1.2rem;
    height: 100%;
  }

  .group-item.has-sub.sub-open-left::after {
    left: auto;
    right: 100%;
  }

  .group-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.44rem;
    border-radius: 0;
    padding: 0.8rem 0.82rem;
    border-bottom: 1px solid color-mix(in srgb, var(--color-border) 86%, transparent);
    color: var(--color-primary);
    font-size: 0.64rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .group-link small {
    font-size: 0.58rem;
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--color-text) 56%, transparent);
    white-space: nowrap;
    text-transform: none;
    letter-spacing: 0.04em;
  }

  .group-item:last-child > .group-link {
    border-bottom: none;
  }

  .group-item:hover > .group-link,
  .group-item:focus-within > .group-link {
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
  }

  .sub-flyout {
    position: absolute;
    left: calc(100% + 0.24rem);
    top: 0;
    width: min(360px, calc(100vw - 2rem));
    max-height: 60vh;
    overflow: auto;
    border: 1px solid var(--color-border);
    border-radius: 0.22rem;
    background: color-mix(in srgb, var(--color-background-soft) 88%, var(--color-card-bg));
    box-shadow: var(--shadow-medium);
    padding: 0.62rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateX(8px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .sub-flyout.open-left {
    left: auto;
    right: calc(100% + 0.24rem);
    transform: translateX(-8px);
  }

  .group-item:hover > .sub-flyout,
  .group-item:focus-within > .sub-flyout {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(0);
  }

  .sub-open {
    display: block;
    border-radius: 0.3rem;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 32%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 14%, transparent);
    color: var(--color-primary);
    font-size: 0.62rem;
    font-weight: 700;
    padding: 0.5rem 0.56rem;
    margin-bottom: 0.42rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .sub-flyout ul {
    display: grid;
    gap: 0.22rem;
  }

  .sub-flyout li a {
    display: grid;
    gap: 0.12rem;
    border-radius: 0.34rem;
    padding: 0.44rem 0.5rem;
    color: var(--color-primary);
  }

  .sub-flyout li a:hover {
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
  }

  .sub-flyout li a strong {
    font-size: 0.82rem;
    line-height: 1.35;
    font-family: var(--font-display);
    letter-spacing: 0.02em;
  }

  .sub-flyout li a span {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: color-mix(in srgb, var(--color-text) 58%, transparent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: nowrap;
    justify-content: flex-end;
    flex-shrink: 0;
  }

  .search-launch {
    width: 2.35rem;
    height: 2.35rem;
    padding: 0;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 34%, var(--color-border));
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    color: var(--color-primary);
  }

  .search-launch:hover,
  .search-launch:focus-visible {
    border-color: color-mix(in srgb, var(--color-secondary) 60%, transparent);
    transform: translateY(-1px);
  }

  .search-launch svg {
    width: 1rem;
    height: 1rem;
    fill: color-mix(in srgb, var(--color-secondary) 88%, var(--color-text));
  }

  .search-launch span,
  .search-launch kbd {
    display: none;
  }

  .search-launch kbd {
    border: 1px solid var(--color-border);
    border-radius: 0.36rem;
    padding: 0.12rem 0.28rem;
    font-family: var(--font-mono);
    font-size: 0.54rem;
    color: color-mix(in srgb, var(--color-text) 64%, transparent);
  }

  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 180;
    padding: 1.4rem clamp(0.8rem, 3vw, 3.2rem) 2rem;
    background:
      radial-gradient(circle at 12% 6%, color-mix(in srgb, var(--color-secondary) 10%, transparent), transparent 40%),
      color-mix(in srgb, var(--color-background) 92%, rgba(8, 7, 6, 0.9));
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow: auto;
  }

  .search-overlay[hidden] {
    display: none !important;
  }

  .search-overlay-shell {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0.45rem 0.2rem 1.2rem;
    display: grid;
    gap: 1.15rem;
  }

  .search-overlay-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .search-overlay-head p {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-secondary) 88%, var(--color-text));
    font-family: var(--font-mono);
  }

  .search-overlay-close {
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: transparent;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    padding: 0;
  }

  .search-overlay-close svg {
    width: 1rem;
    height: 1rem;
    fill: currentColor;
  }

  .search-overlay-close:hover,
  .search-overlay-close:focus-visible {
    border-color: color-mix(in srgb, var(--color-secondary) 58%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
  }

  .search-query-shell {
    border: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-secondary) 46%, transparent);
    border-radius: 0;
    padding: 0.52rem 0 0.62rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
    background: transparent;
  }

  .search-query-shell:focus-within {
    border-bottom-color: color-mix(in srgb, var(--color-secondary) 92%, transparent);
  }

  .search-query-shell svg {
    width: 2.1rem;
    height: 2.1rem;
    fill: color-mix(in srgb, var(--color-secondary) 85%, transparent);
  }

  .search-query-shell input {
    border: none;
    background: transparent;
    outline: none;
    font-size: clamp(1.4rem, 5.3vw, 3.25rem);
    color: var(--color-primary);
    width: 100%;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    font-family: var(--font-display);
  }

  .search-query-shell input::placeholder {
    color: color-mix(in srgb, var(--color-text) 56%, transparent);
    text-transform: uppercase;
  }

  .search-overlay-grid {
    display: grid;
    grid-template-columns: minmax(220px, 0.42fr) minmax(0, 0.58fr);
    gap: 1.15rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    padding-top: 1rem;
  }

  .search-overlay.search-has-query .search-overlay-grid {
    display: none;
  }

  .search-quick {
    border-right: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
    padding-right: 1.05rem;
    display: grid;
    align-content: start;
    gap: 0.72rem;
  }

  .search-quick h2 {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--color-secondary) 80%, transparent);
  }

  .search-quick div {
    display: grid;
    gap: 0.54rem;
  }

  .search-quick button {
    border: none;
    border-radius: 0;
    background: transparent;
    text-align: left;
    color: color-mix(in srgb, var(--color-primary) 80%, transparent);
    font-size: clamp(1rem, 2vw, 2rem);
    font-family: var(--font-display);
    font-style: italic;
    padding: 0;
  }

  .search-quick button:hover,
  .search-quick button:focus-visible {
    color: var(--color-secondary);
    transform: translateX(4px);
  }

  .search-quick p {
    margin: 0;
    font-size: 0.82rem;
    color: color-mix(in srgb, var(--color-text) 66%, transparent);
    line-height: 1.6;
  }

  .search-logic {
    display: grid;
    align-content: start;
    gap: 0.72rem;
    padding-left: 0.3rem;
  }

  .search-logic h2 {
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--color-secondary) 80%, transparent);
  }

  .search-logic > p {
    margin: 0;
    color: color-mix(in srgb, var(--color-text) 70%, transparent);
    font-size: 1.02rem;
    line-height: 1.7;
    max-width: 54ch;
    font-style: italic;
  }

  .search-lab-note {
    margin-top: 0.4rem;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 20%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 5%, transparent);
    padding: 0.9rem;
    display: grid;
    gap: 0.3rem;
  }

  .search-lab-note span {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: color-mix(in srgb, var(--color-secondary) 90%, var(--color-text));
  }

  .search-lab-note p {
    margin: 0;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .search-results-panel {
    border-top: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    padding-top: 0.92rem;
    display: grid;
    gap: 0.56rem;
  }

  .search-overlay.search-has-query .search-results-panel {
    border-top: none;
    padding-top: 0.2rem;
  }

  .search-results-panel h2 {
    margin: 0;
    font-size: 0.74rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--color-secondary) 80%, transparent);
  }

  .search-filter {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    flex-wrap: wrap;
  }

  .search-filter button {
    border: 1px solid color-mix(in srgb, var(--color-border) 88%, transparent);
    background: color-mix(in srgb, var(--color-card-bg) 90%, transparent);
    border-radius: 999px;
    min-height: 1.8rem;
    padding: 0 0.62rem;
    color: color-mix(in srgb, var(--color-text) 80%, transparent);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 700;
  }

  .search-filter button:hover,
  .search-filter button:focus-visible {
    border-color: color-mix(in srgb, var(--color-secondary) 52%, transparent);
  }

  .search-filter button.is-active {
    border-color: color-mix(in srgb, var(--color-secondary) 74%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 18%, transparent);
    color: var(--color-primary);
  }

  .search-results-panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.44rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    max-height: min(52vh, 620px);
    overflow-y: auto;
    padding-right: 0.24rem;
  }

  :global(.search-results-panel li a) {
    border: 1px solid var(--color-border);
    border-radius: 0.68rem;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--color-card-bg) 97%, transparent),
      color-mix(in srgb, var(--color-background-soft) 74%, transparent)
    );
    display: grid;
    gap: 0.16rem;
    padding: 0.6rem 0.66rem;
    color: var(--color-primary);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  :global(.search-results-panel li a:hover) {
    border-color: color-mix(in srgb, var(--color-secondary) 50%, transparent);
    transform: translateY(-1px);
  }

  :global(.search-results-panel li strong) {
    font-size: 0.92rem;
    line-height: 1.35;
    font-family: var(--font-display);
  }

  :global(.search-result-top) {
    display: flex;
    align-items: center;
    gap: 0.44rem;
  }

  :global(.search-rank) {
    border: 1px solid color-mix(in srgb, var(--color-border) 82%, transparent);
    border-radius: 999px;
    min-width: 2.1rem;
    text-align: center;
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
    padding: 0.16rem 0.3rem;
    color: color-mix(in srgb, var(--color-text) 68%, transparent);
  }

  :global(.search-result-top b) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.65rem;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 45%, transparent);
    border-radius: 999px;
    font-size: 0.56rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    padding: 0.18rem 0.38rem;
    color: color-mix(in srgb, var(--color-secondary) 90%, var(--color-text));
  }

  :global(.search-results-panel li span) {
    font-size: 0.68rem;
    color: color-mix(in srgb, var(--color-text) 60%, transparent);
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  :global(.search-results-panel li small) {
    font-size: 0.68rem;
    color: color-mix(in srgb, var(--color-secondary) 84%, transparent);
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }

  :global(.search-results-panel li em) {
    font-style: normal;
    font-size: 0.66rem;
    color: color-mix(in srgb, var(--color-text) 62%, transparent);
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .search-empty {
    margin: 0;
    padding: 0.66rem 0;
    font-size: 0.72rem;
    color: color-mix(in srgb, var(--color-text) 66%, transparent);
    letter-spacing: 0.02em;
  }

  .search-view-all {
    display: block;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 84%, transparent);
    padding: 0.65rem 0;
    font-size: 0.64rem;
    font-weight: 700;
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .contact-btn {
    border: 1px solid color-mix(in srgb, var(--color-secondary) 42%, transparent);
    background: var(--color-secondary);
    border-radius: 0.3rem;
    padding: 0.5rem 0.72rem;
    font-size: 0.62rem;
    font-weight: 700;
    color: #0e0c09;
    display: inline-flex;
    align-items: center;
    gap: 0.33rem;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }

  .theme-launch {
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 34%, var(--color-border));
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    color: color-mix(in srgb, var(--color-secondary) 88%, var(--color-text));
  }

  .theme-launch:hover,
  .theme-launch:focus-visible {
    border-color: color-mix(in srgb, var(--color-secondary) 62%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 12%, transparent);
  }

  .theme-launch svg {
    width: 0.98rem;
    height: 0.98rem;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .theme-icon-sun {
    display: none;
  }

  :root[data-theme='dark'] .theme-icon-moon {
    display: none;
  }

  :root[data-theme='dark'] .theme-icon-sun {
    display: block;
  }

  .contact-btn:hover,
  .contact-btn:focus-visible {
    opacity: 0.86;
    color: #0e0c09;
    transform: translateY(-1px);
  }

  :root[data-theme='dark'] .nl {
    color: color-mix(in srgb, #ffffff 86%, var(--color-secondary));
  }

  :root[data-theme='dark'] .flyout,
  :root[data-theme='dark'] .sub-flyout {
    border-color: color-mix(in srgb, var(--color-secondary) 34%, rgba(255, 255, 255, 0.18));
    background: linear-gradient(158deg, rgba(15, 13, 10, 0.96), rgba(9, 8, 6, 0.98));
  }

  :root[data-theme='dark'] .group-link {
    color: color-mix(in srgb, #ffffff 90%, var(--color-secondary));
    border-bottom-color: color-mix(in srgb, var(--color-secondary) 28%, rgba(255, 255, 255, 0.12));
  }

  :root[data-theme='dark'] .group-item:hover > .group-link,
  :root[data-theme='dark'] .group-item:focus-within > .group-link {
    background: color-mix(in srgb, var(--color-secondary) 14%, transparent);
  }

  :root[data-theme='dark'] .group-link small,
  :root[data-theme='dark'] .sub-flyout li a span,
  :root[data-theme='dark'] :global(.search-results-panel li span),
  :root[data-theme='dark'] :global(.search-results-panel li em) {
    color: color-mix(in srgb, #ffffff 72%, var(--color-secondary));
  }

  :root[data-theme='dark'] .sub-flyout li a strong {
    color: color-mix(in srgb, #ffffff 94%, var(--color-secondary));
  }

  :root[data-theme='dark'] .sub-flyout li a {
    background: color-mix(in srgb, #0f0d0a 92%, transparent);
  }

  :root[data-theme='dark'] .search-launch {
    border-color: color-mix(in srgb, var(--color-secondary) 58%, transparent);
    background: color-mix(in srgb, var(--color-card-bg) 86%, #050505);
    color: color-mix(in srgb, #ffffff 92%, var(--color-secondary));
  }

  :root[data-theme='dark'] .search-launch svg {
