---
---

<header>
  <nav class="navbar">
    <div class="nav-container">
      <div class="logo">
        <a href="/">
          <span class="brand-name">Velnora</span>
          <span class="tagline">Tools that ship ideas</span>
        </a>
      </div>
      
      <ul class="nav-menu">
        <li><a href="/">Home</a></li>
        <li><a href="/tools">Tools</a></li>
        <li><a href="/learning-hub">Learning Hub</a></li>
        <li><a href="/library">Prompts</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>
  </nav>
</header>

<style>
  header {
    background: rgba(255, 249, 237, 0.88);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
  }
  
  .navbar {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.35rem 1.2rem;
  }
  
  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    min-height: 72px;
  }
  
  .logo a {
    display: flex;
    flex-direction: column;
    padding: 0;
    gap: 0.12rem;
    color: var(--color-primary);
  }
  
  .brand-name {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.015em;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .tagline {
    font-size: 0.7rem;
    font-weight: 700;
    color: #ab5f22;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  
  .nav-menu {
    display: flex;
    list-style: none;
    gap: 0.45rem;
    align-items: center;
  }
  
  .nav-menu a {
    font-weight: 600;
    transition: all 0.22s ease;
    color: #2d3d58;
    border-radius: 999px;
    padding: 0.5rem 0.8rem;
  }
  
  .nav-menu a:hover {
    color: var(--color-primary);
    background: rgba(255, 93, 61, 0.13);
  }
  
  @media (max-width: 768px) {
    .navbar {
      padding: 0.4rem 0.8rem;
    }

    .nav-menu {
      gap: 0.35rem;
      font-size: 0.8rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .nav-menu a {
      padding: 0.38rem 0.62rem;
    }
    
    .nav-container {
      flex-direction: column;
      gap: 0.55rem;
      height: auto;
      padding: 0.65rem 0;
    }
  }
</style>
