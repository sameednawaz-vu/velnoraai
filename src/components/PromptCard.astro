---
interface Props {
  title: string;
  description: string;
  example: string;
  useCase: string;
  category: string;
}

const { title, description, example, useCase, category } = Astro.props;
---

<div class="prompt-card">
  <div class="card-header">
    <h3>{title}</h3>
    <span class="category-badge">{category}</span>
  </div>

  <p class="description">{description}</p>

  <div class="example-section">
    <h4>Example Use:</h4>
    <p class="example">{example}</p>
  </div>

  <div class="usecase-section">
    <h4>Best For:</h4>
    <p class="usecase">{useCase}</p>
  </div>

  <button class="copy-btn" data-prompt={description}>
    Copy prompt
  </button>
</div>

<style>
  .prompt-card {
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    box-shadow: var(--shadow-soft);
  }

  .prompt-card:hover {
    box-shadow: var(--shadow-medium);
    border-color: color-mix(in srgb, var(--color-accent) 44%, var(--color-border));
    transform: translateY(-3px);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.18rem;
    gap: 1rem;
  }

  .card-header h3 {
    font-size: 1.08rem;
    color: var(--color-primary);
    margin: 0;
  }

  .category-badge {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 42%, transparent);
    padding: 0.19rem 0.6rem;
    border-radius: 2rem;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
  }

  .description {
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
    margin-bottom: 0.35rem;
    line-height: 1.6;
  }

  .example-section,
  .usecase-section {
    margin-bottom: 0.45rem;
  }

  .example-section h4,
  .usecase-section h4 {
    font-size: 0.75rem;
    color: var(--color-accent);
    margin-bottom: 0.42rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: var(--font-mono);
  }

  .example,
  .usecase {
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    padding: 0.65rem;
    border-left: 3px solid color-mix(in srgb, var(--color-secondary) 70%, transparent);
    border-radius: 0.55rem;
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
  }

  .copy-btn {
    align-self: flex-start;
    margin-top: auto;
    padding: 0.42rem 0.76rem;
    background: linear-gradient(128deg, var(--color-secondary), #ff8a54);
    color: white;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 55%, transparent);
    border-radius: 0.55rem;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .copy-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(235, 94, 40, 0.22);
  }

  .copy-btn.copied {
    background: linear-gradient(120deg, #1f9d65, #2ab674);
    border-color: rgba(36, 151, 102, 0.62);
  }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const prompt = (e.target as HTMLButtonElement).dataset.prompt;
      try {
        await navigator.clipboard.writeText(prompt || '');
        (e.target as HTMLButtonElement).textContent = '✓ Copied!';
        (e.target as HTMLButtonElement).classList.add('copied');
        setTimeout(() => {
          (e.target as HTMLButtonElement).textContent = 'Copy prompt';
          (e.target as HTMLButtonElement).classList.remove('copied');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy:', err);
      }
    });
  });
</script>
