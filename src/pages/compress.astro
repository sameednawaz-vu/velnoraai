---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SurfaceHub from '../components/utility/SurfaceHub.astro';
import catalog from '../content/data/freeconvert-catalog.json';

const surface = catalog.surfaces.find((entry) => entry.slug === 'compress');
if (!surface) {
  throw new Error('Compress surface catalog not found.');
}

const allTools = surface.groups.flatMap((group) => group.tools);
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Compress tools by Velnora',
  itemListElement: allTools.map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: tool.name,
    url: `https://velnoraai.app/utility/${surface.slug}/${tool.slug}`,
  })),
};
---

<BaseLayout
  title="Compress"
  description="Compress surface with browser-cached media and document compression routes built for deterministic output."
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <Header />

  <main class="page-shell surface-page">
    <SurfaceHub surface={surface} eyebrow="Compress Surface" />

    <section class="section-panel" data-reveal>
      <h2>Compression engine strategy</h2>
      <p class="lede">
        Compress utilities use browser-first execution with reusable local caching. First run loads conversion engines,
        then repeat runs are faster because core assets remain cached in the browser.
      </p>
      <ul>
        <li>Media compression routes run through cached browser FFmpeg core.</li>
        <li>Image and PDF compression uses deterministic in-browser processing.</li>
        <li>No upload required for core compression flows in this surface.</li>
      </ul>
      <div class="cta-row">
        <a class="btn-link" href="/working-tools">Review current working compressors</a>
      </div>
    </section>

    <section class="section-panel" data-reveal>
      <h2>Compression roadmap</h2>
      <p class="lede">
        Compression utilities listed here are active routes from the current browser-supported stack.
      </p>
      <div class="cta-row">
        <a class="btn-link" href="/convert">Open Convert Surface</a>
        <a class="btn-link" href="/utility-tools">Open Tools Surface</a>
        <a class="btn-link" href="/working-tools">Open Working Tools</a>
        <a class="btn-link" href="/blog">Open Blog Guides</a>
        <a class="btn-link" href="/tools/business-finance">See Existing Calculators</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .surface-page ul {
    margin: 0;
    padding-left: 1.05rem;
    display: grid;
    gap: 0.34rem;
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
    line-height: 1.55;
  }
</style>
