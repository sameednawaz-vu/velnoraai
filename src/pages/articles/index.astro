---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Article Index"
  description="Browse tool guides, workflows, and decision frameworks for free conversion and utility tools."
>
  <main style="padding: 2rem; text-align: center; min-height: 50vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
    <h1>Article Index</h1>
    <p style="margin: 1.5rem 0; font-size: 1.1rem; max-width: 600px;">
      This section redirects to the blog index where you'll find all our guides, workflows, and decision frameworks.
    </p>
    <p>
      <a href="/blog" style="display: inline-block; margin-top: 1rem; padding: 0.75rem 1.5rem; background: var(--color-secondary); color: var(--color-primary); text-decoration: none; border-radius: 8px; font-weight: 600;">
        Go to Blog →
      </a>
    </p>
  </main>
</BaseLayout>

