---
import ToolArticleLayout from '../../layouts/ToolArticleLayout.astro';
import { toolArticles } from '../../lib/article-catalog';
import articleVisuals from '../../content/data/article-visuals.json';
import toolVisuals from '../../content/data/tool-page-visuals.json';
import { withImageCdn } from '../../lib/image-cdn';

export async function getStaticPaths() {
  return toolArticles.map((article) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const article = toolArticles.find((entry) => entry.slug === slug);

if (!article) {
  throw new Error(`Article ${slug} not found.`);
}

const relatedArticles =
  article.relatedArticles.length > 0
    ? article.relatedArticles
    : toolArticles
        .filter(
          (entry) =>
            entry.slug !== article.slug &&
            (entry.sectionLabel === article.sectionLabel || entry.familyLabel === article.familyLabel)
        )
        .map((entry) => ({
          slug: entry.slug,
          title: entry.articleTitle,
          href: entry.articleHref,
        }))
        .slice(0, 8);

const relatedTools = article.relatedTools;

type VisualEntry = {
  imageWebp: string;
  imageAvif: string;
  imageFallback: string;
  alt: string;
  caption: string;
};

const articleVisualMap = articleVisuals as Record<string, VisualEntry>;
const toolVisualMap = toolVisuals as Record<string, VisualEntry>;

const rawVisual =
  articleVisualMap[article.slug] ??
  toolVisualMap[article.slug] ?? {
    imageWebp: '/images/favicon-velnora.webp',
    imageAvif: '/images/favicon-velnora.avif',
    imageFallback: '/images/favicon-velnora.jpg',
    alt: `${article.articleTitle} visual`,
    caption: article.articleDescription,
  };

const visual = {
  ...rawVisual,
  imageWebp: withImageCdn(rawVisual.imageWebp),
  imageAvif: withImageCdn(rawVisual.imageAvif),
  imageFallback: withImageCdn(rawVisual.imageFallback),
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.articleTitle,
  description: article.articleDescription,
  image: visual.imageWebp,
  author: {
    '@type': 'Organization',
    name: 'Velnora',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Velnora',
    url: 'https://velnoraai.app',
  },
  datePublished: article.updatedDate,
  dateModified: article.updatedDate,
  mainEntityOfPage: `https://velnoraai.app${article.articleHref}`,
  articleSection: `${article.sectionLabel} - ${article.articleTypeLabel}`,
  keywords: article.keywords.join(', '),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://velnoraai.app/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Articles',
      item: 'https://velnoraai.app/articles',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.articleTitle,
      item: `https://velnoraai.app${article.articleHref}`,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: article.faq.map((entry) => ({
    '@type': 'Question',
    name: entry.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: entry.answer,
    },
  })),
};
---

<ToolArticleLayout
  title={article.articleTitle}
  description={article.articleDescription}
  toolName={article.toolName}
  updatedDate={article.updatedDate}
  familyLabel={article.familyLabel}
  articleTypeLabel={article.articleTypeLabel}
  sectionLabel={article.sectionLabel}
  clusterLabel={article.clusterLabel}
  toolHref={article.toolHref}
  relatedTools={relatedTools}
  relatedArticles={relatedArticles}
  visual={visual}
>
  <script slot="schemas" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script slot="schemas" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script slot="schemas" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section>
    <h2>What this tool helps you do</h2>
    <p>{article.introParagraph}</p>
    <p>{article.summaryParagraph}</p>
  </section>

  <section>
    <h2>How to use this workflow</h2>
    <ol>
      {article.steps.map((step) => (
        <li>{step}</li>
      ))}
    </ol>
  </section>

  <section>
    <h2>Best use cases</h2>
    <ul>
      {article.useCases.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section>
    <h2>SEO and GEO optimization notes</h2>
    <p>
      This article is built for both search engine indexing and generative engine retrieval by keeping tool intent,
      workflow steps, and decision context in clear semantic sections.
    </p>
    <p>
      For best results, pair this guide with the live tool route, then publish supporting pages that include
      practical examples, expected outputs, and consistent terminology.
    </p>
  </section>

  <section>
    <h2>Trusted source reference</h2>
    <p>
      For semantic SEO validation and structured implementation guidance, review the official Search Central
      documentation alongside this workflow.
    </p>
    <p>
      <a href="https://developers.google.com/search/docs/fundamentals/seo-starter-guide" target="_blank" rel="noopener noreferrer">
        Google Search Central SEO starter guide
      </a>
    </p>
  </section>

  <section>
    <h2>Frequently asked questions</h2>
    <dl class="faq-list">
      {article.faq.map((entry) => (
        <>
          <dt>{entry.question}</dt>
          <dd>{entry.answer}</dd>
        </>
      ))}
    </dl>
  </section>
</ToolArticleLayout>
