---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SurfaceHub from '../components/utility/SurfaceHub.astro';
import catalog from '../content/data/freeconvert-catalog.json';
import competitorFormats from '../content/data/competitor-convertio-formats.json';

const surface = catalog.surfaces.find((entry) => entry.slug === 'convert');
if (!surface) {
  throw new Error('Convert surface catalog not found.');
}

const allTools = surface.groups.flatMap((group) => group.tools);
const coverageRatio = Math.max(1, Math.round((allTools.length / competitorFormats.totals.formats) * 100));
const competitorCategories = [...competitorFormats.categories].sort((first, second) => second.formatCount - first.formatCount);
const competitorUpdatedLabel = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'UTC',
}).format(new Date(competitorFormats.generatedAt));
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Convert tools by Velnora',
  itemListElement: allTools.map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: tool.name,
    url: `https://velnoraai.app/utility/${surface.slug}/${tool.slug}`,
  })),
};
---

<BaseLayout
  title="Convert"
  description="Convert surface with browser-supported media/image routes powered by cached local conversion engines."
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <Header />

  <main class="surface-page">
    <SurfaceHub surface={surface} eyebrow="Convert Surface" />

    <section class="stack-panel" data-reveal>
      <h2>Active conversion stack</h2>
      <p>
        Convert routes are now limited to the supported browser stack only. Heavy runtime engines are cached after first
        load to speed up repeat conversions on the same device.
      </p>
      <ul>
        <li>FFmpeg core bundle for media conversion and compression (cached after first run).</li>
        <li>Lightweight browser utilities for image transformations and deterministic output generation.</li>
        <li>Unsupported desktop-only conversion routes removed from this surface.</li>
      </ul>
      <a href="/working-tools">Open working-tools status page</a>
    </section>

    <section class="intel-panel" data-reveal>
      <div class="intel-head">
        <p class="intel-kicker">Stage-three competitor intelligence</p>
        <h2>{competitorFormats.totals.formats} source formats mapped into a refreshable planning feed.</h2>
        <p>
          This panel is generated by a scraper pipeline, not hand-edited lists. Re-run
          <code>npm run scrape:convertio</code> to refresh the catalog snapshot and keep planning data current.
        </p>
      </div>

      <div class="intel-metrics">
        <article>
          <span class="metric">{competitorFormats.totals.formats}</span>
          <h3>Competitor formats tracked</h3>
          <p>Across {competitorFormats.totals.categories} categories from the source matrix.</p>
        </article>
        <article>
          <span class="metric">{allTools.length}</span>
          <h3>Velnora convert tools now listed</h3>
          <p>Current coverage baseline is {coverageRatio}% of the competitor format count benchmark.</p>
        </article>
        <article>
          <span class="metric">{competitorFormats.totals.writeEnabled}</span>
          <h3>Write-enabled source formats</h3>
          <p>Snapshot mode: {competitorFormats.source.mode}. Updated {competitorUpdatedLabel} UTC.</p>
        </article>
      </div>

      <div class="intel-grid">
        {competitorCategories.map((category) => (
          <article class="intel-card">
            <div class="intel-card-head">
              <h3>{category.name}</h3>
              <span>{category.formatCount}</span>
            </div>
            <p>
              Read: {category.readCount} | Write: {category.writeCount}
            </p>
            <ul class="intel-chips">
              {category.formats.slice(0, 10).map((format) => (
                <li>{format.extension}</li>
              ))}
            </ul>
            <a href={category.formats[0]?.sourceUrl ?? competitorFormats.source.url} target="_blank" rel="noopener noreferrer">
              Open category source
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="counter-panel" data-reveal>
      <div>
        <p class="counter-kicker">Live counter</p>
        <h2>Local converted actions started from this browser</h2>
        <p>
          This counter increments when you open a Convert utility route on this surface. It is fully client-side,
          persisted in localStorage, and transparent about its local scope.
        </p>
      </div>
      <div class="counter-shell">
        <strong data-convert-counter-value>0</strong>
        <p data-convert-counter-status>No conversion actions started yet.</p>
        <button type="button" data-convert-counter-reset>Reset local counter</button>
      </div>
    </section>

    <section class="surface-note" data-reveal>
      <h2>Implementation track</h2>
      <p>
        This surface is now restricted to actively supported browser-conversion routes from the current technical stack.
      </p>
      <div class="links-row">
        <a href="/compress">Open Compress Surface</a>
        <a href="/utility-tools">Open Tools Surface</a>
        <a href="/working-tools">Open Working Tools</a>
        <a href="/tools">Browse Capability Index</a>
        <a href="/articles">Browse Tool Articles</a>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const storageKey = 'velnora.convert.localCounter';
      const valueNode = document.querySelector('[data-convert-counter-value]');
      const statusNode = document.querySelector('[data-convert-counter-status]');
      const resetButton = document.querySelector('[data-convert-counter-reset]');

      if (!valueNode || !statusNode) {
        return;
      }

      const toCount = (value) => {
        const parsed = Number.parseInt(String(value), 10);
        return Number.isFinite(parsed) && parsed > 0 ? parsed : 0;
      };

      const render = (count) => {
        valueNode.textContent = count.toLocaleString('en-US');
        statusNode.textContent =
          count === 0
            ? 'No conversion actions started yet.'
            : `${count.toLocaleString('en-US')} conversion action${count === 1 ? '' : 's'} started in this browser.`;
      };

      let currentCount = toCount(window.localStorage.getItem(storageKey));
      render(currentCount);

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }

        const link = target.closest('a[href^="/utility/convert/"]');
        if (!link) {
          return;
        }

        currentCount += 1;
        window.localStorage.setItem(storageKey, String(currentCount));
        render(currentCount);
      });

      if (resetButton instanceof HTMLButtonElement) {
        resetButton.addEventListener('click', () => {
          currentCount = 0;
          window.localStorage.setItem(storageKey, '0');
          render(currentCount);
        });
      }
    })();
  </script>

  <Footer />
</BaseLayout>

<style>
  .surface-page {
    max-width: 1240px;
    margin: 0 auto;
    padding: 1.4rem 1rem 3rem;
    display: grid;
    gap: 1rem;
  }

  .surface-note {
    border: 1px solid var(--color-border);
    border-radius: 0.86rem;
    background: #fffdf7;
    padding: 1rem;
    box-shadow: var(--shadow-soft);
  }

  .stack-panel {
    border: 1px solid #d8e4f2;
    border-radius: 0.9rem;
    background: linear-gradient(145deg, #fefefe 0%, #f1f8ff 62%, #f3fbf7 100%);
    padding: 1rem;
    box-shadow: var(--shadow-soft);
    display: grid;
    gap: 0.6rem;
  }

  .stack-panel p {
    color: #466281;
    line-height: 1.6;
    margin: 0;
  }

  .stack-panel ul {
    margin: 0;
    padding-left: 1.1rem;
    color: #3f5a78;
    display: grid;
    gap: 0.28rem;
  }

  .stack-panel a {
    width: fit-content;
    border: 1px solid #d6c3a4;
    background: #fff7e8;
    color: #25415f;
    border-radius: 0.48rem;
    padding: 0.45rem 0.68rem;
    font-weight: 700;
  }

  .intel-panel,
  .counter-panel {
    border: 1px solid #d3deea;
    border-radius: 0.95rem;
    padding: 1.15rem;
    background: linear-gradient(155deg, #fbfcff 0%, #f3f9ff 58%, #f8fbf5 100%);
    box-shadow: var(--shadow-soft);
  }

  .intel-kicker,
  .counter-kicker {
    margin: 0 0 0.45rem;
    text-transform: uppercase;
    letter-spacing: 0.11rem;
    font-size: 0.76rem;
    font-weight: 700;
    color: #5d7193;
  }

  .intel-head h2,
  .counter-panel h2 {
    margin-bottom: 0.5rem;
    font-size: clamp(1.26rem, 2.7vw, 1.65rem);
  }

  .intel-head p,
  .counter-panel p {
    color: #455d7f;
    line-height: 1.58;
  }

  .intel-head code {
    font-size: 0.88em;
    font-weight: 700;
    background: #ecf3ff;
    border: 1px solid #d6e4fb;
    padding: 0.12rem 0.36rem;
    border-radius: 0.34rem;
  }

  .intel-metrics {
    margin-top: 0.95rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .intel-metrics article {
    border-radius: 0.76rem;
    border: 1px solid #d7e4f2;
    background: #ffffff;
    padding: 0.85rem;
  }

  .intel-metrics .metric {
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
    color: #13294b;
  }

  .intel-metrics h3 {
    margin: 0.35rem 0;
    font-size: 0.95rem;
    color: #223d5f;
  }

  .intel-metrics p {
    margin: 0;
    font-size: 0.84rem;
  }

  .intel-grid {
    margin-top: 0.95rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 0.72rem;
  }

  .intel-card {
    border: 1px solid #d6e0ec;
    border-radius: 0.72rem;
    background: #ffffff;
    padding: 0.8rem;
    display: grid;
    gap: 0.5rem;
  }

  .intel-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .intel-card-head h3 {
    margin: 0;
    font-size: 0.98rem;
    color: #183455;
  }

  .intel-card-head span {
    border-radius: 999px;
    border: 1px solid #c2d5ee;
    background: #eff5ff;
    color: #163a63;
    font-weight: 700;
    font-size: 0.72rem;
    padding: 0.18rem 0.5rem;
  }

  .intel-card p {
    margin: 0;
    font-size: 0.8rem;
    color: #4f6483;
  }

  .intel-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .intel-chips li {
    border-radius: 999px;
    border: 1px solid #dae6f4;
    background: #f8fbff;
    color: #28486f;
    padding: 0.16rem 0.5rem;
    font-size: 0.73rem;
    font-weight: 600;
  }

  .intel-card a {
    font-weight: 700;
    color: #1a497c;
    font-size: 0.82rem;
  }

  .counter-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    background: linear-gradient(155deg, #fff7eb 0%, #f6faff 65%, #f3f8ec 100%);
  }

  .counter-shell {
    min-width: 220px;
    border: 1px solid #d8d9d5;
    border-radius: 0.78rem;
    background: rgba(255, 255, 255, 0.94);
    padding: 0.9rem;
    text-align: center;
    display: grid;
    gap: 0.42rem;
  }

  .counter-shell strong {
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    color: #1e3556;
  }

  .counter-shell p {
    margin: 0;
    font-size: 0.82rem;
  }

  .counter-shell button {
    border: 1px solid #c7cccf;
    border-radius: 0.45rem;
    background: #f8f9f8;
    color: #25425f;
    font-weight: 700;
    padding: 0.5rem 0.62rem;
    cursor: pointer;
  }

  .counter-shell button:hover {
    background: #edf5ff;
    border-color: #b5c8e5;
  }

  .surface-note p {
    margin-top: 0.45rem;
    color: #4e627f;
  }

  .links-row {
    margin-top: 0.85rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .links-row a {
    border: 1px solid #d6c3a4;
    background: #fff7e8;
    color: #25415f;
    border-radius: 0.48rem;
    padding: 0.5rem 0.72rem;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .surface-page {
      padding: 1rem 0.8rem 2.6rem;
    }

    .intel-metrics {
      grid-template-columns: 1fr;
    }

    .counter-panel {
      grid-template-columns: 1fr;
    }

    .counter-shell {
      min-width: 0;
      width: 100%;
    }
  }
</style>
