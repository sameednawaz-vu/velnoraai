---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SurfaceHub from '../components/utility/SurfaceHub.astro';
import catalog from '../content/data/freeconvert-catalog.json';
import competitorFormats from '../content/data/competitor-convertio-formats.json';

const surface = catalog.surfaces.find((entry) => entry.slug === 'convert');
if (!surface) {
  throw new Error('Convert surface catalog not found.');
}

const allTools = surface.groups.flatMap((group) => group.tools);
const coverageRatio = Math.max(1, Math.round((allTools.length / competitorFormats.totals.formats) * 100));
const competitorCategories = [...competitorFormats.categories].sort((first, second) => second.formatCount - first.formatCount);
const competitorUpdatedLabel = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'UTC',
}).format(new Date(competitorFormats.generatedAt));
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Convert tools by Velnora',
  itemListElement: allTools.map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: tool.name,
    url: `https://velnoraai.app/utility/${surface.slug}/${tool.slug}`,
  })),
};
---

<BaseLayout
  title="Convert"
  description="Convert surface with browser-supported media/image routes powered by cached local conversion engines."
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <Header />

  <main class="page-shell surface-page">
    <SurfaceHub surface={surface} eyebrow="Convert Surface" />

    <section class="section-panel" data-reveal>
      <h2>Active conversion stack</h2>
      <p class="lede">
        Convert routes are limited to browser-supported engines only. Core modules are cached after first load so repeat
        conversions on the same device become faster.
      </p>
      <ul>
        <li>FFmpeg core bundle for media conversion and compression.</li>
        <li>Lightweight browser utilities for deterministic image workflows.</li>
        <li>Unsupported desktop-only conversion routes removed from this surface.</li>
      </ul>
      <div class="cta-row">
        <a class="btn-link" href="/working-tools">Open working-tools status page</a>
      </div>
    </section>

    <section class="section-panel intel-panel" data-reveal>
      <div class="section-head">
        <p class="eyebrow">Stage-three competitor intelligence</p>
        <h2>{competitorFormats.totals.formats} source formats mapped into a refreshable planning feed.</h2>
        <p class="lede">
          This panel is generated by the scraper pipeline. Re-run
          <code>npm run scrape:convertio</code> to refresh the source snapshot.
        </p>
      </div>

      <div class="metric-grid">
        <article class="metric-card">
          <strong>{competitorFormats.totals.formats}</strong>
          <span>Competitor formats tracked</span>
        </article>
        <article class="metric-card">
          <strong>{allTools.length}</strong>
          <span>Velnora convert tools listed</span>
        </article>
        <article class="metric-card">
          <strong>{competitorFormats.totals.writeEnabled}</strong>
          <span>Write-enabled formats</span>
        </article>
      </div>

      <p class="small-note">Coverage baseline: {coverageRatio}% · Snapshot mode: {competitorFormats.source.mode} · Updated {competitorUpdatedLabel} UTC.</p>

      <div class="intel-grid">
        {competitorCategories.map((category) => (
          <article class="intel-card">
            <div class="intel-card-head">
              <h3>{category.name}</h3>
              <span>{category.formatCount}</span>
            </div>
            <p>Read: {category.readCount} | Write: {category.writeCount}</p>
            <ul class="intel-chips">
              {category.formats.slice(0, 10).map((format) => (
                <li>{format.extension}</li>
              ))}
            </ul>
            <a href={category.formats[0]?.sourceUrl ?? competitorFormats.source.url} target="_blank" rel="noopener noreferrer">
              Open category source
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="section-panel counter-panel" data-reveal>
      <div>
        <p class="eyebrow">Live counter</p>
        <h2>Local converted actions started from this browser</h2>
        <p class="lede">
          This counter increments when you open a Convert utility route on this surface. It is fully client-side,
          persisted in localStorage, and scoped to this browser only.
        </p>
      </div>
      <div class="counter-shell">
        <strong data-convert-counter-value>0</strong>
        <p data-convert-counter-status>No conversion actions started yet.</p>
        <button type="button" data-convert-counter-reset>Reset local counter</button>
      </div>
    </section>

    <section class="section-panel" data-reveal>
      <h2>Implementation track</h2>
      <p class="lede">
        This surface is restricted to actively supported browser-conversion routes from the current technical stack.
      </p>
      <div class="cta-row">
        <a class="btn-link" href="/compress">Open Compress Surface</a>
        <a class="btn-link" href="/utility-tools">Open Tools Surface</a>
        <a class="btn-link" href="/working-tools">Open Working Tools</a>
        <a class="btn-link" href="/tools">Browse Capability Index</a>
        <a class="btn-link" href="/blog">Browse Blog Guides</a>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const storageKey = 'velnora.convert.localCounter';
      const valueNode = document.querySelector('[data-convert-counter-value]');
      const statusNode = document.querySelector('[data-convert-counter-status]');
      const resetButton = document.querySelector('[data-convert-counter-reset]');

      if (!valueNode || !statusNode) {
        return;
      }

      const toCount = (value) => {
        const parsed = Number.parseInt(String(value), 10);
        return Number.isFinite(parsed) && parsed > 0 ? parsed : 0;
      };

      const render = (count) => {
        valueNode.textContent = count.toLocaleString('en-US');
        statusNode.textContent =
          count === 0
            ? 'No conversion actions started yet.'
            : `${count.toLocaleString('en-US')} conversion action${count === 1 ? '' : 's'} started in this browser.`;
      };

      let currentCount = toCount(window.localStorage.getItem(storageKey));
      render(currentCount);

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) {
          return;
        }

        const link = target.closest('a[href^="/utility/convert/"]');
        if (!link) {
          return;
        }

        currentCount += 1;
        window.localStorage.setItem(storageKey, String(currentCount));
        render(currentCount);
      });

      if (resetButton instanceof HTMLButtonElement) {
        resetButton.addEventListener('click', () => {
          currentCount = 0;
          window.localStorage.setItem(storageKey, '0');
          render(currentCount);
        });
      }
    })();
  </script>

  <Footer />
</BaseLayout>

<style>
  .surface-page ul {
    margin: 0;
    padding-left: 1.05rem;
    display: grid;
    gap: 0.32rem;
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
    line-height: 1.55;
  }

  .section-head {
    display: grid;
    gap: 0.24rem;
    margin-bottom: 0.72rem;
  }

  code {
    border: 1px solid var(--color-border);
    border-radius: 0.42rem;
    padding: 0.08rem 0.28rem;
    background: color-mix(in srgb, var(--color-card-bg) 94%, transparent);
  }

  .small-note {
    margin-top: 0.68rem;
    color: color-mix(in srgb, var(--color-text) 66%, transparent);
    font-size: 0.74rem;
    font-family: var(--font-mono);
  }

  .intel-grid {
    margin-top: 0.8rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 0.65rem;
  }

  .intel-card {
    border: 1px solid var(--color-border);
    border-radius: 0.72rem;
    background: color-mix(in srgb, var(--color-card-bg) 94%, transparent);
    padding: 0.72rem;
    display: grid;
    gap: 0.45rem;
  }

  .intel-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
  }

  .intel-card-head h3 {
    font-size: 0.92rem;
  }

  .intel-card-head span {
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 34%, transparent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-primary);
    padding: 0.16rem 0.48rem;
    font-size: 0.67rem;
    font-weight: 700;
  }

  .intel-card p {
    font-size: 0.78rem;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
  }

  .intel-chips {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .intel-chips li {
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-card-bg) 95%, transparent);
    color: var(--color-primary);
    padding: 0.14rem 0.45rem;
    font-size: 0.66rem;
    font-weight: 600;
  }

  .intel-card a {
    color: var(--color-secondary);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .counter-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.8rem;
    align-items: center;
  }

  .counter-shell {
    min-width: 230px;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--color-card-bg) 95%, transparent);
    padding: 0.75rem;
    text-align: center;
    display: grid;
    gap: 0.4rem;
  }

  .counter-shell strong {
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
    color: var(--color-primary);
  }

  .counter-shell p {
    margin: 0;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
    font-size: 0.78rem;
  }

  .counter-shell button {
    border: 1px solid color-mix(in srgb, var(--color-secondary) 36%, transparent);
    border-radius: 0.58rem;
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.42rem 0.58rem;
  }

  @media (max-width: 980px) {
    .counter-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
