---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/tools/ToolCard.astro';
import toolsData from '../../content/data/tools.json';
import catalog from '../../content/data/freeconvert-catalog.json';
import competitorFormats from '../../content/data/competitor-convertio-formats.json';
import { blogPosts } from '../../content/data/blog-posts';

const publishedTools = toolsData.tools.filter((tool) => tool.status === 'published');
const utilityToolCount = catalog.surfaces.reduce(
  (count, surface) => count + surface.groups.reduce((groupCount, group) => groupCount + group.tools.length, 0),
  0
);
const capabilityCount = publishedTools.length + utilityToolCount + competitorFormats.totals.formats;
const allCategories = toolsData.categories;
const categorySummaries = toolsData.categories
  .map((category) => {
    const count = publishedTools.filter((tool) => tool.category === category.slug).length;
    return { ...category, count };
  })
  .filter((category) => category.count > 0);

const getSurfaceRoute = (surfaceSlug: string) => {
  if (surfaceSlug === 'convert') {
    return '/convert';
  }

  if (surfaceSlug === 'compress') {
    return '/compress';
  }

  return '/utility-tools';
};

const utilityCategorySummaries = catalog.surfaces.flatMap((surface) =>
  surface.groups.map((group) => ({
    slug: `${surface.slug}-${group.slug}`,
    name: `${surface.name} - ${group.name}`,
    count: group.tools.length,
    href: getSurfaceRoute(surface.slug),
    type: 'Utility Surface',
  }))
);

const unifiedCategorySummaries = [
  ...categorySummaries.map((category) => ({
    slug: category.slug,
    name: category.name,
    count: category.count,
    href: `/tools/${category.slug}`,
    type: 'Professional',
  })),
  ...utilityCategorySummaries,
];

const totalCategoryCount = unifiedCategorySummaries.length;

const directoryCategories = categorySummaries.map((category) => ({
  name: category.name,
  count: category.count,
  type: 'Professional',
  tools: publishedTools
    .filter((tool) => tool.category === category.slug)
    .map((tool) => ({
      name: tool.name,
      href: `/tools/${tool.category}/${tool.slug}`,
      feature: tool.valueProposition ?? tool.description ?? `${tool.name} workflow route.`,
    })),
}));

const utilityDirectoryCategories = catalog.surfaces.flatMap((surface) =>
  surface.groups.map((group) => ({
    name: `${surface.name} - ${group.name}`,
    count: group.tools.length,
    type: 'Utility Surface',
    tools: group.tools.map((tool) => ({
      name: tool.name,
      href: `/utility/${surface.slug}/${tool.slug}`,
      feature: `${tool.name} utility route in ${surface.name} / ${group.name}.`,
    })),
  }))
);

const unifiedDirectoryCategories = [...directoryCategories, ...utilityDirectoryCategories];

const utilityTools = catalog.surfaces.flatMap((surface) =>
  surface.groups.flatMap((group) =>
    group.tools.map((tool) => ({
      name: tool.name,
      url: `https://velnoraai.app/utility/${surface.slug}/${tool.slug}`,
    }))
  )
);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Velnora Tools',
  itemListElement: [
    ...publishedTools.map((tool) => ({
      name: tool.name,
      url: `https://velnoraai.app/tools/${tool.category}/${tool.slug}`,
    })),
    ...utilityTools,
  ].map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: tool.name,
    url: tool.url,
  })),
};
---

<BaseLayout
  title="Tools"
  description={`Browse Velnora's free tools library with ${capabilityCount.toLocaleString('en-US')} mapped capabilities, unified categories, and blog-supported execution guidance.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <Header />

  <main class="page-shell tools-page">
    <section class="hero-panel" data-reveal>
      <p class="eyebrow">Unified Tools Command Center</p>
      <h1>{capabilityCount.toLocaleString('en-US')} capabilities across {totalCategoryCount} active categories</h1>
      <p class="lede">
        Browse professional tools and utility surfaces together, then move from the index into live execution with companion guidance in the blog.
      </p>
      <ul class="chip-list">
        <li class="chip">{blogPosts.length} blog posts</li>
        <li class="chip">{publishedTools.length} professional tools</li>
        <li class="chip">{utilityToolCount} utility routes</li>
      </ul>
    </section>

    <section class="section-panel" data-reveal>
      <div class="section-head">
        <h2>Category surfaces</h2>
      </div>
      <div class="category-strip">
        {unifiedCategorySummaries.map((category) => (
          <a href={category.href}>
            <strong>{category.name}</strong>
            <small>{category.type}</small>
            <span>{category.count} tools</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section-panel directory-panel" id="all-tools-directory" data-reveal>
      <div class="section-head">
        <h2>Open tool directory</h2>
        <p>Jump directly into live routes and use the info hints to pick the right tool quickly.</p>
      </div>

      <p class="info-message" id="tool-info-message" role="status" aria-live="polite">
        Select an info button to preview what each linked tool is best for.
      </p>

      <div class="directory-grid">
        {unifiedDirectoryCategories.map((category) => (
          <article class="directory-category">
            <header>
              <h3>{category.name} <small>({category.type})</small></h3>
              <span>{category.count}</span>
            </header>

            <ul>
              {category.tools.map((tool) => (
                <li class="directory-tool-item">
                  <a href={tool.href}>{tool.name}</a>
                  <button
                    class="info-dot"
                    type="button"
                    aria-label={`Feature details for ${tool.name}`}
                    data-info-button
                    data-tool-name={tool.name}
                    data-tool-message={tool.feature}
                  >
                    i
                  </button>
                  <span class="info-tooltip" role="tooltip">{tool.feature}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="section-panel search-panel" data-reveal>
      <div class="search-input-wrap">
        <label for="tool-search">Search tools</label>
        <input
          id="tool-search"
          type="text"
          placeholder="Search by tool name or tag"
          aria-label="Search tools"
        />
      </div>

      <div class="search-filters">
        <div>
          <label for="tool-category-filter">Professional category</label>
          <select id="tool-category-filter" aria-label="Filter by category">
            <option value="all">All categories</option>
            {allCategories.map((category) => (
              <option value={category.slug}>{category.name}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="tool-mode-filter">Mode</label>
          <select id="tool-mode-filter" aria-label="Filter by mode">
            <option value="all">All modes</option>
            <option value="L">L: Launch now</option>
            <option value="B">B: Build-time</option>
            <option value="O">O: Optional API enhancement</option>
          </select>
        </div>

        <button id="tool-filter-reset" type="button">Clear filters</button>
      </div>
    </section>

    <section class="section-panel" data-reveal>
      <div class="section-head">
        <h2>Published professional tool pages</h2>
        <p>
          <span id="tools-visible-count">{publishedTools.length}</span> of {publishedTools.length} tools visible.
        </p>
      </div>

      <div class="tools-grid">
        {publishedTools.map((tool) => (
          <ToolCard tool={tool} />
        ))}
      </div>

      <p class="no-results" id="tools-no-results" hidden>
        No tools matched your current search and filters. Try clearing filters or adjusting your search terms.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const setupToolSearch = () => {
    const searchInput = document.getElementById('tool-search');
    const categoryFilter = document.getElementById('tool-category-filter');
    const modeFilter = document.getElementById('tool-mode-filter');
    const resetButton = document.getElementById('tool-filter-reset');
    const countNode = document.getElementById('tools-visible-count');
    const noResultsNode = document.getElementById('tools-no-results');
    const infoMessageNode = document.getElementById('tool-info-message');
    const infoButtons = Array.from(document.querySelectorAll('[data-info-button]'));
    const cards = Array.from(document.querySelectorAll('[data-tool-card]'));

    if (!(searchInput instanceof HTMLInputElement) || !(categoryFilter instanceof HTMLSelectElement) || !(modeFilter instanceof HTMLSelectElement) || !(resetButton instanceof HTMLButtonElement) || !(countNode instanceof HTMLElement) || !(noResultsNode instanceof HTMLElement)) {
      return;
    }

    const url = new URL(window.location.href);
    const prefill = url.searchParams.get('search') ?? url.searchParams.get('search_term_string');
    if (prefill) {
      searchInput.value = prefill;
    }

    const update = () => {
      const query = searchInput.value.trim().toLowerCase();
      const category = categoryFilter.value;
      const mode = modeFilter.value;
      let visible = 0;

      for (const card of cards) {
        const cardName = (card.getAttribute('data-name') ?? '').toLowerCase();
        const cardTags = (card.getAttribute('data-tags') ?? '').toLowerCase();
        const cardCategory = card.getAttribute('data-category') ?? '';
        const cardMode = card.getAttribute('data-mode') ?? '';

        const queryMatch = query.length === 0 || cardName.includes(query) || cardTags.includes(query);
        const categoryMatch = category === 'all' || cardCategory === category;
        const modeMatch = mode === 'all' || cardMode === mode;

        const isVisible = queryMatch && categoryMatch && modeMatch;
        card.toggleAttribute('hidden', !isVisible);
        if (isVisible) {
          visible += 1;
        }
      }

      countNode.textContent = `${visible}`;
      noResultsNode.toggleAttribute('hidden', visible !== 0);
    };

    searchInput.addEventListener('input', update);
    categoryFilter.addEventListener('change', update);
    modeFilter.addEventListener('change', update);
    resetButton.addEventListener('click', () => {
      searchInput.value = '';
      categoryFilter.value = 'all';
      modeFilter.value = 'all';
      update();
    });

    if (infoMessageNode instanceof HTMLElement) {
      for (const button of infoButtons) {
        if (!(button instanceof HTMLButtonElement)) {
          continue;
        }

        const applyMessage = () => {
          const toolName = button.dataset.toolName ?? 'Selected tool';
          const detail = button.dataset.toolMessage ?? 'No details available yet.';
          infoMessageNode.textContent = `${toolName}: ${detail}`;
        };

        button.addEventListener('click', applyMessage);
        button.addEventListener('focus', applyMessage);
      }
    }

    update();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupToolSearch, { once: true });
  } else {
    setupToolSearch();
  }
</script>

<style>
  .section-head {
    display: grid;
    gap: 0.24rem;
    margin-bottom: 0.8rem;
  }

  .section-head p {
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
    font-size: 0.86rem;
  }

  .category-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.6rem;
  }

  .category-strip a {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 0.75rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-areas:
      'title count'
      'type count';
    gap: 0.22rem 0.55rem;
    align-items: baseline;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    color: var(--color-primary);
  }

  .category-strip a:hover {
    border-color: color-mix(in srgb, var(--color-accent) 48%, transparent);
  }

  .category-strip strong {
    grid-area: title;
    font-size: 0.9rem;
  }

  .category-strip small {
    grid-area: type;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, var(--color-text) 64%, transparent);
    font-family: var(--font-mono);
  }

  .category-strip span {
    grid-area: count;
    font-size: 0.78rem;
    color: var(--color-secondary);
    font-weight: 700;
  }

  .directory-panel {
    display: grid;
    gap: 0.75rem;
  }

  .info-message {
    border: 1px solid color-mix(in srgb, var(--color-accent) 32%, transparent);
    border-radius: 0.68rem;
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    padding: 0.58rem 0.68rem;
    font-size: 0.84rem;
    color: color-mix(in srgb, var(--color-text) 85%, transparent);
  }

  .directory-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.7rem;
  }

  .directory-category {
    border: 1px solid var(--color-border);
    border-radius: 0.74rem;
    padding: 0.72rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    display: grid;
    gap: 0.55rem;
  }

  .directory-category header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .directory-category h3 {
    font-size: 0.94rem;
  }

  .directory-category h3 small {
    font-size: 0.66rem;
    color: color-mix(in srgb, var(--color-text) 64%, transparent);
    font-family: var(--font-mono);
  }

  .directory-category header span {
    font-size: 0.7rem;
    color: var(--color-secondary);
    font-weight: 700;
    font-family: var(--font-mono);
  }

  .directory-category ul {
    list-style: none;
    display: grid;
    gap: 0.35rem;
  }

  .directory-tool-item {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.4rem;
    align-items: center;
    padding: 0.36rem 0;
    border-bottom: 1px dashed color-mix(in srgb, var(--color-text) 16%, transparent);
  }

  .directory-tool-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .directory-tool-item a {
    font-size: 0.82rem;
    color: var(--color-primary);
  }

  .directory-tool-item a:hover {
    color: var(--color-secondary);
  }

  .info-dot {
    width: 1.28rem;
    height: 1.28rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-accent) 38%, transparent);
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
  }

  .info-tooltip {
    position: absolute;
    left: 0;
    top: calc(100% + 0.24rem);
    border: 1px solid var(--color-border);
    border-radius: 0.52rem;
    background: color-mix(in srgb, var(--color-card-bg) 96%, transparent);
    padding: 0.52rem;
    color: color-mix(in srgb, var(--color-text) 84%, transparent);
    font-size: 0.76rem;
    line-height: 1.4;
    width: min(320px, 85vw);
    box-shadow: var(--shadow-soft);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(4px);
    transition: opacity 0.16s ease, transform 0.16s ease;
    z-index: 4;
  }

  .info-dot:hover + .info-tooltip,
  .info-dot:focus-visible + .info-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .search-panel {
    display: grid;
    gap: 0.72rem;
  }

  .search-input-wrap {
    display: grid;
    gap: 0.34rem;
  }

  .search-input-wrap label,
  .search-filters label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .search-input-wrap input,
  .search-filters select {
    border: 1px solid var(--color-border);
    border-radius: 0.62rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    color: var(--color-primary);
    padding: 0.58rem 0.68rem;
    font-size: 0.93rem;
  }

  .search-filters {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
    gap: 0.55rem;
    align-items: end;
  }

  .search-filters > div {
    display: grid;
    gap: 0.34rem;
  }

  .search-filters button {
    border: 1px solid color-mix(in srgb, var(--color-secondary) 34%, transparent);
    border-radius: 0.6rem;
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
    color: var(--color-primary);
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.56rem 0.74rem;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.7rem;
  }

  .no-results {
    margin-top: 0.6rem;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 34%, transparent);
    border-radius: 0.66rem;
    background: color-mix(in srgb, var(--color-secondary) 10%, transparent);
    padding: 0.56rem 0.66rem;
    color: color-mix(in srgb, var(--color-text) 84%, transparent);
    font-size: 0.84rem;
  }

  @media (max-width: 820px) {
    .search-filters {
      grid-template-columns: 1fr;
    }

    .search-filters button {
      width: fit-content;
    }
  }
</style>
