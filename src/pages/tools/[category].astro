---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/tools/ToolCard.astro';
import toolsData from '../../content/data/tools.json';

export async function getStaticPaths() {
  return toolsData.categories.map((category) => ({
    params: { category: category.slug },
  }));
}

const { category } = Astro.params;
const publishedTools = toolsData.tools.filter((tool) => tool.status === 'published');
const categoryInfo = toolsData.categories.find((entry) => entry.slug === category);

if (!categoryInfo) {
  throw new Error(`Category ${category} not found.`);
}

const categoryTools = publishedTools.filter((tool) => tool.category === categoryInfo.slug);

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${categoryInfo.name} tools`,
  description: categoryInfo.description,
  url: `https://velnoraai.app/tools/${categoryInfo.slug}`,
};
---

<BaseLayout
  title={`${categoryInfo.name} Tools`}
  description={`${categoryInfo.description} Explore deterministic tool pages by Velnora.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />

  <Header />

  <main class="page-shell category-page">
    <div class="breadcrumb" data-reveal>
      <a href="/tools">Tools</a>
      <span>/</span>
      <span>{categoryInfo.name}</span>
    </div>

    <section class="hero-panel" data-reveal>
      <p class="eyebrow">Professional category</p>
      <h1>{categoryInfo.name}</h1>
      <p class="lede">{categoryInfo.description}</p>
      <ul class="chip-list">
        <li class="chip">{categoryTools.length} published tools</li>
        <li class="chip">Execution-first workflows</li>
      </ul>
    </section>

    {categoryTools.length > 0 ? (
      <section class="section-panel" data-reveal>
        <div class="tools-grid">
          {categoryTools.map((tool) => (
            <ToolCard tool={tool} />
          ))}
        </div>
      </section>
    ) : (
      <section class="section-panel" data-reveal>
        <h2>Tools for this category are in progress</h2>
        <p class="lede">
          This category is queued for upcoming publishing batches. Browse currently available tools while we ship this track.
        </p>
        <div class="cta-row">
          <a class="btn-link" href="/tools">Browse published tools</a>
        </div>
      </section>
    )}

    <section class="section-panel" data-reveal>
      <h2>Keep learning</h2>
      <p class="lede">
        Pair these tools with practical guides and examples for faster implementation.
      </p>
      <div class="cta-row">
        <a class="btn-link" href="/learning-hub">Learning Hub</a>
        <a class="btn-link" href="/blog">Blog</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.44rem;
    color: color-mix(in srgb, var(--color-text) 62%, transparent);
    font-size: 0.82rem;
    font-family: var(--font-mono);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.7rem;
  }
</style>
