---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AetherFlowHero from '../components/ui/aether-flow-hero';

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Velnora",
  "url": "https://velnoraai.app",
  "logo": "https://velnoraai.app/logo.png",
  "description": "Execution-first AI utility workspace for teams and founders shipping real output in the browser.",
  "sameAs": [
    "https://twitter.com/velnora",
    "https://linkedin.com/company/velnora",
    "https://github.com/velnora"
  ]
};
---

<BaseLayout title="Home - Velnora" description="Velnora is an execution-first workspace with 120 deterministic tools, searchable categories, and practical implementation routes.">
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  
  <Header />
  
  <main id="site-main" role="main">
    <!-- Framer Motion Hero Section -->
    <div data-reveal>
      <AetherFlowHero client:only="preact" />
    </div>

    <!-- Features Section -->
    <section class="features" data-reveal>
      <div class="container">
        <h2>Ship Work, Not Demos</h2>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">🧩</div>
            <h3>Run 120 Tools</h3>
            <p>Writing, SEO, developer, finance, UX, and communication tools in one production-ready platform.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🔎</div>
            <h3>Search and Filter</h3>
            <p>Find tools by name, tags, category, and mode from one searchable workspace index.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🗂️</div>
            <h3>Category Hubs</h3>
            <p>Each category includes dedicated hubs with crawlable tool routes for clear discovery.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">📈</div>
            <h3>SEO-ready Pages</h3>
            <p>Canonical URLs, structured data, internal links, and static route coverage are built in.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Categories Preview -->
    <section class="categories-preview" data-reveal>
      <div class="container">
        <h2>Choose a Surface, Start Running</h2>
        <div class="categories-grid">
          <div class="category-item">
            <h3>✍️ Writing and Messaging</h3>
            <p>Headlines, CTAs, outlines, tone adjustments, and messaging frameworks.</p>
            <a href="/tools/writing-messaging">Explore →</a>
          </div>
          <div class="category-item">
            <h3>📊 SEO and Content Ops</h3>
            <p>Metadata, schema, link operations, and publishing readiness helpers.</p>
            <a href="/tools/seo-content-ops">Explore →</a>
          </div>
          <div class="category-item">
            <h3>⚙️ Developer and Data</h3>
            <p>Formatters, converters, utilities, and technical workflow accelerators.</p>
            <a href="/tools/developer-data-core">Explore →</a>
          </div>
          <div class="category-item">
            <h3>💼 Business and Finance</h3>
            <p>Calculators and planning tools for pricing, budget, revenue, and cash flow.</p>
            <a href="/tools/business-finance">Explore →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section" data-reveal>
      <div class="container">
        <h2>Start in Minutes, Deliver in Hours</h2>
        <p>Use the tool index to locate the exact utility, run it immediately, and move straight into execution.</p>
        <div class="cta-buttons">
          <a href="/tools" class="btn btn-primary">Open Tool Workspace</a>
          <a href="/contact" class="btn btn-secondary">Talk to Velnora</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .btn {
    padding: 1rem 2rem;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 0.55rem;
    transition: all 0.3s ease;
    display: inline-block;
    text-decoration: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-secondary) 0%, #ff9134 100%);
    color: white;
    box-shadow: var(--shadow-soft);
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, #ff6f47 0%, #ff9b3d 100%);
    color: white;
    transform: translateY(-2px);
    box-shadow: var(--shadow-medium);
  }

  .btn-secondary {
    background: #fff6e8;
    color: var(--color-primary);
    border: 2px solid #d7c19f;
  }

  .btn-secondary:hover {
    background-color: #fff0d6;
    color: var(--color-primary);
    border-color: #b98a55;
    transform: translateY(-2px);
    box-shadow: var(--shadow-soft);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .features {
    padding: 4rem 2rem;
    background: linear-gradient(180deg, #fffdf7 0%, #fff2df 100%);
    border-radius: 1rem;
    margin: 1.2rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
  }

  .features h2,
  .categories-preview h2,
  .cta-section h2 {
    text-align: center;
    font-family: var(--font-display);
    font-size: 2.3rem;
    margin-bottom: 3rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background: #fffef9;
    padding: 2rem;
    border-radius: 0.75rem;
    text-align: center;
    transition: all 0.3s ease;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-medium);
    border-color: #d5b78f;
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    margin-bottom: 1rem;
    color: var(--color-cyan);
  }

  .feature-card p {
    color: #4f627e;
    line-height: 1.6;
  }

  .categories-preview {
    padding: 4rem 2rem;
    border-radius: 1rem;
    margin: 1.2rem;
    background: linear-gradient(180deg, #fff9ed 0%, #fff3e1 100%);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .category-item {
    background: #fffef8;
    padding: 2rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
    box-shadow: var(--shadow-soft);
  }

  .category-item:hover {
    border-color: #d1b188;
    box-shadow: var(--shadow-medium);
  }

  .category-item h3 {
    margin-bottom: 1rem;
    color: var(--color-purple);
  }

  .category-item p {
    color: #4f627e;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .category-item a {
    font-weight: 600;
    color: var(--color-cyan);
    transition: all 0.3s ease;
  }

  .category-item a:hover {
    color: var(--color-cyan);
  }

  .cta-section {
    padding: 4rem 2rem;
    background: linear-gradient(135deg, rgba(255, 93, 61, 0.12) 0%, rgba(10, 138, 130, 0.07) 100%);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    margin: 1.2rem;
    color: var(--color-primary);
    text-align: center;
    box-shadow: var(--shadow-soft);
  }

  .cta-section h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    color: #405572;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .features h2,
    .categories-preview h2,
    .cta-section h2 {
      font-size: 1.75rem;
    }

    .btn {
      padding: 0.75rem 1.5rem;
      font-size: 0.9rem;
    }

    .hero-section,
    .features,
    .categories-preview,
    .cta-section {
      margin: 0.7rem;
    }
  }
</style>
