---
import '../styles/tailwind.css';
import '../styles/design-only-2-home.css';
import DesignOnly2Home from '../components/home/DesignOnly2Home';
import { withImageCdn } from '../lib/image-cdn';

const title = 'Home | Velnora';
const description = '165 free professional utility tools. Convert, compress, and build in your browser. Secure, fast, and entirely client-side.';
const canonicalUrl = 'https://velnoraai.app/';
const socialImage = new URL(withImageCdn('/images/favicon-velnora.webp'), canonicalUrl).toString();
const faviconSvgImage = withImageCdn('/images/favicon-velnora.svg');
const faviconWebpImage = withImageCdn('/images/favicon-velnora.webp');

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Velnora',
  url: canonicalUrl,
  description,
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Velnora',
  url: canonicalUrl,
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://velnoraai.app/tools?search={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0e0c09" />
    <meta name="robots" content="index,follow,max-image-preview:large" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Outfit:wght@300;400;500;600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Outfit:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Velnora homepage" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <link rel="icon" type="image/svg+xml" href={faviconSvgImage} />
    <link rel="alternate icon" type="image/webp" href={faviconWebpImage} />

    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script is:inline>
      (() => {
        const key = 'velnora-theme';
        const saved = window.localStorage.getItem(key);
        const initial = saved === 'light' || saved === 'dark' ? saved : 'dark';
        document.documentElement.setAttribute('data-theme', initial);
      })();
    </script>
  </head>
  <body>
    <DesignOnly2Home client:idle />
  </body>
</html>
