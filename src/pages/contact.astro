---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Sameed Nawaz',
  description: 'Direct contact channels for collaboration and product work.',
};
---

<BaseLayout
  title="Contact"
  description="Direct contact channels for Sameed Nawaz including email, LinkedIn, and portfolio links."
>
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <Header />

  <main class="contact-page">
    <section class="contact-hero" data-reveal>
      <p class="eyebrow">Contact</p>
      <h1>Let us talk about your next build</h1>
      <p>
        The contact form is currently paused. Use direct channels below for project inquiries, partnerships,
        collaboration requests, or technical discussion.
      </p>
    </section>

    <section class="contact-grid" data-reveal>
      <article>
        <h2>Email</h2>
        <p>Fastest way to reach me for ongoing work and project questions.</p>
        <a href="mailto:sameednawaz1@gmail.com">sameednawaz1@gmail.com</a>
      </article>

      <article>
        <h2>LinkedIn</h2>
        <p>Professional updates, collaborations, and communication.</p>
        <a href="https://linkedin.com/in/sameed-nawaz-pak" target="_blank" rel="noopener noreferrer">
          linkedin.com/in/sameed-nawaz-pak
        </a>
      </article>

      <article>
        <h2>Portfolio</h2>
        <p>Explore my recent technical and creative work.</p>
        <a href="https://sameednawaz.tech/" target="_blank" rel="noopener noreferrer">sameednawaz.tech</a>
      </article>

      <article>
        <h2>Creative Showcase</h2>
        <p>Selected visual and product creative references.</p>
        <a
          href="https://playbook.com/s/ranasameednawaz/9qCfdH2PS4nHT5J4cvUboY3t"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open showcase
        </a>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .contact-page {
    max-width: 1080px;
    margin: 0 auto;
    padding: 2rem 1rem 3.2rem;
    display: grid;
    gap: 1rem;
  }

  .contact-hero {
    border: 1px solid var(--color-border);
    border-radius: 0.95rem;
    background: linear-gradient(130deg, rgba(255, 134, 56, 0.15), rgba(73, 102, 214, 0.11));
    box-shadow: var(--shadow-soft);
    padding: 1.2rem;
  }

  .eyebrow {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.09rem;
    font-weight: 800;
    color: #4d64c8;
    margin-bottom: 0.3rem;
  }

  .contact-hero h1 {
    margin-bottom: 0.5rem;
  }

  .contact-hero p {
    color: #35506f;
    line-height: 1.72;
    max-width: 80ch;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .contact-grid article {
    border: 1px solid rgba(36, 56, 83, 0.14);
    border-radius: 0.8rem;
    background: #fffef9;
    padding: 0.95rem;
    box-shadow: var(--shadow-soft);
    display: grid;
    gap: 0.5rem;
  }

  .contact-grid h2 {
    font-size: 1.05rem;
    color: #1f3554;
  }

  .contact-grid p {
    color: #47617f;
    font-size: 0.94rem;
    line-height: 1.6;
  }

  .contact-grid a {
    color: #2c45ad;
    word-break: break-word;
    font-weight: 700;
  }

  .contact-grid a:hover {
    color: #1f2f50;
  }

  @media (max-width: 680px) {
    .contact-page {
      padding: 1rem 0.8rem 2.6rem;
    }
  }
</style>
