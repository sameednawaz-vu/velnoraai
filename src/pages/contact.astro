---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Velnora Builder',
  description: 'Direct contact channels for Velnora collaboration and product questions.',
};
---

<BaseLayout
  title="Contact"
  description="Direct contact channels for Velnora including email, Reddit, and Facebook."
>
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <Header />

  <main class="page-shell contact-page">
    <section class="hero-panel" data-reveal>
      <p class="eyebrow">Contact</p>
      <h1>Contact channels</h1>
      <p class="lede">
        Use the channels below for collaboration requests, website questions, and product discussion.
      </p>
    </section>

    <section class="contact-grid" data-reveal>
      <article class="section-panel">
        <h2>Email</h2>
        <p>Fastest way to reach the builder for support and collaboration.</p>
        <a href="mailto:sameednawaz1@gmail.com">sameednawaz1@gmail.com</a>
      </article>

      <article class="section-panel">
        <h2>Reddit</h2>
        <p>Community updates and public discussions.</p>
        <a href="https://www.reddit.com/user/Velnoraai/" target="_blank" rel="noopener noreferrer">
          reddit.com/user/Velnoraai/
        </a>
      </article>

      <article class="section-panel">
        <h2>Facebook</h2>
        <p>Social updates and page visibility.</p>
        <a href="https://www.facebook.com/profile.php?id=61588840100652" target="_blank" rel="noopener noreferrer">
          facebook.com/profile.php?id=61588840100652
        </a>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.68rem;
  }

  .contact-grid article {
    display: grid;
    gap: 0.4rem;
  }

  .contact-grid h2 {
    font-size: 1rem;
  }

  .contact-grid p {
    color: color-mix(in srgb, var(--color-text) 76%, transparent);
    font-size: 0.84rem;
    line-height: 1.56;
  }

  .contact-grid a {
    color: var(--color-secondary);
    font-weight: 700;
    word-break: break-word;
    font-size: 0.82rem;
  }
</style>
