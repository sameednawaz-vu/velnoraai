---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import catalog from '../content/data/freeconvert-catalog.json';

const allTools = catalog.surfaces.flatMap((surface) =>
  surface.groups.flatMap((group) =>
    group.tools.map((tool) => ({
      surface: surface.name,
      surfaceSlug: surface.slug,
      group: group.name,
      groupSlug: group.slug,
      name: tool.name,
      slug: tool.slug,
      href: `/utility/${surface.slug}/${tool.slug}`,
    }))
  )
);

const workingTools = allTools;
const blockedToolRoutes: typeof allTools = [];

const unsupportedRules = [
  {
    name: 'Desktop-only document conversion removed',
    reason: 'Office/PDF/ebook conversion routes require desktop engines outside current browser-only stack.',
  },
  {
    name: 'HEIC browser decode instability',
    reason: 'HEIC/HEIF decode support is inconsistent across browsers and devices in pure browser workflows.',
  },
  {
    name: 'Generic converter routes disabled',
    reason: 'Broad converter routes were removed to avoid unsupported format pairs and unclear outcomes.',
  },
  {
    name: 'Archive conversion disabled in-browser',
    reason: 'Archive conversion still requires desktop-oriented tooling for reliable multi-format handling.',
  },
];

const unsupportedFormats = [
  'HEIC and HEIF conversion routes',
  'PDF to DOCX direct browser conversion',
  'DOCX to PDF office fidelity conversion',
  'EPUB to PDF and PDF to EPUB conversion',
  'General archive format conversion workflows',
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Velnora Working Tools Board',
  itemListElement: workingTools.map((entry, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: entry.name,
    url: `https://velnoraai.app${entry.href}`,
  })),
};
---

<BaseLayout
  title="Working Tools"
  description="Internal working-tools board showing currently functioning routes, unsupported rules, and blocked format classes."
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <Header />

  <main class="page-shell working-page">
    <section class="hero-panel" data-reveal>
      <p class="eyebrow">Owner board</p>
      <h1>Working tools status board</h1>
      <p class="lede">
        This page tracks currently functioning tool routes from the live catalog and highlights rules and formats that
        are not runnable in the active browser stack.
      </p>
      <ul class="chip-list">
        <li class="chip">{workingTools.length} active tools</li>
        <li class="chip">{catalog.surfaces.length} active surfaces</li>
        <li class="chip">{unsupportedFormats.length} blocked format classes</li>
      </ul>
    </section>

    <section class="section-panel" data-reveal>
      <h2>Surface board</h2>
      <div class="surface-board">
        {catalog.surfaces.map((surface) => (
          <article class="surface-card">
            <h3>{surface.name}</h3>
            <p>{surface.description}</p>

            <div class="group-grid">
              {surface.groups
                .map((group) => {
                  const groupWorkingTools = workingTools.filter(
                    (tool) => tool.surfaceSlug === surface.slug && tool.groupSlug === group.slug
                  );

                  if (!groupWorkingTools.length) {
                    return null;
                  }

                  return (
                    <section class="group-block">
                      <h4>{group.name}</h4>
                      <ul>
                        {groupWorkingTools.map((tool) => (
                          <li>
                            <a href={tool.href}>{tool.name}</a>
                          </li>
                        ))}
                      </ul>
                    </section>
                  );
                })}
            </div>
          </article>
        ))}
      </div>
    </section>

    {blockedToolRoutes.length > 0 && (
      <section class="section-panel" data-reveal>
        <h2>Mapped routes not browser-runnable yet</h2>
        <ul>
          {blockedToolRoutes.map((tool) => (
            <li>
              <strong>{tool.name}</strong>
              <p>{tool.surface} / {tool.group} route remains mapped but not browser-runnable in current stack.</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="section-panel" data-reveal>
      <h2>Rules not functioning properly right now</h2>
      <ul>
        {unsupportedRules.map((item) => (
          <li>
            <strong>{item.name}</strong>
            <p>{item.reason}</p>
          </li>
        ))}
      </ul>
    </section>

    <section class="section-panel" data-reveal>
      <h2>File formats currently not functionable</h2>
      <ul>
        {unsupportedFormats.map((formatName) => (
          <li>{formatName}</li>
        ))}
      </ul>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .working-page ul {
    margin: 0;
    padding-left: 1.05rem;
    display: grid;
    gap: 0.34rem;
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
  }

  .surface-board {
    display: grid;
    gap: 0.75rem;
  }

  .surface-card {
    border: 1px solid var(--color-border);
    border-radius: 0.8rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    padding: 0.75rem;
  }

  .surface-card h3 {
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }

  .surface-card p {
    color: color-mix(in srgb, var(--color-text) 74%, transparent);
    font-size: 0.84rem;
  }

  .group-grid {
    margin-top: 0.65rem;
    display: grid;
    gap: 0.55rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .group-block {
    border: 1px solid var(--color-border);
    border-radius: 0.68rem;
    background: color-mix(in srgb, var(--color-card-bg) 94%, transparent);
    padding: 0.58rem;
  }

  .group-block h4 {
    font-size: 0.88rem;
    color: var(--color-accent);
    margin-bottom: 0.35rem;
  }

  .group-block ul {
    padding-left: 0.95rem;
    gap: 0.2rem;
  }

  .group-block a {
    color: var(--color-primary);
    font-size: 0.8rem;
    font-weight: 600;
  }
</style>
