---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sameed Nawaz',
  jobTitle: 'Product Builder and AI Workflow Creator',
  description:
    'Technical creator focused on AI-powered products, UX-centric web experiences, and practical automation workflows.',
  url: 'https://sameednawaz.tech/',
  sameAs: [
    'https://linkedin.com/in/sameed-nawaz-pak',
    'https://playbook.com/s/ranasameednawaz/9qCfdH2PS4nHT5J4cvUboY3t',
  ],
};
---

<BaseLayout
  title="About Sameed Nawaz"
  description="Technical profile of Sameed Nawaz: AI product building, UX-forward web creation, and practical creative engineering."
  image="https://velnoraai.app/images/about-sameed.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <Header />

  <main class="about-page">
    <section class="hero-card" data-reveal>
      <div class="hero-photo-wrap">
        <img src="/images/about-sameed.jpg" alt="Sameed Nawaz" loading="eager" decoding="async" />
      </div>

      <div class="hero-copy">
        <p class="eyebrow">About Me</p>
        <h1>Sameed Nawaz</h1>
        <p>
          I build practical digital products where design clarity and technical execution move together. My core work is
          centered on AI workflows, web interfaces, and conversion-oriented tool experiences that are fast, reliable,
          and easy to use.
        </p>

        <div class="hero-links">
          <a href="https://sameednawaz.tech/" target="_blank" rel="noopener noreferrer">Portfolio</a>
          <a href="https://linkedin.com/in/sameed-nawaz-pak" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="mailto:sameednawaz1@gmail.com">Email</a>
        </div>
      </div>
    </section>

    <section class="about-section" data-reveal>
      <h2>Technical Focus</h2>
      <div class="focus-grid">
        <article>
          <h3>AI Product Workflows</h3>
          <p>
            Designing and shipping AI-supported utility surfaces, prompt frameworks, and deterministic browser-first
            tools that are useful in real production scenarios.
          </p>
        </article>

        <article>
          <h3>Web Experience Engineering</h3>
          <p>
            Building modern, responsive interfaces with strong navigation systems, scalable component patterns,
            performance-aware rendering, and clear user flows.
          </p>
        </article>

        <article>
          <h3>Creative Systems Thinking</h3>
          <p>
            Translating ideas into visual systems, reusable design language, and product narratives that improve both
            usability and brand recall.
          </p>
        </article>
      </div>
    </section>

    <section class="about-section" data-reveal>
      <h2>How I Build</h2>
      <ul class="workflow-list">
        <li>Start with user journey mapping and define the smallest version that creates clear value.</li>
        <li>Structure products with reusable components and data-driven routes for long-term scalability.</li>
        <li>Balance aesthetics with speed, accessibility, and deterministic fallbacks.</li>
        <li>Iterate quickly through measurable improvements in interaction clarity and conversion flow.</li>
      </ul>
    </section>

    <section class="about-section statement" data-reveal>
      <h2>Current Direction</h2>
      <p>
        I am currently focused on turning Velnora into a complete tool-first platform with polished UX, category-first
        discoverability, and production-ready client-side utility experiences.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .about-page {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1rem 3.5rem;
    display: grid;
    gap: 1.2rem;
  }

  .hero-card {
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1rem;
    background: linear-gradient(130deg, rgba(78, 113, 247, 0.08), rgba(255, 133, 40, 0.14));
    box-shadow: var(--shadow-soft);
    display: grid;
    grid-template-columns: minmax(140px, 220px) minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
  }

  .hero-photo-wrap {
    justify-self: center;
    width: 100%;
    max-width: 210px;
    border-radius: 0.9rem;
    overflow: hidden;
    border: 1px solid rgba(21, 43, 72, 0.2);
    box-shadow: 0 14px 24px rgba(19, 34, 57, 0.2);
    background: #d7ea74;
  }

  .hero-photo-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  .hero-copy h1 {
    margin-top: 0.2rem;
    margin-bottom: 0.5rem;
  }

  .hero-copy p {
    color: #344d6e;
    line-height: 1.72;
    max-width: 70ch;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08rem;
    text-transform: uppercase;
    color: #4f68ca;
  }

  .hero-links {
    margin-top: 0.85rem;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .hero-links a {
    border: 1px solid #c4d1e7;
    border-radius: 0.45rem;
    color: #223a58;
    background: rgba(255, 255, 255, 0.82);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.45rem 0.62rem;
  }

  .hero-links a:hover {
    border-color: #7e96e3;
    color: #1c2f4a;
  }

  .about-section {
    border: 1px solid var(--color-border);
    border-radius: 0.9rem;
    background: #fffdf8;
    box-shadow: var(--shadow-soft);
    padding: 1rem;
  }

  .about-section h2 {
    font-size: clamp(1.35rem, 2.5vw, 1.9rem);
    margin-bottom: 0.7rem;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .focus-grid article {
    border: 1px solid rgba(36, 56, 83, 0.12);
    border-radius: 0.7rem;
    background: #ffffff;
    padding: 0.85rem;
  }

  .focus-grid h3 {
    font-size: 1.05rem;
    margin-bottom: 0.3rem;
    color: #1f3554;
  }

  .focus-grid p {
    color: #445d7e;
    line-height: 1.6;
    font-size: 0.95rem;
  }

  .workflow-list {
    list-style: none;
    display: grid;
    gap: 0.45rem;
    padding: 0;
  }

  .workflow-list li {
    border: 1px solid rgba(36, 56, 83, 0.1);
    border-radius: 0.55rem;
    background: #ffffff;
    padding: 0.62rem 0.72rem;
    color: #364f70;
    line-height: 1.55;
    position: relative;
    padding-left: 2rem;
  }

  .workflow-list li::before {
    content: '';
    position: absolute;
    left: 0.72rem;
    top: 0.92rem;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #4a6bea, #ff7d2c);
  }

  .statement p {
    color: #374f70;
    line-height: 1.72;
    max-width: 78ch;
  }

  @media (max-width: 900px) {
    .hero-card {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-links {
      justify-content: center;
    }

    .hero-copy p {
      margin: 0 auto;
    }
  }

  @media (max-width: 680px) {
    .about-page {
      padding: 1rem 0.8rem 2.8rem;
    }

    .hero-photo-wrap {
      max-width: 180px;
    }
  }
</style>
