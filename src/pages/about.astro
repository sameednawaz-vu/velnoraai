---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withImageCdn } from '../lib/image-cdn';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sameed Nawaz',
  jobTitle: 'Velnora Builder and Workflow Product Creator',
  description:
    'Builder of Velnora, a tools-first website focused on practical browser workflows, conversion utilities, and fast execution UX.',
  url: 'https://velnoraai.app/about',
  sameAs: [
    'https://www.reddit.com/user/Velnoraai/',
    'https://www.facebook.com/profile.php?id=61588840100652',
  ],
};

const aboutImageAvif = withImageCdn('/images/about-sameed.avif');
const aboutImageWebp = withImageCdn('/images/about-sameed.webp');
const aboutImageJpg = withImageCdn('/images/about-sameed.jpg');
---

<BaseLayout
  title="About Velnora"
  description="Learn about Velnora and its builder, Sameed Nawaz. We provide a tools-first website focusing on practical workflows and secure conversion utilities."
  image={aboutImageWebp}
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <Header />

  <main class="page-shell about-page">
    <section class="hero-panel about-hero" data-reveal>
      <div class="hero-photo-wrap">
        <picture>
          <source srcset={aboutImageAvif} type="image/avif" />
          <source srcset={aboutImageWebp} type="image/webp" />
          <img src={aboutImageJpg} alt="Sameed Nawaz, Creator of Velnora" loading="eager" decoding="async" width="420" height="420" />
        </picture>
      </div>

      <div class="hero-copy">
        <p class="eyebrow">About Velnora</p>
        <h1>Empowering Fast, Secure Workflows</h1>
        <p class="lede">
          Velnora is a free, utility-first website designed for practical execution. Our mission is to provide you with secure, client-side tools so you can convert, compress, and run complex workflows directly in your browser.
        </p>

        <div class="cta-row">
          <a class="btn-link" href="https://velnoraai.app/">Website</a>
          <a class="btn-link" href="https://www.reddit.com/user/Velnoraai/" target="_blank" rel="noopener noreferrer">Reddit</a>
          <a class="btn-link" href="https://www.facebook.com/profile.php?id=61588840100652" target="_blank" rel="noopener noreferrer">Facebook</a>
        </div>
      </div>
    </section>

    <section class="section-panel" data-reveal>
      <h2>Our Core Values & Focus</h2>
      <div class="focus-grid">
        <article>
          <h3>100% Free & Accessible</h3>
          <p>
            We believe professional-grade utilities should not be hidden behind paywalls. Velnora prioritizes usable browser workflows for conversion, compression, and practical utility tasks that run without account friction.
          </p>
        </article>

        <article>
          <h3>Client-Side Privacy First</h3>
          <p>
            Your data remains yours. Our tools leverage modern WebAssembly to process files locally on your device. We do not upload your sensitive images or documents to remote servers, ensuring complete privacy.
          </p>
        </article>

        <article>
          <h3>Clear Route Architecture</h3>
          <p>
            Categories, tool routes, and expert blog guidance are organized for fast discovery. We help you move directly from search intent to task execution with zero distractions.
          </p>
        </article>
      </div>
    </section>

    <section class="section-panel" data-reveal>
      <h2>How Velnora is Built</h2>
      <ul class="workflow-list">
        <li><strong>Task Clarity:</strong> Start from user task clarity and keep each page focused on what users can do immediately.</li>
        <li><strong>Deterministic Outputs:</strong> Ship deterministic client-side workflows compatible with secure, static deployment constraints.</li>
        <li><strong>SEO & Technical Excellence:</strong> Prioritize responsive rendering, metadata quality, structured information architecture, and Core Web Vitals.</li>
        <li><strong>Continuous Iteration:</strong> Iterate through measured improvements in search UX, page clarity, and route reliability.</li>
      </ul>
    </section>

    <section class="section-panel" data-reveal>
      <h2>Meet the Builder</h2>
      <p class="lede" style="margin-bottom: 1rem;">
        Velnora is proudly built and maintained by <strong>Sameed Nawaz</strong>. 
      </p>
      <p style="color: color-mix(in srgb, var(--color-text) 78%, transparent); font-size: 0.9rem; line-height: 1.6;">
        With a deep focus on technical SEO, semantic content structuring, and robust frontend engineering, Sameed created Velnora as a long-term, free tools destination. The goal is to provide users with a clean, fast, and secure publishing workflow that solves everyday digital problems without compromise.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .about-hero {
    display: grid;
    grid-template-columns: minmax(200px, 300px) minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
  }

  .hero-photo-wrap {
    width: 100%;
    border-radius: 0.9rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    box-shadow: var(--shadow-soft);
  }

  .hero-photo-wrap img {
    width: 100%;
    display: block;
    height: auto;
  }

  .hero-copy {
    display: grid;
    gap: 0.65rem;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.65rem;
  }

  .focus-grid article {
    border: 1px solid var(--color-border);
    border-radius: 0.72rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    padding: 0.7rem;
  }

  .focus-grid h3 {
    font-size: 0.96rem;
    margin-bottom: 0.28rem;
    color: var(--color-primary);
  }

  .focus-grid p {
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
    font-size: 0.84rem;
    line-height: 1.58;
  }

  .workflow-list {
    list-style: none;
    display: grid;
    gap: 0.42rem;
    padding: 0;
  }

  .workflow-list li {
    border: 1px solid var(--color-border);
    border-radius: 0.62rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    padding: 0.58rem 0.68rem;
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
    line-height: 1.55;
    position: relative;
    padding-left: 1.85rem;
  }

  .workflow-list li::before {
    content: '';
    position: absolute;
    left: 0.66rem;
    top: 0.82rem;
    width: 0.64rem;
    height: 0.64rem;
    border-radius: 999px;
    background: linear-gradient(132deg, var(--color-secondary), var(--color-accent));
  }

  @media (max-width: 900px) {
    .about-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
