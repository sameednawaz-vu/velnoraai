---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { withImageCdn } from '../lib/image-cdn';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sameed Nawaz',
  jobTitle: 'Velnora Builder and Workflow Product Creator',
  description:
    'Builder of Velnora, a tools-first website focused on practical browser workflows, conversion utilities, and fast execution UX.',
  url: 'https://velnoraai.app/about',
  sameAs: ['https://linkedin.com/in/sameed-nawaz-pak'],
};

const aboutImageAvif = withImageCdn('/images/about-sameed.avif');
const aboutImageWebp = withImageCdn('/images/about-sameed.webp');
const aboutImageJpg = withImageCdn('/images/about-sameed.jpg');
---

<BaseLayout
  title="About Velnora"
  description="About Velnora and its builder: a tools-first website focused on practical browser workflows, conversion utilities, and clear execution UX."
  image={aboutImageWebp}
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <Header />

  <main class="page-shell about-page">
    <section class="hero-panel about-hero" data-reveal>
      <div class="hero-photo-wrap">
        <picture>
          <source srcset={aboutImageAvif} type="image/avif" />
          <source srcset={aboutImageWebp} type="image/webp" />
          <img src={aboutImageJpg} alt="Sameed Nawaz" loading="eager" decoding="async" width="420" height="420" />
        </picture>
      </div>

      <div class="hero-copy">
        <p class="eyebrow">About Velnora</p>
        <h1>Website and builder overview</h1>
        <p class="lede">
          Velnora is a free tools website designed for practical execution. The product direction is tools-first,
          client-side processing, and clear navigation so users can convert, compress, and run utility workflows
          quickly.
        </p>

        <div class="cta-row">
          <a class="btn-link" href="https://velnoraai.app/">Website</a>
          <a class="btn-link" href="https://linkedin.com/in/sameed-nawaz-pak" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        </div>
      </div>
    </section>

    <section class="section-panel" data-reveal>
      <h2>Website focus</h2>
      <div class="focus-grid">
        <article>
          <h3>Free utility execution</h3>
          <p>
            Velnora prioritizes usable browser workflows for conversion, compression, and practical utility tasks that
            can run without account friction.
          </p>
        </article>

        <article>
          <h3>Clear route architecture</h3>
          <p>
            Categories, tool routes, and blog guidance are organized for fast discovery and direct movement from search
            intent to execution.
          </p>
        </article>

        <article>
          <h3>Builder direction</h3>
          <p>
            The builder direction is to keep Velnora practical, stable, and continuously improved through production QA,
            SEO hygiene, and UX iteration.
          </p>
        </article>
      </div>
    </section>

    <section class="section-panel" data-reveal>
      <h2>How Velnora is built</h2>
      <ul class="workflow-list">
        <li>Start from user task clarity and keep each page focused on what users can do immediately.</li>
        <li>Ship deterministic client-side workflows compatible with static deployment constraints.</li>
        <li>Prioritize responsive rendering, metadata quality, and structured information architecture.</li>
        <li>Iterate through measured improvements in search UX, page clarity, and route reliability.</li>
      </ul>
    </section>

    <section class="section-panel" data-reveal>
      <h2>Builder note</h2>
      <p class="lede">
        Velnora is built by Sameed Nawaz and focused on long-term growth as a free tools destination with practical
        utility surfaces and a clean publishing workflow.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .about-hero {
    display: grid;
    grid-template-columns: minmax(200px, 300px) minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
  }

  .hero-photo-wrap {
    width: 100%;
    border-radius: 0.9rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    box-shadow: var(--shadow-soft);
  }

  .hero-photo-wrap img {
    width: 100%;
    display: block;
    height: auto;
  }

  .hero-copy {
    display: grid;
    gap: 0.65rem;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.65rem;
  }

  .focus-grid article {
    border: 1px solid var(--color-border);
    border-radius: 0.72rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    padding: 0.7rem;
  }

  .focus-grid h3 {
    font-size: 0.96rem;
    margin-bottom: 0.28rem;
    color: var(--color-primary);
  }

  .focus-grid p {
    color: color-mix(in srgb, var(--color-text) 78%, transparent);
    font-size: 0.84rem;
    line-height: 1.58;
  }

  .workflow-list {
    list-style: none;
    display: grid;
    gap: 0.42rem;
    padding: 0;
  }

  .workflow-list li {
    border: 1px solid var(--color-border);
    border-radius: 0.62rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    padding: 0.58rem 0.68rem;
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
    line-height: 1.55;
    position: relative;
    padding-left: 1.85rem;
  }

  .workflow-list li::before {
    content: '';
    position: absolute;
    left: 0.66rem;
    top: 0.82rem;
    width: 0.64rem;
    height: 0.64rem;
    border-radius: 999px;
    background: linear-gradient(132deg, var(--color-secondary), var(--color-accent));
  }

  @media (max-width: 900px) {
    .about-hero {
      grid-template-columns: 1fr;
    }
  }
</style>
