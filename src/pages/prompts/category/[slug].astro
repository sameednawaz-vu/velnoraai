---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PromptCard from '../../../components/PromptCard.astro';
import promptsData from '../../../content/data/prompts.json';

export async function getStaticPaths() {
  const categories = Object.keys(promptsData.categories);
  return categories.map((category) => ({
    params: { slug: category },
  }));
}

const { slug } = Astro.params;
const categoryData = promptsData.categories[slug as keyof typeof promptsData.categories];

if (!categoryData) {
  throw new Error(`Category ${slug} not found`);
}

const categorySchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${categoryData.name} Prompts`,
  description: categoryData.description,
  url: `https://velnoraai.app/prompts/category/${slug}`,
};

const promptListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${categoryData.name} Prompt List`,
  itemListElement: categoryData.prompts.map((prompt, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: prompt.title,
    url: `https://velnoraai.app/prompts/category/${slug}`,
  })),
};
---

<BaseLayout
  title={`${categoryData.name} Prompts`}
  description={`Browse ${categoryData.name.toLowerCase()} prompts. ${categoryData.description}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(categorySchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(promptListSchema)} />

  <Header />

  <main class="page-shell prompts-page">
    <section class="hero-panel" data-reveal>
      <div class="breadcrumb">
        <a href="/library">Prompts Library</a>
        <span>/</span>
        <span>{categoryData.name}</span>
      </div>
      <p class="eyebrow">Prompt category</p>
      <h1>{categoryData.name}</h1>
      <p class="lede">{categoryData.description}</p>
    </section>

    <section class="prompt-grid" data-reveal>
      {categoryData.prompts.map((prompt) => (
        <PromptCard
          title={prompt.title}
          description={prompt.description}
          example={prompt.example}
          useCase={prompt.useCase}
          category={prompt.category}
        />
      ))}
    </section>

    <section class="section-panel other-categories" data-reveal>
      <h2>Explore other categories</h2>
      <div class="category-links">
        {Object.entries(promptsData.categories).map(([key, cat]) =>
          key !== slug ? (
            <a href={`/prompts/category/${key}`} class="category-link">
              <span>{cat.name}</span>
              <small>Open prompts</small>
            </a>
          ) : null
        )}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.34rem;
    color: color-mix(in srgb, var(--color-text) 64%, transparent);
    font-size: 0.74rem;
    font-family: var(--font-mono);
  }

  .prompt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.68rem;
  }

  .other-categories {
    display: grid;
    gap: 0.65rem;
  }

  .other-categories h2 {
    margin: 0;
    font-size: 1.06rem;
  }

  .category-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.54rem;
  }

  .category-link {
    border: 1px solid var(--color-border);
    border-radius: 0.64rem;
    padding: 0.54rem 0.62rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
    display: grid;
    gap: 0.16rem;
    transition: transform var(--timing-medium), border-color var(--timing-medium);
  }

  .category-link span {
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.8rem;
  }

  .category-link small {
    color: color-mix(in srgb, var(--color-text) 66%, transparent);
    font-size: 0.68rem;
    font-family: var(--font-mono);
  }

  .category-link:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-secondary) 55%, transparent);
  }
</style>
