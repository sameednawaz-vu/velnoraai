---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PromptCard from '../../../components/PromptCard.astro';
import promptsData from '../../../content/prompts.json';

export async function getStaticPaths() {
  const categories = Object.keys(promptsData.categories);
  return categories.map((category) => ({
    params: { slug: category },
  }));
}

const { slug } = Astro.params;
const categoryData = promptsData.categories[slug as keyof typeof promptsData.categories];

if (!categoryData) {
  throw new Error(`Category ${slug} not found`);
}
---

<BaseLayout 
  title={`${categoryData.name} Prompts`}
  description={`Browse our ${categoryData.name.toLowerCase()} prompts. ${categoryData.description}`}
>
  <Header />
  
  <main class="prompts-page">
    <div class="container">
      <div class="breadcrumb">
        <a href="/library">Prompts Library</a>
        <span> / </span>
        <span>{categoryData.name}</span>
      </div>

      <h1>{categoryData.name}</h1>
      <p class="category-description">{categoryData.description}</p>

      <div class="prompts-grid">
        {categoryData.prompts.map((prompt) => (
          <PromptCard
            title={prompt.title}
            description={prompt.description}
            example={prompt.example}
            useCase={prompt.useCase}
            category={prompt.category}
          />
        ))}
      </div>

      <div class="explore-other">
        <h2>Explore Other Categories</h2>
        <div class="category-links">
          {Object.entries(promptsData.categories).map(([key, cat]) => (
            key !== slug && (
              <a href={`/prompts/category/${key}`} class="category-link">
                {cat.name}
              </a>
            )
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .prompts-page {
    padding: 3rem 2rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .breadcrumb {
    margin-bottom: 2rem;
    color: #666;
    font-size: 0.95rem;
  }

  .breadcrumb a {
    color: var(--color-secondary);
  }

  .prompts-page h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .category-description {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  .prompts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .explore-other {
    background: #f9f9f9;
    padding: 3rem;
    border-radius: 0.5rem;
    text-align: center;
  }

  .explore-other h2 {
    margin-bottom: 2rem;
    color: var(--color-primary);
  }

  .category-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .category-link {
    padding: 0.75rem 1.5rem;
    background-color: white;
    border: 2px solid var(--color-secondary);
    border-radius: 0.25rem;
    color: var(--color-secondary);
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .category-link:hover {
    background-color: var(--color-secondary);
    color: white;
  }

  @media (max-width: 768px) {
    .prompts-page h1 {
      font-size: 1.75rem;
    }

    .prompts-grid {
      grid-template-columns: 1fr;
    }

    .explore-other {
      padding: 2rem;
    }

    .category-links {
      gap: 0.5rem;
    }

    .category-link {
      font-size: 0.9rem;
      padding: 0.5rem 1rem;
    }
  }
</style>
