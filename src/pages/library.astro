---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const librarySchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Velnora Library',
  description: 'Workflow playbooks, tutorials, references, and templates for tool operations.',
  url: 'https://velnoraai.app/library',
};
---

<BaseLayout title="Library" description="Browse Velnora resources: workflows, tutorials, playbooks, and reference material for tools operations.">
  <script type="application/ld+json" set:html={JSON.stringify(librarySchema)} />

  <Header />

  <main class="page-shell library-page">
    <section class="hero-panel" data-reveal>
      <p class="eyebrow">Library</p>
      <h1>Resource library</h1>
      <p class="lede">Structured references and guides to help teams execute tool workflows with confidence.</p>
    </section>

    <section class="resource-grid" data-reveal>
      <article class="section-panel">
        <h2>Workflow playbooks</h2>
        <p>Step-by-step process maps for conversion, compression, and utility operations.</p>
      </article>

      <article class="section-panel">
        <h2>Tool tutorials</h2>
        <p>Practical how-to guides with examples, edge cases, and result validation tips.</p>
      </article>

      <article class="section-panel">
        <h2>Reference docs</h2>
        <p>Specifications, compatibility notes, and route-level implementation patterns.</p>
      </article>

      <article class="section-panel">
        <h2>Template kits</h2>
        <p>Reusable checklists and content structures for publishing high-quality tool pages.</p>
      </article>
    </section>

    <section class="section-panel" data-reveal>
      <h2>Featured resources</h2>
      <ul class="featured-list">
        <li>
          <h3>Tool onboarding checklist</h3>
          <p>Use this when launching a new tool route to ensure UX and technical readiness.</p>
        </li>
        <li>
          <h3>Conversion quality assurance guide</h3>
          <p>Validate output integrity, format consistency, and performance constraints before release.</p>
        </li>
        <li>
          <h3>Utility operations handbook</h3>
          <p>Build repeatable execution systems for daily utility tasks across teams.</p>
        </li>
        <li>
          <h3>SEO and GEO publishing reference</h3>
          <p>Document title, description, schema, and linking patterns so people can find the right page faster.</p>
        </li>
      </ul>
    </section>

    <section class="hero-panel" data-reveal>
      <h2>Need guided learning?</h2>
      <p class="lede">Visit the learning hub for category-based lessons, practical walkthroughs, and workflow examples.</p>
      <div class="cta-row">
        <a class="btn-link primary" href="/learning-hub">Open learning hub</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .resource-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.66rem;
  }

  .resource-grid article {
    display: grid;
    gap: 0.38rem;
  }

  .resource-grid h2 {
    font-size: 0.98rem;
  }

  .resource-grid p {
    color: color-mix(in srgb, var(--color-text) 76%, transparent);
    font-size: 0.83rem;
    line-height: 1.55;
  }

  .featured-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  .featured-list li {
    border: 1px solid var(--color-border);
    border-radius: 0.66rem;
    padding: 0.58rem 0.66rem;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
  }

  .featured-list h3 {
    font-size: 0.88rem;
    margin-bottom: 0.16rem;
    color: var(--color-primary);
  }

  .featured-list p {
    color: color-mix(in srgb, var(--color-text) 76%, transparent);
    font-size: 0.8rem;
    line-height: 1.52;
  }
</style>
