---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import StarterUtilityRunner from '../../../components/utility/StarterUtilityRunner';
import catalog from '../../../content/data/freeconvert-catalog.json';
import keywordIntel from '../../../content/data/seo-keywords.generated.json';

interface ToolEntry {
  name: string;
  slug: string;
  status: string;
}

interface GroupEntry {
  slug: string;
  name: string;
  tools: ToolEntry[];
}

interface SurfaceEntry {
  slug: string;
  name: string;
  description: string;
  groups: GroupEntry[];
}

interface CatalogEntry {
  surface: SurfaceEntry;
  group: GroupEntry;
  tool: ToolEntry;
}

type FormatProfile = 'video' | 'audio' | 'image' | 'document' | 'archive' | 'gif' | 'generic';

const normalizeFormatToken = (value: string) => value.trim().replace(/^\./, '').toLowerCase();

const formatAlias: Record<string, string> = {
  video: 'mp4',
  audio: 'mp3',
  image: 'png',
  document: 'pdf',
  ebook: 'pdf',
  pdf: 'pdf',
  archive: 'zip',
  jpeg: 'jpg',
};

const normalizeFormatChoice = (value: string) => formatAlias[normalizeFormatToken(value)] ?? normalizeFormatToken(value);

const cleanToken = (value: string) => value.trim().replace(/[-_]+/g, ' ').replace(/\s+/g, ' ').toLowerCase();

const toTitleCase = (value: string) =>
  value
    .replace(/\b\w/g, (char) => char.toUpperCase())
    .replace(/\s+/g, ' ')
    .trim();

const deriveIntentKeyword = (toolSlug: string, toolName: string) => {
  if (toolSlug.includes('-to-')) {
    return `${toolSlug.replace(/-/g, ' ')} converter`;
  }

  if (toolSlug.endsWith('-converter') || toolSlug.endsWith('-compressor')) {
    return `${toolSlug.replace(/-/g, ' ')}`;
  }

  return `${cleanToken(toolName)} tool`;
};

const buildSemanticKeywordSet = (intentKeyword: string, slug: string) => {
  const reusableKeywords = Array.isArray(keywordIntel.reusableKeywords) ? keywordIntel.reusableKeywords : [];
  const slugTemplates = keywordIntel.toolKeywordTemplates?.[slug] ?? [];

  const ranked = [...new Set([intentKeyword, ...slugTemplates, ...reusableKeywords])]
    .map((entry) => cleanToken(entry))
    .filter(Boolean)
    .slice(0, 10);

  return ranked;
};

const truncateToMetaLength = (value: string, maxLength = 158) => {
  if (value.length <= maxLength) {
    return value;
  }

  const trimmed = value.slice(0, maxLength - 1).trim();
  return `${trimmed}.`;
};

const buildSeoDescription = (toolName: string, primaryPhrase: string, secondaryPhrase: string) => {
  const description = `${toolName}: ${primaryPhrase} and ${secondaryPhrase}. Secure browser-first workflow with private processing where supported.`;
  return truncateToMetaLength(description);
};

const formatPools = {
  video: ['mp4', 'mov', 'mkv', 'avi', 'webm', 'mpeg'],
  audio: ['mp3', 'wav', 'ogg', 'aac', 'flac', 'm4a'],
  image: ['png', 'jpg', 'jpeg', 'webp', 'gif', 'svg', 'avif', 'bmp', 'jfif'],
  document: ['pdf', 'jpg', 'jpeg', 'png'],
  archive: ['zip'],
  gif: ['gif', 'mp4', 'webm', 'apng', 'mov', 'avi', 'png', 'jpg', 'jpeg', 'webp'],
  generic: ['txt', 'json', 'xml', 'csv'],
} as const;

const detectFormatProfile = (toolSlug: string, groupSlug: string): FormatProfile => {
  if (toolSlug.includes('gif') || groupSlug === 'gif') return 'gif';
  if (toolSlug.includes('archive')) return 'archive';
  if (toolSlug.includes('pdf') || toolSlug.includes('document') || toolSlug.includes('docx') || toolSlug.includes('ebook') || groupSlug.includes('pdf')) {
    return 'document';
  }
  if (toolSlug.includes('image') || toolSlug.includes('png') || toolSlug.includes('jpg') || toolSlug.includes('webp') || groupSlug.includes('image')) {
    return 'image';
  }
  if (toolSlug.includes('audio') || toolSlug.includes('mp3') || toolSlug.includes('wav') || toolSlug.includes('ogg')) {
    return 'audio';
  }
  if (toolSlug.includes('video') || toolSlug.includes('mp4') || toolSlug.includes('mov') || toolSlug.includes('avi') || toolSlug.includes('webm') || groupSlug.includes('video')) {
    return 'video';
  }
  return 'generic';
};

const getDefaultPair = (toolSlug: string, profile: FormatProfile) => {
  const options = formatPools[profile];
  const first = options[0] ?? 'txt';
  const second = options[1] ?? first;
  const conversionMatch = toolSlug.match(/^(.+)-to-(.+)$/);

  if (conversionMatch) {
    const from = normalizeFormatChoice(conversionMatch[1]);
    const to = normalizeFormatChoice(conversionMatch[2]);
    return {
      from: options.includes(from) ? from : first,
      to: options.includes(to) ? to : second,
    };
  }

  if (profile === 'video') return { from: 'mov', to: 'mp4' };
  if (profile === 'audio') return { from: 'wav', to: 'mp3' };
  if (profile === 'image') return { from: 'png', to: 'jpg' };
  if (profile === 'document') return { from: 'pdf', to: 'png' };
  if (profile === 'archive') return { from: 'zip', to: 'zip' };
  if (profile === 'gif') return { from: 'mp4', to: 'gif' };

  return { from: first, to: second };
};

export async function getStaticPaths() {
  return catalog.surfaces.flatMap((surface) =>
    surface.groups.flatMap((group) =>
      group.tools.map((tool) => ({
        params: {
          surface: surface.slug,
          slug: tool.slug,
        },
        props: {
          surface,
          group,
          tool,
        },
      }))
    )
  );
}

const { surface, group, tool } = Astro.props as CatalogEntry;
const hubHref = surface.slug === 'tools' ? '/utility-tools' : `/${surface.slug}`;
const toHubSlug = (groupSlug: string) => {
  if (groupSlug.includes('image')) return 'images';
  if (groupSlug.includes('video') || groupSlug.includes('audio')) return 'video-audio';
  if (groupSlug.includes('gif')) return 'gif';
  if (groupSlug.includes('pdf') || groupSlug.includes('document')) return 'pdf';
  return groupSlug;
};
const groupHubHref = `/utility/${toHubSlug(group.slug)}`;

const sameGroup = group.tools.filter((item) => item.slug !== tool.slug);
const sameSurface = surface.groups
  .flatMap((entry) => entry.tools)
  .filter((item) => item.slug !== tool.slug && !sameGroup.some((same) => same.slug === item.slug));

const relatedTools = [...sameGroup, ...sameSurface].slice(0, 4);
const normalizedStatus = tool.status === 'scaffold' || tool.status === 'starter' ? 'active' : tool.status;
const surfaceToolSlugs = surface.groups.flatMap((entry) => entry.tools.map((item) => item.slug));
const formatProfile = detectFormatProfile(tool.slug, group.slug);
const formatOptions = formatPools[formatProfile];
const defaultPair = getDefaultPair(tool.slug, formatProfile);

const convertSurface = catalog.surfaces.find((entry) => entry.slug === 'convert');
const conversionPairs = (convertSurface?.groups ?? []).flatMap((entry) =>
  entry.tools
    .map((candidate) => {
      const match = candidate.slug.match(/^([a-z0-9]+)-to-([a-z0-9]+)$/);
      if (!match) {
        return null;
      }

      return {
        name: candidate.name,
        slug: candidate.slug,
        href: `/utility/convert/${candidate.slug}`,
        from: normalizeFormatChoice(match[1]),
        to: normalizeFormatChoice(match[2]),
      };
    })
    .filter(
      (
        candidate
      ): candidate is { name: string; slug: string; href: string; from: string; to: string } => Boolean(candidate)
    )
);

const currentPairMatch = tool.slug.match(/^([a-z0-9]+)-to-([a-z0-9]+)$/);
const currentFrom = normalizeFormatChoice(currentPairMatch?.[1] ?? defaultPair.from);
const currentTo = normalizeFormatChoice(currentPairMatch?.[2] ?? defaultPair.to);

const recommendedConversionPairs: Array<{ name: string; href: string; reason: string }> = [];
const addRecommendedPair = (candidate: { name: string; slug: string; href: string; from: string; to: string }) => {
  if (candidate.slug === tool.slug || recommendedConversionPairs.some((entry) => entry.href === candidate.href)) {
    return;
  }

  if (recommendedConversionPairs.length >= 5) {
    return;
  }

  const reason = candidate.from === currentFrom ? `From ${currentFrom.toUpperCase()}` : `To ${currentTo.toUpperCase()}`;
  recommendedConversionPairs.push({
    name: candidate.name,
    href: candidate.href,
    reason,
  });
};

for (const candidate of conversionPairs) {
  if (candidate.from === currentFrom || candidate.to === currentTo) {
    addRecommendedPair(candidate);
  }
}

for (const candidate of conversionPairs) {
  if (recommendedConversionPairs.length >= 5) {
    break;
  }
  if (candidate.from === currentTo || candidate.to === currentFrom) {
    addRecommendedPair(candidate);
  }
}

for (const candidate of conversionPairs) {
  if (recommendedConversionPairs.length >= 5) {
    break;
  }
  addRecommendedPair(candidate);
}

const switchActionLabel =
  surface.slug === 'convert'
    ? 'Continue to convert'
    : surface.slug === 'compress'
      ? 'Continue to compress'
      : 'Open selected tool';

type SurfaceTemplate = {
  key: 'conversion' | 'compression' | 'utility';
  title: string;
  summary: string;
  checklist: string[];
};

type TrustedReference = {
  label: string;
  href: string;
};

const surfaceTemplate: SurfaceTemplate =
  surface.slug === 'convert'
    ? {
        key: 'conversion',
        title: 'How this converter page is organized',
        summary:
          'Pick your source and target format, then jump to the most accurate converter route without leaving your workflow.',
        checklist: [
          'The format switcher stays close to the main run area.',
          'Related converters are grouped so you can switch quickly.',
          'When an exact format pair exists, the page sends you there automatically.',
        ],
      }
    : surface.slug === 'compress'
      ? {
          key: 'compression',
          title: 'How this compression page is organized',
          summary:
            'This page keeps compression controls, quality checks, and related routes in one place so you can reduce file size with confidence.',
          checklist: [
            'Compression presets focus on size reduction and output quality.',
            'You can test one sample first before running a full batch.',
            'Helpful references are included for image, media, and document compression.',
          ],
        }
      : {
          key: 'utility',
          title: 'How this utility page is organized',
          summary:
            'This layout keeps the runner, related routes, and practical guidance close together so you can complete the task faster.',
          checklist: [
            'Status and controls stay visible while you work.',
            'Related tools are easy to open from the same screen.',
            'References are available if you want deeper technical detail.',
          ],
        };

const trustedReferences: TrustedReference[] =
  surface.slug === 'convert'
    ? [
        {
          label: 'IANA media type registry',
          href: 'https://www.iana.org/assignments/media-types/media-types.xhtml',
        },
        {
          label: 'Digital file format overview (Wikipedia)',
          href: 'https://en.wikipedia.org/wiki/File_format',
        },
      ]
    : surface.slug === 'compress'
      ? [
          {
            label: 'Data compression fundamentals (Wikipedia)',
            href: 'https://en.wikipedia.org/wiki/Data_compression',
          },
          {
            label: 'Image compression techniques (web.dev)',
            href: 'https://web.dev/learn/images/compression/',
          },
        ]
      : [
          {
            label: 'W3C File API recommendation',
            href: 'https://www.w3.org/TR/FileAPI/',
          },
          {
            label: 'MDN File and Blob interfaces',
            href: 'https://developer.mozilla.org/en-US/docs/Web/API/File',
          },
        ];

const intentKeyword = deriveIntentKeyword(tool.slug, tool.name);
const semanticKeywords = buildSemanticKeywordSet(intentKeyword, tool.slug);
const headlineKeyword = toTitleCase(semanticKeywords[0] ?? intentKeyword);
const templateKeywords = Array.isArray(keywordIntel.toolKeywordTemplates?.[tool.slug])
  ? keywordIntel.toolKeywordTemplates[tool.slug]
  : [];
const primarySemanticPhrase = cleanToken(templateKeywords[0] ?? semanticKeywords[0] ?? intentKeyword);
const secondarySemanticPhrase = cleanToken(templateKeywords[1] ?? semanticKeywords[1] ?? `free ${intentKeyword}`);
const privacyPromise =
  formatProfile === 'audio' || formatProfile === 'video' || formatProfile === 'image' || formatProfile === 'gif'
    ? 'For browser-native media routes, processing runs locally in your browser tab. Your file is not uploaded to a remote conversion server for these paths.'
    : 'This utility is browser-first. If a route needs desktop tooling or a different flow, the page tells you before you run it.';

const practicalBenefit =
  surface.slug === 'compress'
    ? `${tool.name} helps you reduce file size so uploads are faster, pages load quicker, and storage use stays lower.`
    : surface.slug === 'convert'
      ? `${tool.name} helps you move between file formats without switching tools, which keeps your workflow fast and predictable.`
      : `${tool.name} helps you finish this task in one browser workflow with no account setup.`;

const faqItems = [
  {
    question: `Is ${tool.name} free to use?`,
    answer:
      'Yes. This route is free to use and does not require signup. You can run a sample first, confirm the result, then process your full file set.',
  },
  {
    question: `What is the main advantage of using ${tool.name}?`,
    answer: `${practicalBenefit} Start with the recommended pair on this page (${currentFrom.toUpperCase()} to ${currentTo.toUpperCase()}) and switch formats if needed.`,
  },
  {
    question: `Will my files stay private while using ${tool.name}?`,
    answer: privacyPromise,
  },
];

const seoTitle = `${tool.name} | ${headlineKeyword}`;
const seoDescription = buildSeoDescription(tool.name, primarySemanticPhrase, secondarySemanticPhrase);

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name,
  applicationCategory: 'UtilityApplication',
  applicationSubCategory: `${surface.name} / ${group.name}`,
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  description: seoDescription,
  keywords: semanticKeywords.slice(0, 8),
  featureList: [
    'Client-side execution',
    'Deterministic output controls',
    'SEO-aware workflow guidance',
  ],
  url: `https://velnoraai.app/utility/${surface.slug}/${tool.slug}`,
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((entry) => ({
    '@type': 'Question',
    name: entry.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: entry.answer,
    },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://velnoraai.app/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Utility',
      item: 'https://velnoraai.app/utility-tools',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: surface.name,
      item: `https://velnoraai.app${hubHref}`,
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: group.name,
      item: `https://velnoraai.app${groupHubHref}`,
    },
    {
      '@type': 'ListItem',
      position: 5,
      name: tool.name,
      item: `https://velnoraai.app/utility/${surface.slug}/${tool.slug}`,
    },
  ],
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
>
  <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <Header />

  <main class={`utility-page surface-${surfaceTemplate.key}`}>
    <nav class="breadcrumb" aria-label="Breadcrumb" data-reveal>
      <a href="/">Home</a>
      <span>/</span>
      <a href="/utility-tools">Utility</a>
      <span>/</span>
      <a href={hubHref}>{surface.name}</a>
      <span>/</span>
      <a href={groupHubHref}>{group.name}</a>
      <span>/</span>
      <span>{tool.name}</span>
    </nav>

    <section class="hero" data-reveal>
      <div class="hero-layout">
        <div>
          <p class="eyebrow">{surface.name} / {group.name}</p>
          <h1>{tool.name}</h1>
          <p>
            Use this tool directly in your browser. Upload one file, choose your options, and run in a few clicks.
          </p>
          <div class="chips">
            <span>Surface: {surface.name}</span>
            <span>Group: {group.name}</span>
            <span>Status: {normalizedStatus}</span>
            <span>Profile: {toTitleCase(formatProfile)}</span>
          </div>
        </div>

        <aside class="hero-board" aria-label="Execution profile">
          <h2>{surfaceTemplate.title}</h2>
          <ul>
            <li>
              <span>Primary flow</span>
              <strong>{currentFrom.toUpperCase()} to {currentTo.toUpperCase()}</strong>
            </li>
            <li>
              <span>Execution mode</span>
              <strong>Browser-first and deterministic</strong>
            </li>
            <li>
              <span>Active route</span>
              <strong>/utility/{surface.slug}/{tool.slug}</strong>
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="runner-layout" data-reveal>
      <div class="runner-main">
        <StarterUtilityRunner
          client:load
          toolSlug={tool.slug}
          surfaceSlug={surface.slug}
          surfaceToolSlugs={surfaceToolSlugs}
        />
      </div>

      <aside class="recommended-rail" aria-label="Recommended tools">
        <h2>Recommended Tools</h2>
        <p>
          Related conversion pairs based on {currentFrom.toUpperCase()} and {currentTo.toUpperCase()}.
        </p>
        <ul>
          {recommendedConversionPairs.slice(0, 5).map((entry) => (
            <li>
              <a href={entry.href}>
                <strong>{entry.name}</strong>
                <span>{entry.reason}</span>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    </section>

    <section
      class="format-switcher"
      data-reveal
      data-format-switcher
      data-surface={surface.slug}
      data-current-tool={tool.slug}
      data-profile={formatProfile}
      data-tool-slugs={JSON.stringify(surfaceToolSlugs)}
    >
      <div class="switcher-head">
        <h2>Switch formats and jump to the best route</h2>
        <p>
          Select from/to formats, or upload one sample file to auto-detect the source format and route you to the most
          precise tool.
        </p>
      </div>

      <div class="switcher-grid">
        <label>
          From format
          <select data-switch-from>
            {formatOptions.map((entry) => (
              <option value={entry} selected={entry === defaultPair.from}>{entry.toUpperCase()}</option>
            ))}
          </select>
        </label>

        <label>
          To format
          <select data-switch-to>
            {formatOptions.map((entry) => (
              <option value={entry} selected={entry === defaultPair.to}>{entry.toUpperCase()}</option>
            ))}
          </select>
        </label>

        <a
          class="switch-action"
          data-switch-open
          href={`/utility/${surface.slug}/${tool.slug}?from=${defaultPair.from}&to=${defaultPair.to}`}
        >
          {switchActionLabel}
        </a>
      </div>

      <label class="switch-upload" for="switch-upload-input">
        Auto-detect source format from one file
        <input id="switch-upload-input" type="file" data-switch-file />
      </label>

      <p class="switch-status" data-switch-status>
        Selected formats: {defaultPair.from.toUpperCase()} to {defaultPair.to.toUpperCase()}.
      </p>

      <div class="switch-links">
        {sameGroup.slice(0, 8).map((entry) => (
          <a href={`/utility/${surface.slug}/${entry.slug}`}>{entry.name}</a>
        ))}
      </div>
    </section>

    <section class="template-brief" data-reveal>
      <h2>{surfaceTemplate.title}</h2>
      <p>{surfaceTemplate.summary}</p>
      <ul>
        {surfaceTemplate.checklist.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="privacy-proof" data-reveal>
      <h2>Privacy and processing clarity</h2>
      <p>{privacyPromise}</p>
    </section>

    <section class="readiness" data-reveal>
      <h2>Before you run this tool</h2>
      <ul>
        <li>Start with one small sample file so you can check quality before full runs.</li>
        <li>If output is not right, adjust settings and run again immediately.</li>
        <li>Use the related links below when you need a nearby format or utility option.</li>
      </ul>
    </section>

    <section class="related" data-reveal>
      <h2>Related utilities</h2>
      <div class="related-grid">
        {relatedTools.map((entry) => (
          <a href={`/utility/${surface.slug}/${entry.slug}`}>{entry.name}</a>
        ))}
      </div>
      <div class="cross-links">
        <a href={hubHref}>Back to {surface.name}</a>
        <a href={groupHubHref}>Browse {group.name} hub</a>
        <a href="/tools">Open Existing Tools Platform</a>
        <a href="/learning-hub">Open Learning Hub</a>
      </div>
    </section>

    <section class="faq-block" data-reveal itemScope itemType="https://schema.org/FAQPage">
      <h2>Common questions users ask</h2>
      <div class="faq-grid">
        {faqItems.map((entry) => (
          <article itemProp="mainEntity" itemScope itemType="https://schema.org/Question">
            <h3 itemProp="name">{entry.question}</h3>
            <p itemProp="acceptedAnswer" itemScope itemType="https://schema.org/Answer">
              <span itemProp="text">{entry.answer}</span>
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="reference-links" data-reveal>
      <h2>Trusted technical references</h2>
      <p>
        These references explain file formats, browser processing, and quality best practices if you want deeper detail.
      </p>
      <ul>
        <li>
          <a href="https://developer.mozilla.org/en-US/docs/WebAssembly" target="_blank" rel="noopener noreferrer">
            WebAssembly documentation (MDN)
          </a>
        </li>
        <li>
          <a href="https://ffmpeg.org/ffmpeg.html" target="_blank" rel="noopener noreferrer">
            FFmpeg command and processing reference
          </a>
        </li>
        <li>
          <a
            href="https://developers.google.com/search/docs/fundamentals/seo-starter-guide"
            target="_blank"
            rel="noopener noreferrer"
          >
            Google Search technical SEO starter guide
          </a>
        </li>
        {trustedReferences.map((entry) => (
          <li>
            <a href={entry.href} target="_blank" rel="noopener noreferrer">
              {entry.label}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector('[data-format-switcher]');
      if (!(root instanceof HTMLElement)) {
        return;
      }

      const fromSelect = root.querySelector('[data-switch-from]');
      const toSelect = root.querySelector('[data-switch-to]');
      const openLink = root.querySelector('[data-switch-open]');
      const statusNode = root.querySelector('[data-switch-status]');
      const fileInput = root.querySelector('[data-switch-file]');

      if (
        !(fromSelect instanceof HTMLSelectElement) ||
        !(toSelect instanceof HTMLSelectElement) ||
        !(openLink instanceof HTMLAnchorElement) ||
        !(statusNode instanceof HTMLElement)
      ) {
        return;
      }

      let toolSlugs = [];
      try {
        const parsed = JSON.parse(root.dataset.toolSlugs ?? '[]');
        toolSlugs = Array.isArray(parsed) ? parsed : [];
      } catch {
        toolSlugs = [];
      }

      const surface = root.dataset.surface ?? 'convert';
      const profile = root.dataset.profile ?? 'generic';
      const currentTool = root.dataset.currentTool ?? '';

      const profileFallback = {
        video: 'mov-to-mp4',
        audio: 'mp4-to-mp3',
        image: 'webp-to-png',
        document: 'pdf-merge',
        archive: currentTool,
        gif: 'video-to-gif',
        generic: currentTool,
      };

      const formatAliases = {
        jpeg: 'jpg',
        jpe: 'jpg',
        jfif: 'jpg',
        tif: 'tiff',
        ogv: 'ogg',
      };

      const slugVariantMap = {
        jpg: ['jpg', 'jpeg'],
        tiff: ['tiff', 'tif'],
      };

      const normalizeFormat = (value) => {
        const raw = (value || '').trim().toLowerCase();
        return formatAliases[raw] ?? raw;
      };

      const resolveTargetSlug = (from, to) => {
        const fromVariants = slugVariantMap[from] ?? [from];
        const toVariants = slugVariantMap[to] ?? [to];

        for (const fromVariant of fromVariants) {
          for (const toVariant of toVariants) {
            const exact = `${fromVariant}-to-${toVariant}`;
            if (toolSlugs.includes(exact)) {
              return exact;
            }
          }
        }

        const fallback = profileFallback[profile] ?? currentTool;
        if (typeof fallback === 'string' && toolSlugs.includes(fallback)) {
          return fallback;
        }
        return currentTool;
      };

      const optionExists = (value) => {
        return Array.from(fromSelect.options).some((entry) => entry.value === value);
      };

      const isExactRoute = (targetSlug, from, to) => {
        const fromVariants = slugVariantMap[from] ?? [from];
        const toVariants = slugVariantMap[to] ?? [to];
        for (const fromVariant of fromVariants) {
          for (const toVariant of toVariants) {
            if (targetSlug === `${fromVariant}-to-${toVariant}`) {
              return true;
            }
          }
        }
        return false;
      };

      const detectExtension = (name) => {
        const parts = String(name || '').toLowerCase().split('.');
        if (parts.length < 2) {
          return '';
        }
        return normalizeFormat(parts[parts.length - 1]);
      };

      const update = ({ autoNavigate = false } = {}) => {
        const from = normalizeFormat(fromSelect.value);
        const to = normalizeFormat(toSelect.value);
        const targetSlug = resolveTargetSlug(from, to);
        openLink.href = `/utility/${surface}/${targetSlug}?from=${encodeURIComponent(from)}&to=${encodeURIComponent(to)}`;

        if (isExactRoute(targetSlug, from, to)) {
          statusNode.textContent = `Ready: ${from.toUpperCase()} to ${to.toUpperCase()}.`;
        } else if (targetSlug === currentTool) {
          statusNode.textContent = `No exact tool yet. Staying on this page with ${from.toUpperCase()} to ${to.toUpperCase()}.`;
        } else {
          statusNode.textContent = `Using closest tool for ${from.toUpperCase()} to ${to.toUpperCase()}.`;
        }

        if (autoNavigate && targetSlug && targetSlug !== currentTool) {
          window.location.assign(openLink.href);
        }
      };

      fromSelect.addEventListener('change', () => update({ autoNavigate: false }));
      toSelect.addEventListener('change', () => update({ autoNavigate: false }));

      openLink.addEventListener('click', (event) => {
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey || event.button !== 0) {
          return;
        }
        event.preventDefault();
        update({ autoNavigate: false });
        window.location.assign(openLink.href);
      });

      if (fileInput instanceof HTMLInputElement) {
        fileInput.addEventListener('change', () => {
          const file = fileInput.files?.[0];
          const ext = detectExtension(file?.name ?? '');
          if (!ext) {
            return;
          }

          if (optionExists(ext)) {
            fromSelect.value = ext;
          } else {
            statusNode.textContent = `Detected ${ext.toUpperCase()}, but this route does not support it directly.`;
            return;
          }

          update({ autoNavigate: true });
        });
      }

      update({ autoNavigate: false });
    })();
  </script>

  <Footer />
</BaseLayout>

