---
import BlogPost from '../../layouts/BlogPost.astro';
import blogVisuals from '../../content/data/blog-visuals.json';
import { blogPosts, type BlogPostEntry } from '../../content/data/blog-posts';
import { withImageCdn } from '../../lib/image-cdn';

type BlogVisualEntry = {
  image: string;
  alt: string;
  caption: string;
};

export async function getStaticPaths() {
  const visualBySlug = blogVisuals as Record<string, BlogVisualEntry>;
  const postsWithVisuals = blogPosts.map((post) => ({
    ...post,
    image: withImageCdn(visualBySlug[post.slug]?.image ?? '/images/favicon-velnora.svg'),
    imageAlt: visualBySlug[post.slug]?.alt ?? `${post.title} illustration`,
    imageCaption: visualBySlug[post.slug]?.caption ?? post.description,
  }));

  return postsWithVisuals.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

const { title, description, publishedDate, author, readingTime, sections, checklist, image, imageAlt, imageCaption } =
  Astro.props as BlogPostEntry & { image?: string; imageAlt?: string; imageCaption?: string };
---

<BlogPost
  title={title}
  description={description}
  publishedDate={publishedDate}
  author={author}
  readingTime={readingTime}
  image={image}
  imageAlt={imageAlt}
  imageCaption={imageCaption}
>
  {sections.map((section) => (
    <>
      <h2>{section.heading}</h2>
      {section.body.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </>
  ))}

  <h2>Execution checklist</h2>
  <ul>
    {checklist.map((item) => (
      <li>{item}</li>
    ))}
  </ul>

  <p>
    Keep this framework connected to your tool pages and blog routes so users can move directly from guidance to
    execution.
  </p>
</BlogPost>
