---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import blogVisuals from '../../content/data/blog-visuals.json';
import { blogPosts } from '../../content/data/blog-posts';
import { withImageCdn } from '../../lib/image-cdn';

type BlogVisualEntry = {
  image: string;
  alt: string;
  caption: string;
};

const visualBySlug = blogVisuals as Record<string, BlogVisualEntry>;
const toAbsoluteImageUrl = (value: string) => {
  if (/^(https?:)?\/\//i.test(value)) {
    return value;
  }

  return `https://velnoraai.app${value.startsWith('/') ? value : `/${value}`}`;
};

const postsWithVisual = blogPosts.map((post) => {
  const sourceVisual = visualBySlug[post.slug] ?? {
    image: '/images/favicon-velnora.svg',
    alt: `${post.title} visual`,
    caption: post.excerpt,
  };

  return {
    title: post.title,
    slug: post.slug,
    excerpt: post.excerpt,
    date: post.publishedDate,
    category: post.category,
    readingTime: post.readingTime,
    visual: {
      ...sourceVisual,
      image: withImageCdn(sourceVisual.image),
    },
  };
});

const blogCategories = Array.from(new Set(postsWithVisual.map((post) => post.category))).sort((first, second) =>
  first.localeCompare(second)
);

const blogListSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Velnora Blog',
  description: 'Execution notes on conversion workflows, compression strategy, utility UX, and technical SEO.',
  url: 'https://velnoraai.app/blog',
  blogPost: postsWithVisual.map((post) => ({
    '@type': 'BlogPosting',
    headline: post.title,
    datePublished: post.date,
    image: toAbsoluteImageUrl(post.visual.image),
    url: `https://velnoraai.app/blog/${post.slug}`,
  })),
};
---

<BaseLayout
  title="Blog"
  description="Read practical posts on conversion workflows, compression strategy, utility UX, and technical SEO for tool websites."
>
  <script type="application/ld+json" set:html={JSON.stringify(blogListSchema)} />

  <Header />

  <main class="page-shell blog-page">
    <section class="hero-panel" data-reveal>
      <p class="eyebrow">Blog</p>
      <h1>Execution notes for a tools-first website</h1>
      <p class="lede">
        Tactical posts on conversion, compression, internal linking, metadata quality, and product-side publishing
        systems.
      </p>
    </section>

    <section class="post-list">
      {postsWithVisual.map((post) => (
        <article
          class="section-panel post-card"
          data-blog-card
          data-blog-title={post.title.toLowerCase()}
          data-blog-category={post.category.toLowerCase()}
          data-blog-excerpt={post.excerpt.toLowerCase()}
        >
          <a class="post-visual" href={`/blog/${post.slug}`}>
            <img src={post.visual.image} alt={post.visual.alt} width="1200" height="630" loading="lazy" decoding="async" />
          </a>
          <div class="post-meta">
            <span class="chip category">{post.category}</span>
            <span class="time">{post.readingTime} min read</span>
          </div>
          <h2>
            <a href={`/blog/${post.slug}`}>{post.title}</a>
          </h2>
          <p>{post.excerpt}</p>
          <div class="post-footer">
            <time datetime={post.date}>
              {new Date(post.date).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
            <a href={`/blog/${post.slug}`} class="read-link">
              Read article
            </a>
          </div>
        </article>
      ))}
      <p class="empty-state" data-blog-empty hidden>No posts match this search yet. Try a broader term.</p>

      <div class="blog-pagination" data-blog-pagination hidden>
        <button type="button" data-blog-prev>Previous</button>
        <span data-blog-page-info>Page 1 of 1</span>
        <button type="button" data-blog-next>Next</button>
      </div>
    </section>

    <section class="section-panel blog-search" data-reveal>
      <label for="blog-search-input">Search blog posts</label>
      <div class="search-row">
        <input
          id="blog-search-input"
          type="search"
          placeholder="Search by title, category, or topic"
          autocomplete="off"
          data-blog-search-input
        />
        <select aria-label="Filter blog by category" data-blog-category>
          <option value="all">All categories</option>
          {blogCategories.map((category) => (
            <option value={category}>{category}</option>
          ))}
        </select>
      </div>
    </section>

    <section class="hero-panel weekly-cta" data-reveal>
      <h2>Weekly publishing rhythm</h2>
      <p class="lede">
        New entries cover practical improvements in route UX, tool content structure, and search-oriented implementation.
      </p>
      <div class="cta-row">
        <a class="btn-link primary" href="/tools">Open live tools</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  (() => {
    const container = document.querySelector('.blog-page');
    if (!(container instanceof HTMLElement)) {
      return;
    }

    const queryInput = container.querySelector('[data-blog-search-input]');
    const categorySelect = container.querySelector('[data-blog-category]');
    const cards = Array.from(container.querySelectorAll('[data-blog-card]'));
    const emptyState = container.querySelector('[data-blog-empty]');
    const paginationShell = container.querySelector('[data-blog-pagination]');
    const prevButton = container.querySelector('[data-blog-prev]');
    const nextButton = container.querySelector('[data-blog-next]');
    const pageInfo = container.querySelector('[data-blog-page-info]');
    const pageSize = 10;
    let currentPage = 1;

    if (!(queryInput instanceof HTMLInputElement) || !(categorySelect instanceof HTMLSelectElement)) {
      return;
    }

    const renderPagination = (visibleCards) => {
      const totalPages = Math.max(1, Math.ceil(visibleCards.length / pageSize));
      currentPage = Math.min(currentPage, totalPages);

      const pageStart = (currentPage - 1) * pageSize;
      const pageEnd = pageStart + pageSize;
      const pageCards = new Set(visibleCards.slice(pageStart, pageEnd));

      cards.forEach((card) => {
        if (!(card instanceof HTMLElement)) {
          return;
        }

        if (card.hidden) {
          return;
        }

        card.hidden = !pageCards.has(card);
      });

      if (paginationShell instanceof HTMLElement) {
        paginationShell.hidden = visibleCards.length <= pageSize || visibleCards.length === 0;
      }

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = currentPage <= 1;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = currentPage >= totalPages;
      }

      if (pageInfo instanceof HTMLElement) {
        pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
      }
    };

    const applyFilter = (resetPage = false) => {
      if (resetPage) {
        currentPage = 1;
      }

      const query = queryInput.value.trim().toLowerCase();
      const category = categorySelect.value.trim().toLowerCase();
      const visibleCards = [];

      cards.forEach((card) => {
        if (!(card instanceof HTMLElement)) {
          return;
        }

        const title = card.dataset.blogTitle ?? '';
        const categoryValue = card.dataset.blogCategory ?? '';
        const excerpt = card.dataset.blogExcerpt ?? '';
        const categoryMatches = category === 'all' || categoryValue === category;
        const queryMatches =
          query.length === 0 || title.includes(query) || categoryValue.includes(query) || excerpt.includes(query);
        const isVisible = categoryMatches && queryMatches;

        card.hidden = !isVisible;
        if (isVisible) {
          visibleCards.push(card);
        }
      });

      if (emptyState instanceof HTMLElement) {
        emptyState.hidden = visibleCards.length > 0;
      }

      renderPagination(visibleCards);
    };

    queryInput.addEventListener('input', () => applyFilter(true));
    categorySelect.addEventListener('change', () => applyFilter(true));

    if (prevButton instanceof HTMLButtonElement) {
      prevButton.addEventListener('click', () => {
        if (currentPage <= 1) {
          return;
        }

        currentPage -= 1;
        applyFilter(false);
      });
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.addEventListener('click', () => {
        currentPage += 1;
        applyFilter(false);
      });
    }

    applyFilter(true);
  })();
</script>

<style>
  .blog-search {
    display: grid;
    gap: 0.46rem;
  }

  .blog-search label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06rem;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-text) 66%, transparent);
  }

  .search-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(180px, 220px);
    gap: 0.45rem;
  }

  .search-row input,
  .search-row select {
    border: 1px solid color-mix(in srgb, var(--color-border) 80%, var(--color-secondary));
    background: color-mix(in srgb, var(--color-card-bg) 94%, transparent);
    border-radius: 0.64rem;
    min-height: 2.2rem;
    padding: 0 0.7rem;
    color: var(--color-text);
    font-size: 0.8rem;
  }

  .search-row input::placeholder {
    color: color-mix(in srgb, var(--color-text) 54%, transparent);
  }

  .empty-state {
    margin: 0;
    border: 1px dashed color-mix(in srgb, var(--color-border) 82%, transparent);
    border-radius: 0.68rem;
    padding: 0.72rem;
    color: color-mix(in srgb, var(--color-text) 72%, transparent);
    font-size: 0.82rem;
  }

  .post-list {
    display: grid;
    gap: 0.68rem;
  }

  .blog-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 0.4rem;
  }

  .blog-pagination button {
    border: 1px solid color-mix(in srgb, var(--color-border) 84%, var(--color-secondary));
    background: color-mix(in srgb, var(--color-card-bg) 90%, transparent);
    border-radius: 0.5rem;
    min-height: 2rem;
    padding: 0 0.78rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
  }

  .blog-pagination button:hover,
  .blog-pagination button:focus-visible {
    border-color: color-mix(in srgb, var(--color-secondary) 60%, transparent);
  }

  .blog-pagination button:disabled {
    opacity: 0.42;
    cursor: not-allowed;
  }

  .blog-pagination span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-text) 68%, transparent);
  }

  .post-card {
    display: grid;
    gap: 0.5rem;
  }

  .post-visual {
    display: block;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 26%, var(--color-border));
    border-radius: 0.68rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-card-bg) 90%, transparent);
  }

  .post-visual img {
    width: 100%;
    height: auto;
    display: block;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .category {
    border-color: color-mix(in srgb, var(--color-secondary) 56%, transparent);
    background: color-mix(in srgb, var(--color-secondary) 16%, transparent);
  }

  .time {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: color-mix(in srgb, var(--color-text) 64%, transparent);
  }

  .post-card h2 {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.4;
  }

  .post-card h2 a {
    color: var(--color-primary);
  }

  .post-card p {
    margin: 0;
    color: color-mix(in srgb, var(--color-text) 76%, transparent);
    font-size: 0.84rem;
    line-height: 1.58;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.4rem;
    border-top: 1px dashed color-mix(in srgb, var(--color-text) 18%, transparent);
    padding-top: 0.42rem;
    font-size: 0.74rem;
    color: color-mix(in srgb, var(--color-text) 60%, transparent);
    font-family: var(--font-mono);
  }

  .read-link {
    color: var(--color-secondary);
    font-weight: 700;
    font-family: var(--font-heading);
    font-size: 0.74rem;
  }

  .weekly-cta {
    text-align: center;
  }

  @media (max-width: 760px) {
    .search-row {
      grid-template-columns: 1fr;
    }
  }
</style>
