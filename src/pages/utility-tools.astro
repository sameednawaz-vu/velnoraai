---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SurfaceHub from '../components/utility/SurfaceHub.astro';
import catalog from '../content/data/freeconvert-catalog.json';

const surface = catalog.surfaces.find((entry) => entry.slug === 'tools');
if (!surface) {
  throw new Error('Utility Tools surface catalog not found.');
}

const allTools = surface.groups.flatMap((group) => group.tools);
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Utility tools by Velnora',
  itemListElement: allTools.map((tool, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: tool.name,
    url: `https://velnoraai.app/utility/${surface.slug}/${tool.slug}`,
  })),
};
---

<BaseLayout
  title="Utility Tools"
  description="FreeConvert-style utility tools surface for Velnora with image, video, and PDF operations."
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <Header />

  <main class="page-shell surface-page">
    <SurfaceHub surface={surface} eyebrow="Tools Surface" />

    <section class="section-panel" data-reveal>
      <h2>Tooling sequence</h2>
      <p class="lede">
        Utility operations are categorized and route-live. Starter deterministic tools are active, while advanced
        image/PDF transforms are rolling out in progressive implementation waves.
      </p>
      <div class="cta-row">
        <a class="btn-link" href="/convert">Open Convert Surface</a>
        <a class="btn-link" href="/compress">Open Compress Surface</a>
        <a class="btn-link" href="/blog">Open Blog Guides</a>
        <a class="btn-link" href="/tools">Browse Existing Tools Platform</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
