---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const learningHubSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Velnora Learning Hub',
  description: 'Practical guides on conversion, compression, utility workflows, and content systems.',
  url: 'https://velnoraai.app/learning-hub',
};
---

<BaseLayout title="Learning Hub" description="Practical guides on conversion workflows, utility operations, tool QA, and technical SEO execution.">
  <script type="application/ld+json" set:html={JSON.stringify(learningHubSchema)} />

  <Header />

  <main class="page-shell learning-hub">
    <section class="hero-panel" data-reveal>
      <p class="eyebrow">Learning hub</p>
      <h1>Tools learning hub</h1>
      <p class="lede">Master practical workflows for conversion, compression, and utility execution.</p>
    </section>

    <section class="learning-grid" data-reveal>
      <article class="section-panel learning-card">
        <h2>Getting started with tool workflows</h2>
        <p>Learn how to select the right tool, prepare clean inputs, and ship reliable outputs for common web tasks.</p>
        <ul class="topics">
          <li>Choosing the right tool route</li>
          <li>Input cleanup and validation</li>
          <li>Output quality checks</li>
          <li>First end-to-end workflow</li>
        </ul>
      </article>

      <article class="section-panel learning-card">
        <h2>Conversion and compression fundamentals</h2>
        <p>Use proven techniques for file conversion and compression without breaking quality or workflow speed.</p>
        <ul class="topics">
          <li>Format compatibility basics</li>
          <li>Quality vs file size tradeoffs</li>
          <li>Batch execution patterns</li>
          <li>Review and fallback checks</li>
        </ul>
      </article>

      <article class="section-panel learning-card">
        <h2>Advanced utility operations</h2>
        <p>Master strategies for high-volume jobs, QA gates, and repeatable team-oriented execution.</p>
        <ul class="topics">
          <li>High-volume queue patterns</li>
          <li>Operator checklists</li>
          <li>Post-run validation</li>
          <li>Error recovery flow</li>
        </ul>
      </article>

      <article class="section-panel learning-card">
        <h2>Content systems for tool sites</h2>
        <p>Build content that explains tool usage clearly and supports stronger indexing across search and images.</p>
        <ul class="topics">
          <li>Explanatory article structure</li>
          <li>Internal linking strategy</li>
          <li>Image-first education blocks</li>
          <li>Metadata consistency</li>
        </ul>
      </article>

      <article class="section-panel learning-card">
        <h2>Operational playbooks</h2>
        <p>Document workflows so teams run conversion and utility tasks with fewer mistakes and better handoffs.</p>
        <ul class="topics">
          <li>Intake and prioritization</li>
          <li>Standard operating procedures</li>
          <li>Review checkpoints</li>
          <li>Delivery and handoff notes</li>
        </ul>
      </article>

      <article class="section-panel learning-card">
        <h2>Tool mastery</h2>
        <p>Get detailed guides on using conversion, compression, and utility tools effectively and efficiently.</p>
        <ul class="topics">
          <li>Tool-specific workflows</li>
          <li>Cross-tool chaining</li>
          <li>Integration workflows</li>
          <li>Productivity tips</li>
        </ul>
      </article>
    </section>

    <section class="hero-panel" data-reveal>
      <h2>Ready to dive deeper?</h2>
      <p class="lede">Explore detailed articles, examples, and reusable workflow templates in the library.</p>
      <div class="cta-row">
        <a href="/library" class="btn-link primary">Browse workflow library</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .learning-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 0.7rem;
  }

  .learning-card {
    display: grid;
    gap: 0.5rem;
  }

  .learning-card h2 {
    font-size: 1rem;
  }

  .learning-card p {
    color: color-mix(in srgb, var(--color-text) 76%, transparent);
    font-size: 0.84rem;
    line-height: 1.58;
  }

  .topics {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.28rem;
  }

  .topics li {
    padding: 0.34rem 0.45rem 0.34rem 1.35rem;
    border: 1px solid var(--color-border);
    border-radius: 0.58rem;
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
    font-size: 0.78rem;
    position: relative;
    background: color-mix(in srgb, var(--color-card-bg) 92%, transparent);
  }

  .topics li::before {
    content: '';
    position: absolute;
    left: 0.5rem;
    top: 0.58rem;
    width: 0.54rem;
    height: 0.54rem;
    border-radius: 999px;
    background: linear-gradient(130deg, var(--color-accent), var(--color-secondary));
  }
</style>
